      "option": [
        {
          "name": "--before",
          "tip": [
            "U: --before <BEFORE>",
            "选择在此时间点之前运行的所有命令"
          ],
          "next": 0
        },
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "输出格式（默认 json）"
          ],
          "next": [
            {
              "name": "csv",
              "tip": [
                "CSV 格式"
              ]
            },
            {
              "name": "json",
              "tip": [
                "JSON 格式"
              ]
            }
          ]
        },
        {
          "name": "--regex",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --regex <REGEX>",
            "要求命令匹配指定的正则表达式"
          ],
          "next": 0
        },
        {
          "name": "--since",
          "tip": [
            "U: --since <SINCE>",
            "选择在此时间点之后运行的所有命令"
          ],
          "next": 0
        },
        {
          "name": "--sort",
          "alias": [
            "-s"
