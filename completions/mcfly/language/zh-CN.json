      ],
      "next": [
        {
          "name": "bash",
          "tip": [
            "Bash 历史格式"
          ]
        },
        {
          "name": "fish",
          "tip": [
            "Fish 历史格式"
          ]
        },
        {
          "name": "zsh",
          "tip": [
            "Zsh 历史格式"
          ]
        },
        {
          "name": "zsh-extended",
          "tip": [
            "Zsh 扩展历史格式"
          ]
        }
      ]
    },
    {
      "name": "--mcfly_history",
      "tip": [
        "U: --mcfly_history <MCFLY_HISTORY>",
        "添加或搜索时读取的 shell 历史文件（默认 $MCFLY_HISTORY）"
      ],
      "next": 0
