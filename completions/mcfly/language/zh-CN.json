{
  "meta": {
    "url": "https://github.com/cantino/mcfly",
    "description": [
      "在 Shell 历史记录中快速穿梭"
    ]
  },
  "next": [
    {
      "name": "add",
      "tip": [
        "U: add [OPTIONS] [COMMAND]...",
        "将命令添加到历史记录"
      ],
      "option": [
        {
          "name": "--append-to-histfile",
          "alias": [
            "-a"
          ],
          "tip": [
            "U: -a, --append-to-histfile <HISTFILE>",
            "同时将命令追加到指定文件"
          ],
          "next": 0
        },
        {
          "name": "--dir",
          "alias": [
            "-d"
          ],
          "tip": [
            "U: -d, --dir <PATH>",
            "命令执行时的目录（默认 $PWD）"
          ],
          "next": 0
        },
        {
          "name": "--exit",
          "alias": [
            "-e"
          ],
          "tip": [
            "U: -e, --exit <EXIT_CODE>",
            "命令的退出码"
          ],
          "next": 0
        },
        {
          "name": "--old-dir",
          "alias": [
            "-o"
          ],
          "tip": [
            "U: -o, --old-dir <PATH>",
            "执行命令前用户所在的目录（默认 $OLDPWD）"
          ],
          "next": 0
        },
        {
          "name": "--when",
          "alias": [
            "-w"
