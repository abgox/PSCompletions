        {
          "name": "fish",
          "tip": [
            "为 fish 初始化"
          ]
        },
        {
          "name": "powershell",
          "tip": [
            "为 powershell 初始化"
          ]
        },
        {
          "name": "zsh",
          "tip": [
            "为 zsh 初始化"
          ]
        }
      ]
    },
    {
      "name": "move",
      "tip": [
        "U: move <OLD_DIR_PATH> <NEW_DIR_PATH>",
        "记录目录移动；将命令记录从旧路径迁移到新路径"
      ]
    },
    {
      "name": "search",
      "tip": [
        "U: search [OPTIONS] [COMMAND]...",
        "搜索历史记录"
      ],
      "option": [
        {
          "name": "--delete_without_confirm",
          "tip": [
            "无需确认直接删除条目"
          ]
        },
        {
          "name": "--dir",
          "alias": [
            "-d"
          ],
          "tip": [
            "U: -d, --dir <PATH>",
            "命令执行时的目录（默认 $PWD）"
          ],
          "next": 0
        },
        {
          "name": "--fuzzy",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --fuzzy <FUZZY>",
            "模糊搜索结果。0 为关闭；数值越高，越倾向于匹配较短或较早的记录"
          ],
          "next": 0
        },
        {
          "name": "--output-selection",
          "alias": [
            "-o"
          ],
          "tip": [
            "U: -o, --output-selection <PATH>",
            "将结果写入文件，包含选择模式、新命令行以及特定 shell 的请求"
          ],
          "next": 0
        },
        {
          "name": "--results",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --results <NUMBER>",
            "返回的结果数量"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "stats",
      "tip": [
        "U: stats [OPTIONS]",
        "输出统计信息"
      ],
      "option": [
        {
          "name": "--cmds",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --cmds <cmds>",
