          ],
          "next": 0
        },
        {
          "name": "--dirs",
          "alias": [
            "-d"
          ],
          "tip": [
            "U: -d, --dirs <dirs>",
            "按顶级目录分类显示（默认: 0，即不限制目录）"
          ],
          "next": 0
        },
        {
          "name": "--global-commands-to-ignore",
          "alias": [
            "-g"
