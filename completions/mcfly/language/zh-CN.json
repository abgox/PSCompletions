          ],
          "next": 0
        },
        {
          "name": "--min-cmd-length",
          "alias": [
            "-m"
          ],
          "tip": [
            "U: -m, --min-cmd-length <min_cmd_length>",
            "列入\"top-n\"命令的最小命令长度（默认: 0）"
          ],
          "next": 0
        },
        {
          "name": "--only-dir",
          "alias": [
            "-o"
          ],
          "tip": [
            "U: -o, --only-dir <ONLY_DIR>",
            "仅显示来自指定目录的命令"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "train",
      "tip": [
        "U: train [OPTIONS]",
        "训练建议引擎（开发者工具）"
      ],
      "option": [
        {
          "name": "--refresh_cache",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --refresh_cache",
            "刷新建议缓存"
          ]
        }
      ]
