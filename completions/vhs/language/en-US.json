{
  "meta": {
    "url": "https://github.com/charmbracelet/vhs",
    "description": [
      "Your CLI home video recorder.",
      "Record terminal GIFs from shell scripts"
    ]
  },
  "next": [
    {
      "name": "new",
      "tip": [
        "U: new <NAME>",
        "Create a new tape file with example tape file contents and documentation"
      ]
    },
    {
      "name": "publish",
      "tip": [
        "U: publish <GIF>",
        "Publish your GIF to vhs.charm.sh and get a shareable URL"
      ]
    },
    {
      "name": "record",
      "tip": [
        "U: record [OPTIONS]",
        "Create a new tape file by recording your actions"
      ],
      "option": [
        {
          "name": "--shell",
          "alias": [
            "-s"
          ],
          "tip": [
            "U: -s, --shell <SHELL>",
            "Shell for recording"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "serve",
      "tip": [
        "U: serve",
        "Start the VHS SSH server"
      ]
    },
    {
      "name": "themes",
      "tip": [
        "U: themes",
        "List all the available themes, one per line"
      ]
    },
    {
      "name": "validate",
      "tip": [
        "U: validate <FILE>...",
        "Validate a glob file path and parses all the files to ensure they are valid without running them"
      ]
    }
  ],
  "option": [
    {
      "name": "--output",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --output <FILE>",
        "File name(s) of video output"
      ],
      "repeat": 99
    },
    {
      "name": "--publish",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --publish",
        "Publish your GIF to vhs.charm.sh and get a shareable URL"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "Quiet mode, do not log messages"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Print the version"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show help"
      ]
    }
  ]
}
