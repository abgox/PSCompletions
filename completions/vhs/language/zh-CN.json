{
  "meta": {
    "url": "https://github.com/charmbracelet/vhs",
    "description": [
      "你的 CLI 家庭录像机",
      "从 Shell 脚本录制终端 GIF"
    ]
  },
  "next": [
    {
      "name": "new",
      "tip": [
        "U: new <NAME>",
        "创建一个新的 tape 文件，包含示例内容和文档"
      ]
    },
    {
      "name": "publish",
      "tip": [
        "U: publish <GIF>",
        "将 GIF 发布到 vhs.charm.sh 并获取可分享的 URL"
      ]
    },
    {
      "name": "record",
      "tip": [
        "U: record [OPTIONS]",
        "通过录制你的操作创建新的 tape 文件"
      ],
      "option": [
        {
          "name": "--shell",
          "alias": [
            "-s"
          ],
          "tip": [
            "U: -s, --shell <SHELL>",
            "用于录制的 Shell"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "serve",
      "tip": [
        "U: serve",
        "启动 VHS SSH 服务器"
      ]
    },
    {
      "name": "themes",
      "tip": [
        "U: themes",
        "列出所有可用的主题，每行一个"
      ]
    },
    {
      "name": "validate",
      "tip": [
        "U: validate <FILE>...",
        "验证 glob 文件路径并解析所有文件以确保有效，但不运行"
      ]
    }
  ],
  "option": [
    {
      "name": "--output",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --output <FILE>",
        "视频输出的文件名"
      ],
      "repeat": 99
    },
    {
      "name": "--publish",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --publish",
        "将 GIF 发布到 vhs.charm.sh 并获取可分享的 URL"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "静默模式，不输出日志消息"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "打印版本"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助"
      ]
    }
  ]
}
