{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "编码/解码数据并输出到标准输出。"
    ]
  },
  "option": [
    {
      "name": "--base16",
      "tip": [
        "十六进制编码"
      ]
    },
    {
      "name": "--base2lsbf",
      "tip": [
        "最低有效位（lsb）在前的位字符串"
      ]
    },
    {
      "name": "--base2msbf",
      "tip": [
        "最高有效位（msb）在前的位字符串"
      ]
    },
    {
      "name": "--base32",
      "tip": [
        "与 'base32' 程序相同"
      ]
    },
    {
      "name": "--base32hex",
      "tip": [
        "扩展十六进制字母表 base32"
      ]
    },
    {
      "name": "--base58",
      "tip": [
        "视觉上无歧义的 base58 编码"
      ]
    },
    {
      "name": "--base64",
      "tip": [
        "与 'base64' 程序相同"
      ]
    },
    {
      "name": "--base64url",
      "tip": [
        "文件和 URL 安全的 base64"
      ]
    },
    {
      "name": "--decode",
      "alias": [
        "-d",
        "-D"
      ],
      "tip": [
        "U: -d, -D, --decode",
        "解码数据"
      ]
    },
    {
      "name": "--ignore-garbage",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore-garbage",
        "解码时忽略非字母字符"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--wrap",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --wrap <COLS>",
        "在 COLS 个字符后换行（默认 76，0 表示禁用换行）"
      ],
      "next": 0
    },
    {
      "name": "--z85",
      "tip": [
        "类 ascii85 编码；",
        "编码时，输入长度必须是 4 的倍数；",
        "解码时，输入长度必须是 5 的倍数"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
