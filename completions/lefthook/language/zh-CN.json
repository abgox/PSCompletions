{
  "meta": {
    "url": "https://github.com/evilmartians/lefthook",
    "description": [
      "Git 钩子管理器。"
    ]
  },
  "next": [
    {
      "name": "add",
      "tip": [
        "U: add <hook_name>",
        "向配置添加新钩子。"
      ],
      "next": 0
    },
    {
      "name": "check-install",
      "tip": [
        "检查 lefthook 是否已安装。"
      ]
    },
    {
      "name": "dump",
      "tip": [
        "转储 lefthook 配置。"
      ]
    },
    {
      "name": "install",
      "alias": [
        "i"
      ],
      "tip": [
        "U: i|install",
        "将钩子脚本安装到 git 仓库。"
      ],
      "option": [
        {
          "name": "--force",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --force",
            "即使钩子已存在也强制安装。"
          ]
        },
        {
          "name": "--reset-hooks-path",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --reset-hooks-path",
            "将钩子路径重置为默认值。"
          ]
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "详细输出。"
          ]
        }
      ]
    },
    {
      "name": "run",
      "alias": [
        "r"
      ],
      "tip": [
        "U: r|run [group_names]",
        "执行钩子脚本。"
      ],
      "option": [
        {
          "name": "--all-files",
          "tip": [
            "在所有文件上运行。"
          ]
        },
        {
          "name": "--colors",
          "tip": [
            "U: --colors <on|off|auto>",
            "强制彩色输出。"
          ],
          "next": [
            {
              "name": "auto"
            },
            {
              "name": "off"
            },
            {
              "name": "on"
            }
          ]
        },
        {
          "name": "--command",
          "tip": [
            "U: --command <NAME>",
            "运行特定命令。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <PATTERN>",
            "按模式排除文件。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--fail-on-changes",
          "tip": [
            "如果有暂存的更改则失败。"
          ]
        },
        {
          "name": "--file",
          "tip": [
            "U: --file <FILE>",
            "运行特定文件。"
          ],
          "next": 0
        },
        {
          "name": "--files-from-stdin",
          "tip": [
            "从 stdin 读取文件。"
          ]
        },
        {
          "name": "--force",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --force",
            "即使不在 git 仓库中也强制运行。"
          ]
        },
        {
          "name": "--job",
          "tip": [
            "U: --job <NAME>",
            "运行特定作业。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--no-auto-install",
          "tip": [
            "禁用自动安装。"
          ]
        },
        {
          "name": "--no-fail-on-changes",
          "tip": [
            "不在有暂存更改时失败。"
          ]
        },
        {
          "name": "--no-stage-fixed",
          "tip": [
            "不暂存已修复的文件。"
          ]
        },
        {
          "name": "--no-tty",
          "tip": [
            "不使用 TTY。"
          ]
        },
        {
          "name": "--skip-lfs",
          "tip": [
            "跳过 LFS 钩子。"
          ]
        },
        {
          "name": "--tag",
          "tip": [
            "U: --tag <NAME>",
            "按标签运行作业。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "详细输出。"
          ]
        }
      ]
    },
    {
      "name": "self-update",
      "tip": [
        "将 lefthook 更新到最新版本。"
      ]
    },
    {
      "name": "uninstall",
      "alias": [
        "u"
      ],
      "tip": [
        "U: u|uninstall",
        "从 git 仓库卸载钩子脚本。"
      ]
    },
    {
      "name": "validate",
      "tip": [
        "验证 lefthook 配置。"
      ]
    },
    {
      "name": "version",
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "显示版本。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助。"
      ]
    }
  ]
}
