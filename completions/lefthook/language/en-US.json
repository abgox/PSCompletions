{
  "meta": {
    "url": "https://github.com/evilmartians/lefthook",
    "description": [
      "Git hooks manager."
    ]
  },
  "next": [
    {
      "name": "add",
      "tip": [
        "U: add <hook_name>",
        "Add a new hook to the configuration."
      ],
      "next": 0
    },
    {
      "name": "check-install",
      "tip": [
        "Check if lefthook is installed."
      ]
    },
    {
      "name": "dump",
      "tip": [
        "Dump lefthook configuration."
      ]
    },
    {
      "name": "install",
      "alias": [
        "i"
      ],
      "tip": [
        "U: i|install",
        "Install hook scripts to the git repository."
      ],
      "option": [
        {
          "name": "--force",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --force",
            "Force install even if hooks exist."
          ]
        },
        {
          "name": "--reset-hooks-path",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --reset-hooks-path",
            "Reset hooks path to default."
          ]
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "Verbose output."
          ]
        }
      ]
    },
    {
      "name": "run",
      "alias": [
        "r"
      ],
      "tip": [
        "U: r|run [group_names]",
        "Execute hook scripts."
      ],
      "option": [
        {
          "name": "--all-files",
          "tip": [
            "Run on all files."
          ]
        },
        {
          "name": "--colors",
          "tip": [
            "U: --colors <on|off|auto>",
            "Force colored output."
          ],
          "next": [
            {
              "name": "auto"
            },
            {
              "name": "off"
            },
            {
              "name": "on"
            }
          ]
        },
        {
          "name": "--command",
          "tip": [
            "U: --command <NAME>",
            "Run specific command."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <PATTERN>",
            "Exclude files by pattern."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--fail-on-changes",
          "tip": [
            "Fail if there are staged changes."
          ]
        },
        {
          "name": "--file",
          "tip": [
            "U: --file <FILE>",
            "Run specific file."
          ],
          "next": 0
        },
        {
          "name": "--files-from-stdin",
          "tip": [
            "Read files from stdin."
          ]
        },
        {
          "name": "--force",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --force",
            "Force run even if not in a git repository."
          ]
        },
        {
          "name": "--job",
          "tip": [
            "U: --job <NAME>",
            "Run specific job."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--no-auto-install",
          "tip": [
            "Disable auto-install."
          ]
        },
        {
          "name": "--no-fail-on-changes",
          "tip": [
            "Don't fail on staged changes."
          ]
        },
        {
          "name": "--no-stage-fixed",
          "tip": [
            "Don't stage fixed files."
          ]
        },
        {
          "name": "--no-tty",
          "tip": [
            "Don't use TTY."
          ]
        },
        {
          "name": "--skip-lfs",
          "tip": [
            "Skip LFS hooks."
          ]
        },
        {
          "name": "--tag",
          "tip": [
            "U: --tag <NAME>",
            "Run jobs by tag."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "Verbose output."
          ]
        }
      ]
    },
    {
      "name": "self-update",
      "tip": [
        "Update lefthook to the latest version."
      ]
    },
    {
      "name": "uninstall",
      "alias": [
        "u"
      ],
      "tip": [
        "U: u|uninstall",
        "Uninstall hook scripts from the git repository."
      ]
    },
    {
      "name": "validate",
      "tip": [
        "Validate lefthook configuration."
      ]
    },
    {
      "name": "version",
      "tip": [
        "Show version information."
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Show version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show help."
      ]
    }
  ]
}
