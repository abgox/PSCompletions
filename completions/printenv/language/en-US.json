{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "Print the values of environment VARIABLE(s)."
    ]
  },
  "option": [
    {
      "name": "--null",
      "alias": [
        "-0"
      ],
      "tip": [
        "U: -0, --null",
        "End each output line with NUL, not newline."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
