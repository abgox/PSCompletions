{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "输出指定环境变量的值。"
    ]
  },
  "option": [
    {
      "name": "--null",
      "alias": [
        "-0"
      ],
      "tip": [
        "U: -0, --null",
        "每行输出以 NUL 而非换行符结尾。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
