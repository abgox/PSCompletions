{
  "meta": {
    "url": "https://github.com/nilaoda/N_m3u8DL-RE",
    "description": [
      "Cross-platform browser stream downloader (HLS/DASH/Smooth)."
    ]
  },
  "option": [
    {
      "name": "--ad-keyword",
      "tip": [
        "U: --ad-keyword <REG>",
        "Set the URL keyword for ad segments (regex)."
      ],
      "next": 0
    },
    {
      "name": "--allow-hls-multi-ext-map",
      "tip": [
        "Allow multiple #EXT-X-MAP in HLS (experimental). [default: False]"
      ]
    },
    {
      "name": "--append-url-params",
      "tip": [
        "Append input URL params to segments. Useful for some sites. [default: False]"
      ]
    },
    {
      "name": "--auto-select",
      "tip": [
        "Auto-select the best tracks of all types. [default: False]"
      ]
    },
    {
      "name": "--auto-subtitle-fix",
      "tip": [
        "Auto-fix subtitles. [default: True]"
      ]
    },
    {
      "name": "--base-url",
      "tip": [
        "U: --base-url <base-url>",
        "Set the BaseURL."
      ],
      "next": 0
    },
    {
      "name": "--binary-merge",
      "tip": [
        "Binary merge. [default: False]"
      ]
    },
    {
      "name": "--check-segments-count",
      "tip": [
        "Check if the actual downloaded segment count matches the expected count. [default: True]"
      ]
    },
    {
      "name": "--concurrent-download",
      "alias": [
        "-mt"
      ],
      "tip": [
        "U: -mt, --concurrent-download",
        "Concurrently download selected audio, video, and subtitle. [default: False]"
      ]
    },
    {
      "name": "--custom-hls-iv",
      "tip": [
        "U: --custom-hls-iv <FILE|HEX|BASE64>",
        "Specify HLS decryption IV."
      ],
      "next": 0
    },
    {
      "name": "--custom-hls-key",
      "tip": [
        "U: --custom-hls-key <FILE|HEX|BASE64>",
        "Specify HLS decryption key."
      ],
      "next": 0
    },
    {
      "name": "--custom-hls-method",
      "tip": [
        "U: --custom-hls-method <METHOD>",
        "Specify HLS encryption method."
      ],
      "next": [
        {
          "name": "AES_128"
        },
        {
          "name": "AES_128_ECB"
        },
        {
          "name": "CENC"
        },
        {
          "name": "CHACHA20"
        },
        {
          "name": "NONE"
        },
        {
          "name": "SAMPLE_AES"
        },
        {
          "name": "SAMPLE_AES_CTR"
        },
        {
          "name": "UNKNOWN"
        }
      ]
    },
    {
      "name": "--custom-proxy",
      "tip": [
        "U: --custom-proxy <URL>",
        "Set the request proxy.",
        "E: --custom-proxy http://127.0.0.1:8888"
      ],
      "next": 0
    },
    {
      "name": "--custom-range",
      "tip": [
        "U: --custom-range <RANGE>",
        "Download only a portion of segments. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--decryption-binary-path",
      "tip": [
        "U: --decryption-binary-path <PATH>",
        "Full path to MP4 decryption tool.",
        "E: --decryption-binary-path C:\\Tools\\mp4decrypt.exe"
      ],
      "next": 0
    },
    {
      "name": "--decryption-engine",
      "tip": [
        "U: --decryption-engine <FFMPEG|MP4DECRYPT|SHAKA_PACKAGER>",
        "Set the third-party program for decryption. [default: MP4DECRYPT]"
      ],
      "next": [
        {
          "name": "FFMPEG"
        },
        {
          "name": "MP4DECRYPT"
        },
        {
          "name": "SHAKA_PACKAGER"
        }
      ]
    },
    {
      "name": "--del-after-done",
      "tip": [
        "Delete temporary files after completion. [default: True]"
      ]
    },
    {
      "name": "--disable-update-check",
      "tip": [
        "Disable version update check. [default: False]"
      ]
    },
    {
      "name": "--download-retry-count",
      "tip": [
        "U: --download-retry-count <number>",
        "Set the retry count for each segment download. [default: 3]"
      ],
      "next": 0
    },
    {
      "name": "--drop-audio",
      "alias": [
        "-da"
      ],
      "tip": [
        "U: -da, --drop-audio <OPTIONS>",
        "Drop audio streams matching regex. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--drop-subtitle",
      "alias": [
        "-ds"
      ],
      "tip": [
        "U: -ds, --drop-subtitle <OPTIONS>",
        "Drop subtitle streams matching regex. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--drop-video",
      "alias": [
        "-dv"
      ],
      "tip": [
        "U: -dv, --drop-video <OPTIONS>",
        "Drop video streams matching regex. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--ffmpeg-binary-path",
      "tip": [
        "U: --ffmpeg-binary-path <PATH>",
        "Full path to ffmpeg executable.",
        "E: --ffmpeg-binary-path C:\\Tools\\ffmpeg.exe"
      ],
      "next": 0
    },
    {
      "name": "--force-ansi-console",
      "tip": [
        "Force the terminal to be recognized as ANSI and interactive."
      ]
    },
    {
      "name": "--header",
      "alias": [
        "-H"
      ],
      "tip": [
        "U: -H, --header <header>",
        "Set specific HTTP request headers.",
        "E: -H \"Cookie: mycookie\" -H \"User-Agent: iOS\""
      ],
      "next": 0
    },
    {
      "name": "--http-request-timeout",
      "tip": [
        "U: --http-request-timeout <seconds>",
        "Set the HTTP request timeout in seconds. [default: 100]"
      ],
      "next": 0
    },
    {
      "name": "--key",
      "tip": [
        "U: --key <key>",
        "Set the decryption key. Format:",
        "--key KID1:KEY1 --key KID2:KEY2",
        "For same key: --key KEY"
      ],
      "next": 0
    },
    {
      "name": "--key-text-file",
      "tip": [
        "U: --key-text-file <key-text-file>",
        "Set the key text file for decryption."
      ],
      "next": 0
    },
    {
      "name": "--live-fix-vtt-by-audio",
      "tip": [
        "Fix VTT subtitle by reading audio start time. [default: False]"
      ]
    },
    {
      "name": "--live-keep-segments",
      "tip": [
        "Keep segments when recording live with real-time merge. [default: True]"
      ]
    },
    {
      "name": "--live-perform-as-vod",
      "tip": [
        "Download live stream as VOD. [default: False]"
      ]
    },
    {
      "name": "--live-pipe-mux",
      "tip": [
        "Mux live stream to TS via pipe + ffmpeg. [default: False]"
      ]
    },
    {
      "name": "--live-real-time-merge",
      "tip": [
        "Real-time merge while recording live streams. [default: False]"
      ]
    },
    {
      "name": "--live-record-limit",
      "tip": [
        "U: --live-record-limit <HH:mm:ss>",
        "Set the recording duration limit."
      ],
      "next": 0
    },
    {
      "name": "--live-take-count",
      "tip": [
        "U: --live-take-count <NUM>",
        "Manually set the initial segment count for live recording. [default: 16]"
      ],
      "next": 0
    },
    {
      "name": "--live-wait-time",
      "tip": [
        "U: --live-wait-time <SEC>",
        "Manually set the live playlist refresh interval."
      ],
      "next": 0
    },
    {
      "name": "--log-file-path",
      "tip": [
        "U: --log-file-path <log-file-path>",
        "Set the log file path.",
        "E: --log-file-path C:\\Logs\\log.txt"
      ],
      "next": 0
    },
    {
      "name": "--log-level",
      "tip": [
        "U: --log-level <DEBUG|ERROR|INFO|OFF|WARN>",
        "Set the log level. [default: INFO]"
      ],
      "next": [
        {
          "name": "DEBUG"
        },
        {
          "name": "ERROR"
        },
        {
          "name": "INFO"
        },
        {
          "name": "OFF"
        },
        {
          "name": "WARN"
        }
      ]
    },
    {
      "name": "--max-speed",
      "alias": [
        "-R"
      ],
      "tip": [
        "U: -R, --max-speed <SPEED>",
        "Set speed limit (Mbps or Kbps).",
        "E: -R 15M or -R 100K"
      ],
      "next": 0
    },
    {
      "name": "--morehelp",
      "tip": [
        "U: --morehelp <OPTION>",
        "Show detailed help for a specific option."
      ],
      "next": 0
    },
    {
      "name": "--mp4-real-time-decryption",
      "tip": [
        "Real-time decryption of MP4 segments. [default: False]"
      ]
    },
    {
      "name": "--mux-after-done",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --mux-after-done <OPTIONS>",
        "Mux audio and video after all work is done. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--mux-import",
      "tip": [
        "U: --mux-import <OPTIONS>",
        "Import external media files during muxing. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--no-ansi-color",
      "tip": [
        "Remove ANSI colors."
      ]
    },
    {
      "name": "--no-date-info",
      "tip": [
        "Do not write date info during muxing. [default: False]"
      ]
    },
    {
      "name": "--no-log",
      "tip": [
        "Disable log file output. [default: False]"
      ]
    },
    {
      "name": "--save-dir",
      "tip": [
        "U: --save-dir <save-dir>",
        "Set the output directory."
      ],
      "next": 0
    },
    {
      "name": "--save-name",
      "tip": [
        "U: --save-name <save-name>",
        "Set the output file name."
      ],
      "next": 0
    },
    {
      "name": "--save-pattern",
      "tip": [
        "U: --save-pattern <save-pattern>",
        "Set the file naming pattern, supports variables:",
        "<SaveName>, <Id>, <Codecs>, <Language>, <Resolution>, <Bandwidth>, <MediaType>, <Channels>, <FrameRate>, <VideoRange>, <GroupId>, <Ext>",
        "E: --save-pattern \"<SaveName>_<Resolution>_<Bandwidth>\""
      ],
      "next": 0
    },
    {
      "name": "--select-audio",
      "alias": [
        "-sa"
      ],
      "tip": [
        "U: -sa, --select-audio <OPTIONS>",
        "Select audio streams matching regex. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--select-subtitle",
      "alias": [
        "-ss"
      ],
      "tip": [
        "U: -ss, --select-subtitle <OPTIONS>",
        "Select subtitle streams matching regex. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--select-video",
      "alias": [
        "-sv"
      ],
      "tip": [
        "U: -sv, --select-video <OPTIONS>",
        "Select video streams matching regex. Use --morehelp for details."
      ],
      "next": 0
    },
    {
      "name": "--skip-download",
      "tip": [
        "Skip downloading. [default: False]"
      ]
    },
    {
      "name": "--skip-merge",
      "tip": [
        "Skip merging segments. [default: False]"
      ]
    },
    {
      "name": "--sub-format",
      "tip": [
        "U: --sub-format <SRT|VTT>",
        "Subtitle output format. [default: SRT]"
      ],
      "next": [
        {
          "name": "SRT"
        },
        {
          "name": "VTT"
        }
      ]
    },
    {
      "name": "--sub-only",
      "tip": [
        "Only select subtitle tracks. [default: False]"
      ]
    },
    {
      "name": "--task-start-at",
      "tip": [
        "U: --task-start-at <yyyyMMddHHmmss>",
        "Do not start the task before this time."
      ],
      "next": 0
    },
    {
      "name": "--thread-count",
      "tip": [
        "U: --thread-count <number>",
        "Set the download thread count. [default: 16]"
      ],
      "next": 0
    },
    {
      "name": "--tmp-dir",
      "tip": [
        "U: --tmp-dir <tmp-dir>",
        "Set the temporary file storage directory."
      ],
      "next": 0
    },
    {
      "name": "--ui-language",
      "tip": [
        "U: --ui-language <en-US|zh-CN|zh-TW>",
        "Set the UI language."
      ],
      "next": [
        {
          "name": "en-US"
        },
        {
          "name": "zh-CN"
        },
        {
          "name": "zh-TW"
        }
      ]
    },
    {
      "name": "--urlprocessor-args",
      "tip": [
        "U: --urlprocessor-args <urlprocessor-args>",
        "This string will be passed directly to the URL Processor."
      ],
      "next": 0
    },
    {
      "name": "--use-ffmpeg-concat-demuxer",
      "tip": [
        "Use ffmpeg concat demuxer instead of concat protocol. [default: False]"
      ]
    },
    {
      "name": "--use-system-proxy",
      "tip": [
        "Use the system default proxy. [default: True]"
      ]
    },
    {
      "name": "--version",
      "tip": [
        "Show version information."
      ]
    },
    {
      "name": "--write-meta-json",
      "tip": [
        "Output parsed info to a JSON file. [default: True]"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h",
        "-?"
      ],
      "tip": [
        "U: -?, -h, --help",
        "Show help and usage information."
      ]
    }
  ]
}
