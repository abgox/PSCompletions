{
  "meta": {
    "url": "https://www.typescriptlang.org/docs/handbook/compiler-options.html",
    "description": [
      "TypeScript 编译器。"
    ]
  },
  "option": [
    {
      "name": "--all",
      "tip": [
        "显示所有编译器选项。"
      ]
    },
    {
      "name": "--init",
      "tip": [
        "初始化 TypeScript 项目并创建 tsconfig.json 文件。"
      ]
    },
    {
      "name": "--listFilesOnly",
      "tip": [
        "打印编译过程中涉及的文件名，然后停止处理。"
      ]
    },
    {
      "name": "--locale",
      "tip": [
        "U: --locale <LOCALE>",
        "设置 TypeScript 消息的语言。"
      ]
    },
    {
      "name": "--project",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --project <PATH>",
        "编译指定配置文件路径或包含 'tsconfig.json' 文件夹的项目。"
      ]
    },
    {
      "name": "--showConfig",
      "tip": [
        "打印最终配置而不是构建。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "打印编译器版本。"
      ]
    },
    {
      "name": "--watch",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --watch",
        "监视输入文件。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示 CLI 的本地帮助信息。"
      ]
    }
  ]
}
