{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "计算并校验消息摘要。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--check",
      "alias": [
        "-c"
      ],
      "tip": [
        "从文件中读取哈希值并校验。"
      ]
    },
    {
      "name": "--ignore-missing",
      "tip": [
        "对于缺失的文件不报错或报告状态。"
      ]
    },
    {
      "name": "--length",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --length <BITS>",
        "摘要长度，以位为单位；",
        "不得超过最大长度，对于 blake2b 必须是 8 的倍数；",
        "对于 sha2 或 sha3 必须是 224、256、384 或 512"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "对于每个成功校验的文件不打印 OK。"
      ]
    },
    {
      "name": "--status",
      "alias": [
        "-s"
      ],
      "tip": [
        "不输出任何内容，通过状态码显示成功。"
      ]
    },
    {
      "name": "--strict",
      "tip": [
        "对于格式不正确的校验行以非零状态退出。"
      ]
    },
    {
      "name": "--tag",
      "tip": [
        "创建 BSD 风格的校验和。"
      ]
    },
    {
      "name": "--text",
      "alias": [
        "-t"
      ],
      "tip": [
        "以文本模式读取。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--warn",
      "alias": [
        "-w"
      ],
      "tip": [
        "对格式不正确的校验行发出警告。"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "以 NUL 而非换行符结束每行输出，并禁用文件名转义。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
