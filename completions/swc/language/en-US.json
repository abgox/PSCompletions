{
  "meta": {
    "url": "https://swc.rs/",
    "description": [
      "Super-fast TypeScript/JavaScript compiler."
    ]
  },
  "option": [
    {
      "name": "--cli-config-file",
      "tip": [
        "U: --cli-config-file <PATH>",
        "Path to a JSON file containing CLI options"
      ],
      "next": 0
    },
    {
      "name": "--config",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --config <CONFIG>",
        "Override a config from .swcrc file"
      ]
    },
    {
      "name": "--config-file",
      "tip": [
        "U: --config-file <PATH>",
        "Path to a .swcrc file to use"
      ],
      "next": 0
    },
    {
      "name": "--copy-files",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --copy-files",
        "When compiling a directory copy over non-compilable files"
      ]
    },
    {
      "name": "--delete-dir-on-start",
      "tip": [
        "Whether or not delete output directory on start"
      ]
    },
    {
      "name": "--env-name",
      "tip": [
        "U: --env-name <NAME>",
        "The name of the 'env' to use when loading configs and plugins"
      ],
      "next": 0
    },
    {
      "name": "--extensions",
      "tip": [
        "U: --extensions <LIST>",
        "Use specific extensions"
      ],
      "next": 0
    },
    {
      "name": "--filename",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --filename <FILENAME>",
        "Filename to use when reading from stdin"
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Display help for command"
      ]
    },
    {
      "name": "--ignore",
      "tip": [
        "U: --ignore <LIST>",
        "List of glob paths to **not** compile"
      ],
      "next": 0
    },
    {
      "name": "--include-dotfiles",
      "tip": [
        "Include dotfiles when compiling and copying non-compilable files"
      ]
    },
    {
      "name": "--log-watch-compilation",
      "tip": [
        "Log a message when a watched file is successfully compiled"
      ]
    },
    {
      "name": "--no-swcrc",
      "tip": [
        "Whether or not to look up .swcrc files"
      ]
    },
    {
      "name": "--only",
      "tip": [
        "U: --only <LIST>",
        "List of glob paths to **only** compile"
      ],
      "next": 0
    },
    {
      "name": "--out-dir",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --out-dir <OUT>",
        "Compile an input directory of modules into an output directory"
      ],
      "next": 0
    },
    {
      "name": "--out-file",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --out-file <OUT>",
        "Compile all input files into a single file"
      ],
      "next": 0
    },
    {
      "name": "--out-file-extension",
      "tip": [
        "U: --out-file-extension <STRING>",
        "Use a specific extension for the output files"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "Suppress compilation output"
      ]
    },
    {
      "name": "--source-file-name",
      "tip": [
        "U: --source-file-name <STRING>",
        "Set `sources[0]` on returned source map"
      ],
      "next": 0
    },
    {
      "name": "--source-map-target",
      "tip": [
        "U: --source-map-target <STRING>",
        "Set `file` on returned source map"
      ],
      "next": 0
    },
    {
      "name": "--source-maps",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --source-maps <VALUE>",
        "Generate source maps"
      ],
      "next": [
        {
          "name": "both",
          "tip": [
            "Both inline and external source maps"
          ]
        },
        {
          "name": "false",
          "tip": [
            "Disable source maps"
          ]
        },
        {
          "name": "inline",
          "tip": [
            "Inline source maps as data URLs"
          ]
        },
        {
          "name": "true",
          "tip": [
            "Generate external source maps"
          ]
        }
      ]
    },
    {
      "name": "--source-root",
      "tip": [
        "U: --source-root <FILENAME>",
        "The root from which all sources are relative"
      ],
      "next": 0
    },
    {
      "name": "--strip-leading-paths",
      "tip": [
        "Remove the leading directory when building the final output path"
      ]
    },
    {
      "name": "--sync",
      "tip": [
        "Invoke swc synchronously"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Output the version number"
      ]
    },
    {
      "name": "--watch",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --watch",
        "Recompile files on changes"
      ]
    },
    {
      "name": "--workers",
      "tip": [
        "U: --workers <NUMBER>",
        "The number of workers to use for parallel processing"
      ],
      "next": 0
    }
  ]
}
