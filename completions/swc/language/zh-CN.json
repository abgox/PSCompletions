{
  "meta": {
    "url": "https://swc.rs/",
    "description": [
      "超快的 TypeScript/JavaScript 编译器。"
    ]
  },
  "option": [
    {
      "name": "--cli-config-file",
      "tip": [
        "U: --cli-config-file <PATH>",
        "包含 CLI 选项的 JSON 文件路径"
      ],
      "next": 0
    },
    {
      "name": "--config",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --config <CONFIG>",
        "覆盖 .swcrc 文件中的配置"
      ]
    },
    {
      "name": "--config-file",
      "tip": [
        "U: --config-file <PATH>",
        "要使用的 .swcrc 文件路径"
      ],
      "next": 0
    },
    {
      "name": "--copy-files",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --copy-files",
        "编译目录时复制不可编译的文件"
      ]
    },
    {
      "name": "--delete-dir-on-start",
      "tip": [
        "启动时是否删除输出目录"
      ]
    },
    {
      "name": "--env-name",
      "tip": [
        "U: --env-name <NAME>",
        "加载配置和插件时使用的环境名称"
      ],
      "next": 0
    },
    {
      "name": "--extensions",
      "tip": [
        "U: --extensions <LIST>",
        "使用特定的扩展名"
      ],
      "next": 0
    },
    {
      "name": "--filename",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --filename <FILENAME>",
        "从 stdin 读取时使用的文件名"
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息"
      ]
    },
    {
      "name": "--ignore",
      "tip": [
        "U: --ignore <LIST>",
        "不需要编译的 glob 路径列表"
      ],
      "next": 0
    },
    {
      "name": "--include-dotfiles",
      "tip": [
        "编译和复制不可编译文件时包含点文件"
      ]
    },
    {
      "name": "--log-watch-compilation",
      "tip": [
        "监视的文件成功编译时记录消息"
      ]
    },
    {
      "name": "--no-swcrc",
      "tip": [
        "是否查找 .swcrc 文件"
      ]
    },
    {
      "name": "--only",
      "tip": [
        "U: --only <LIST>",
        "仅编译的 glob 路径列表"
      ],
      "next": 0
    },
    {
      "name": "--out-dir",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --out-dir <OUT>",
        "将输入模块目录编译到输出目录"
      ],
      "next": 0
    },
    {
      "name": "--out-file",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --out-file <OUT>",
        "将所有输入文件编译为单个文件"
      ],
      "next": 0
    },
    {
      "name": "--out-file-extension",
      "tip": [
        "U: --out-file-extension <STRING>",
        "为输出文件使用特定的扩展名"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "抑制编译输出"
      ]
    },
    {
      "name": "--source-file-name",
      "tip": [
        "U: --source-file-name <STRING>",
        "设置返回 source map 的 `sources[0]` 字段"
      ],
      "next": 0
    },
    {
      "name": "--source-map-target",
      "tip": [
        "U: --source-map-target <STRING>",
        "设置返回 source map 的 `file` 字段"
      ],
      "next": 0
    },
    {
      "name": "--source-maps",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --source-maps <VALUE>",
        "生成 source maps"
      ],
      "next": [
        {
          "name": "both",
          "tip": [
            "同时生成内联和外部 source maps"
          ]
        },
        {
          "name": "false",
          "tip": [
            "禁用 source maps"
          ]
        },
        {
          "name": "inline",
          "tip": [
            "将 source maps 内联为数据 URL"
          ]
        },
        {
          "name": "true",
          "tip": [
            "生成外部 source maps"
          ]
        }
      ]
    },
    {
      "name": "--source-root",
      "tip": [
        "U: --source-root <FILENAME>",
        "所有源文件的相对根路径"
      ],
      "next": 0
    },
    {
      "name": "--strip-leading-paths",
      "tip": [
        "构建最终输出路径时移除前导目录"
      ]
    },
    {
      "name": "--sync",
      "tip": [
        "同步调用 swc"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "输出版本号"
      ]
    },
    {
      "name": "--watch",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --watch",
        "文件更改时重新编译"
      ]
    },
    {
      "name": "--workers",
      "tip": [
        "U: --workers <NUMBER>",
        "用于并行处理的工作线程数"
      ],
      "next": 0
    }
  ]
}
