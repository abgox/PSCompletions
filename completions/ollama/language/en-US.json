      "name": "show",
      "tip": [
        "U: show <MODEL> [flags]",
        "Show information for a model."
      ],
      "option": [
        {
          "name": "--license",
          "tip": [
            "Show license of a model"
          ]
        },
        {
          "name": "--modelfile",
          "tip": [
            "Show Modelfile of a model"
          ]
        },
        {
          "name": "--parameters",
          "tip": [
            "Show parameters of a model"
          ]
        },
        {
          "name": "--system",
          "tip": [
            "Show system message of a model"
          ]
        },
        {
          "name": "--template",
          "tip": [
            "Show template of a model"
          ]
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "Show detailed model information"
          ]
        }
      ]
    },
    {
      "name": "signin",
      "tip": [
        "U: signin",
        "Sign in to ollama.com."
      ]
    },
    {
      "name": "signout",
      "tip": [
        "U: signout",
        "Sign out from ollama.com."
      ]
    },
    {
      "name": "stop",
      "tip": [
        "U: stop <MODEL>",
        "Stop a running model."
      ]
    }
  ],
  "option": [
    {
      "name": "--nowordwrap",
      "tip": [
        "Don't wrap words to the next line automatically."
      ]
    },
    {
      "name": "--verbose",
      "tip": [
        "Show timings for response."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Show version information."
      ]
    }
