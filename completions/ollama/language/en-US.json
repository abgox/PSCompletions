          "next": 0
        },
        {
          "name": "--steps",
          "tip": [
            "U: --steps <int>",
            "Denoising steps (experimental)"
          ],
          "next": 0
        },
        {
          "name": "--think",
          "tip": [
            "U: --think [=\"true\"]",
            "Enable thinking mode: true/false or high/medium/low"
