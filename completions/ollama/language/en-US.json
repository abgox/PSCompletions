{
  "meta": {
    "url": "https://docs.ollama.com/cli",
    "description": [
      "Local large language model runner."
    ]
  },
  "next": [
    {
      "name": "cp",
      "tip": [
        "U: cp <SOURCE> <DEST>",
        "Copy a model."
      ]
    },
    {
      "name": "create",
      "tip": [
        "U: create <MODEL> [flags]",
        "Create a customized model with modelfile."
      ],
      "option": [
        {
          "name": "--draft-quantize",
          "tip": [
            "U: --draft-quantize <string>",
            "Quantize draft model to this level"
          ],
          "next": 0
        },
        {
          "name": "--experimental",
          "tip": [
            "Enable experimental safetensors model creation"
          ]
        },
        {
          "name": "--file",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --file <string>",
            "Name of the Modelfile (default: Modelfile)"
          ],
          "next": 0
        },
        {
          "name": "--quantize",
          "alias": [
            "-q"
          ],
          "tip": [
            "U: -q, --quantize <string>",
            "Quantize model to this level (e.g. q4_K_M)"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "help",
      "tip": [
        "U: help [command]",
        "Help about any command."
      ],
      "next": 0
    },
    {
      "name": "launch",
      "tip": [
        "U: launch [flags]",
        "Configure and launch external applications to use Ollama models."
      ],
      "option": [
        {
          "name": "--config",
          "tip": [
            "Configure without launching"
          ]
        },
        {
          "name": "--model",
          "tip": [
            "U: --model <string>",
            "Launch with a specific model"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "list",
      "alias": [
        "ls"
