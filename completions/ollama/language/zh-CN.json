{
  "meta": {
    "url": "https://docs.ollama.com/cli",
    "description": [
      "ollama - ollama 的命令行工具。"
    ]
  },
  "root": [
    {
      "name": "cp",
      "tip": [
        "复制模型"
      ]
    },
    {
      "name": "create",
      "tip": [
        "使用 modelfile 创建自定义模型。"
      ],
      "option": [
        {
          "name": "-f",
          "tip": [
            "modelfile 的路径"
          ]
        }
      ]
    },
    {
      "name": "launch",
      "tip": [
        "配置并启动外部应用程序以使用 Ollama 模型。",
        "目前支持 OpenCode、Claude Code、Codex、VS Code 和 Droid。"
      ],
      "option": [
        {
          "name": "--config",
          "tip": [
            "仅配置而不启动。"
          ]
        },
        {
          "name": "--model",
          "tip": [
            "使用特定模型启动。"
          ]
        }
      ]
    },
    {
      "name": "ls",
      "tip": [
        "列出模型"
      ]
    },
    {
      "name": "ps",
      "tip": [
        "列出正在运行的模型"
      ]
    },
    {
      "name": "pull",
      "tip": [
        "下载模型"
      ]
    },
    {
      "name": "push",
      "tip": [
        "推送模型"
      ]
    },
    {
      "name": "rm",
      "tip": [
        "删除模型"
      ]
    },
    {
      "name": "run",
      "tip": [
        "运行模型。",
        "如果你正在运行嵌入模型，可以直接在终端中生成文本嵌入。",
        "输出嵌入向量的 JSON 数组。"
      ]
    },
    {
      "name": "serve",
      "tip": [
        "启动 Ollama"
      ],
      "option": [
        {
          "name": "--help",
          "tip": [
            "查看可为 ollama 设置的环境变量列表。"
          ]
        }
      ]
    },
    {
      "name": "show",
      "tip": [
        "显示指定模型的信息"
      ]
    },
    {
      "name": "signin",
      "tip": [
        "登录到 Ollama"
      ]
    },
    {
      "name": "signout",
      "tip": [
        "退出 Ollama"
      ]
    },
    {
      "name": "stop",
      "tip": [
        "停止正在运行的模型"
      ]
    }
  ],
  "option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示ollama的帮助信息"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "显示ollama的版本"
      ]
    }
  ]
}