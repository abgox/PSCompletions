{
  "meta": {
    "url": "https://github.com/sharkdp/hyperfine",
    "description": [
      "A command-line benchmarking tool"
    ]
  },
  "option": [
    {
      "name": "--cleanup",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --cleanup <CMD>",
        "Execute CMD after the completion of all benchmarking runs"
      ],
      "next": 0
    },
    {
      "name": "--command-name",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --command-name <NAME>",
        "Give a meaningful name to a command"
      ],
      "next": 0
    },
    {
      "name": "--conclude",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --conclude <CMD>",
        "Execute CMD after each timing run"
      ],
      "next": 0
    },
    {
      "name": "--export-asciidoc",
      "tip": [
        "U: --export-asciidoc <FILE>",
        "Export the timing summary statistics as an AsciiDoc table"
      ],
      "next": 0
    },
    {
      "name": "--export-csv",
      "tip": [
        "U: --export-csv <FILE>",
        "Export the timing summary statistics as CSV"
      ],
      "next": 0
    },
    {
      "name": "--export-json",
      "tip": [
        "U: --export-json <FILE>",
        "Export the timing summary statistics and timings as JSON"
      ],
      "next": 0
    },
    {
      "name": "--export-markdown",
      "tip": [
        "U: --export-markdown <FILE>",
        "Export the timing summary statistics as a Markdown table"
      ],
      "next": 0
    },
    {
      "name": "--export-orgmode",
      "tip": [
        "U: --export-orgmode <FILE>",
        "Export the timing summary statistics as an Emacs org-mode table"
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--ignore-failure",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore-failure",
        "Ignore failures of the benchmarked programs"
      ]
    },
    {
      "name": "--input",
      "tip": [
        "U: --input <WHERE>",
        "Control where the input of the benchmark comes from"
      ],
      "next": [
        {
          "name": "null",
          "tip": [
            "Read from /dev/null (default)"
          ]
        }
      ]
    },
    {
      "name": "--max-runs",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --max-runs <NUM>",
        "Perform at most NUM runs for each command"
      ],
      "next": 0
    },
    {
      "name": "--min-runs",
      "alias": [
        "-m"
      ],
      "tip": [
        "U: -m, --min-runs <NUM>",
        "Perform at least NUM runs for each command"
      ],
      "next": 0
    },
    {
      "name": "--output",
      "tip": [
        "U: --output <WHERE>",
        "Control where the output of the benchmark is redirected"
      ],
      "next": [
        {
          "name": "inherit",
          "tip": [
            "Don't redirect the output"
          ]
        },
        {
          "name": "null",
          "tip": [
            "Redirect output to /dev/null (default)"
          ]
        },
        {
          "name": "pipe",
          "tip": [
            "Feed the output through a pipe"
          ]
        }
      ]
    },
    {
      "name": "--parameter-list",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --parameter-list <VAR> <VALUES>",
        "Perform benchmark runs for each value in the comma-separated list"
      ],
      "next": 0
    },
    {
      "name": "--parameter-scan",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --parameter-scan <VAR> <MIN> <MAX>",
        "Perform benchmark runs for each value in the range MIN..MAX"
      ],
      "next": 0
    },
    {
      "name": "--parameter-step-size",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --parameter-step-size <DELTA>",
        "Traverse the range MIN..MAX in steps of DELTA"
      ],
      "next": 0
    },
    {
      "name": "--prepare",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --prepare <CMD>",
        "Execute CMD before each timing run"
      ],
      "next": 0
    },
    {
      "name": "--reference",
      "tip": [
        "U: --reference <CMD>",
        "The reference command for relative comparison"
      ],
      "next": 0
    },
    {
      "name": "--reference-name",
      "tip": [
        "U: --reference-name <NAME>",
        "Give a meaningful name to the reference command"
      ],
      "next": 0
    },
    {
      "name": "--runs",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --runs <NUM>",
        "Perform exactly NUM runs for each command"
      ],
      "next": 0
    },
    {
      "name": "--setup",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --setup <CMD>",
        "Execute CMD before each set of timing runs"
      ],
      "next": 0
    },
    {
      "name": "--shell",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --shell <SHELL>",
        "Set the shell to use for executing benchmarked commands"
      ],
      "next": 0
    },
    {
      "name": "--show-output",
      "tip": [
        "Print the stdout and stderr of the benchmark"
      ]
    },
    {
      "name": "--sort",
      "tip": [
        "U: --sort <METHOD>",
        "Specify the sort order of the speed comparison summary"
      ],
      "next": [
        {
          "name": "auto",
          "tip": [
            "Order by time (default)"
          ]
        },
        {
          "name": "command",
          "tip": [
            "Order by command input order"
          ]
        },
        {
          "name": "mean-time",
          "tip": [
            "Order by mean runtime"
          ]
        }
      ]
    },
    {
      "name": "--style",
      "tip": [
        "U: --style <TYPE>",
        "Set output style type"
      ],
      "next": [
        {
          "name": "auto",
          "tip": [
            "Automatic (default)"
          ]
        },
        {
          "name": "basic",
          "tip": [
            "Basic output"
          ]
        },
        {
          "name": "color",
          "tip": [
            "Colors without interactive output"
          ]
        },
        {
          "name": "full",
          "tip": [
            "Full output with all effects"
          ]
        },
        {
          "name": "nocolor",
          "tip": [
            "Interactive without colors"
          ]
        },
        {
          "name": "none",
          "tip": [
            "Disable all output"
          ]
        }
      ]
    },
    {
      "name": "--time-unit",
      "alias": [
        "-u"
      ],
      "tip": [
        "U: -u, --time-unit <UNIT>",
        "Set the time unit to be used"
      ],
      "next": [
        {
          "name": "microsecond",
          "tip": [
            "Microsecond"
          ]
        },
        {
          "name": "millisecond",
          "tip": [
            "Millisecond"
          ]
        },
        {
          "name": "second",
          "tip": [
            "Second"
          ]
        }
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version"
      ]
    },
    {
      "name": "--warmup",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --warmup <NUM>",
        "Perform NUM warmup runs before the actual benchmark"
      ],
      "next": 0
    },
    {
      "name": "-N",
      "tip": [
        "Alias for --shell=none"
      ]
    }
  ]
}
