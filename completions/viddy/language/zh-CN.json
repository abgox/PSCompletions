{
  "meta": {
    "url": "https://github.com/sachaos/viddy",
    "description": [
      "现代 watch 命令",
      "时间机器和分页器等"
    ]
  },
  "option": [
    {
      "name": "--bell",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bell",
        "更新之间有变化时响铃"
      ]
    },
    {
      "name": "--debug",
      "tip": [
        "启用调试模式"
      ]
    },
    {
      "name": "--deletion-differences",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --deletion-differences",
        "高亮删除的变化"
      ]
    },
    {
      "name": "--differences",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --differences",
        "高亮更新之间的变化"
      ]
    },
    {
      "name": "--disable-auto-save",
      "tip": [
        "禁用自动保存"
      ]
    },
    {
      "name": "--disable-mouse",
      "tip": [
        "停止处理鼠标事件"
      ]
    },
    {
      "name": "--exec",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --exec",
        "将命令传递给 exec 而非 Shell"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助"
      ]
    },
    {
      "name": "--interval",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --interval <SECONDS>",
        "更新间隔秒数（>= 100ms）"
      ],
      "next": 0
    },
    {
      "name": "--load",
      "tip": [
        "U: --load <FILE>",
        "要加载的备份文件路径"
      ],
      "next": 0
    },
    {
      "name": "--no-title",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --no-title",
        "关闭标题栏"
      ]
    },
    {
      "name": "--precise",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --precise",
        "尝试以精确间隔运行命令"
      ]
    },
    {
      "name": "--save",
      "tip": [
        "U: --save <FILE>",
        "备份文件路径"
      ],
      "next": 0
    },
    {
      "name": "--shell",
      "tip": [
        "U: --shell <SHELL>",
        "使用的 Shell"
      ],
      "next": 0
    },
    {
      "name": "--shell-options",
      "tip": [
        "U: --shell-options [<OPTIONS>...]",
        "额外的 Shell 选项"
      ],
      "next": 0
    },
    {
      "name": "--skip-empty-diffs",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --skip-empty-diffs",
        "跳过历史中无变化的快照"
      ]
    },
    {
      "name": "--unfold",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --unfold",
        "关闭自动换行"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本"
      ]
    }
  ]
}
