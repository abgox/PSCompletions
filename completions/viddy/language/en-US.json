{
  "meta": {
    "url": "https://github.com/sachaos/viddy",
    "description": [
      "A modern watch command",
      "Time machine and pager etc."
    ]
  },
  "option": [
    {
      "name": "--bell",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bell",
        "Ring terminal bell on changes between updates"
      ]
    },
    {
      "name": "--debug",
      "tip": [
        "Enable debug mode"
      ]
    },
    {
      "name": "--deletion-differences",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --deletion-differences",
        "Highlight deletion changes between updates"
      ]
    },
    {
      "name": "--differences",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --differences",
        "Highlight changes between updates"
      ]
    },
    {
      "name": "--disable-auto-save",
      "tip": [
        "Disable automatic save"
      ]
    },
    {
      "name": "--disable-mouse",
      "tip": [
        "Stop handling mouse events"
      ]
    },
    {
      "name": "--exec",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --exec",
        "Pass command to exec instead of shell"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--interval",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --interval <SECONDS>",
        "Seconds to wait between updates (>= 100ms)"
      ],
      "next": 0
    },
    {
      "name": "--load",
      "tip": [
        "U: --load <FILE>",
        "Path to the backup file to load"
      ],
      "next": 0
    },
    {
      "name": "--no-title",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --no-title",
        "Turn off header"
      ]
    },
    {
      "name": "--precise",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --precise",
        "Attempt run command in precise intervals"
      ]
    },
    {
      "name": "--save",
      "tip": [
        "U: --save <FILE>",
        "Path to the backup file"
      ],
      "next": 0
    },
    {
      "name": "--shell",
      "tip": [
        "U: --shell <SHELL>",
        "Shell to use"
      ],
      "next": 0
    },
    {
      "name": "--shell-options",
      "tip": [
        "U: --shell-options [<OPTIONS>...]",
        "Additional shell options"
      ],
      "next": 0
    },
    {
      "name": "--skip-empty-diffs",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --skip-empty-diffs",
        "Skip snapshots with no changes in history"
      ]
    },
    {
      "name": "--unfold",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --unfold",
        "Turn off line wrapping"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version"
      ]
    }
  ]
}
