{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "输出去除前导目录组件后的名称。"
    ]
  },
  "option": [
    {
      "name": "--multiple",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --multiple",
        "支持多个参数并将每个参数视为一个 NAME"
      ]
    },
    {
      "name": "--suffix",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --suffix <SUFFIX>",
        "移除尾部的 SUFFIX；隐含 -a"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --zero",
        "以 NUL 而非换行符结束每行输出"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
