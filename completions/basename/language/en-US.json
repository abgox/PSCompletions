{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Print NAME with leading directory components removed."
    ]
  },
  "option": [
    {
      "name": "--multiple",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --multiple",
        "support multiple arguments and treat each as a NAME"
      ]
    },
    {
      "name": "--suffix",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --suffix <SUFFIX>",
        "remove a trailing SUFFIX; implies -a"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --zero",
        "end each output line with NUL, not newline"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
