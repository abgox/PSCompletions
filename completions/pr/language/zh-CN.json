{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "为打印分页或分列文件。"
    ]
  },
  "option": [
    {
      "name": "--across",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --across",
        "横向打印列而非纵向，与 -COLUMN 一起使用。"
      ]
    },
    {
      "name": "--columns",
      "alias": [
        "-"
      ],
      "tip": [
        "U: -COLUMN, --columns=COLUMN",
        "输出 COLUMN 列并向下打印列，除非使用 -a。",
        "平衡每页上的列行数。"
      ],
      "next": 0
    },
    {
      "name": "--date-format",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --date-format=<FORMAT>",
        "使用 FORMAT 作为页眉日期。"
      ],
      "next": 0
    },
    {
      "name": "--double-space",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --double-space",
        "输出双倍行距。"
      ]
    },
    {
      "name": "--expand-tabs",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e[CHAR[WIDTH]], --expand-tabs[=CHAR[WIDTH]]",
        "将输入字符（制表符）扩展为制表宽度（8）。"
      ]
    },
    {
      "name": "--first-line-number",
      "alias": [
        "-N"
      ],
      "tip": [
        "U: -N, --first-line-number=<NUMBER>",
        "从打印的第一页的第一行开始以 NUMBER 计数。"
      ],
      "next": 0
    },
    {
      "name": "--form-feed",
      "alias": [
        "-F",
        "-f"
      ],
      "tip": [
        "U: -F, -f, --form-feed",
        "使用换页符而非换行符分隔页面。"
      ]
    },
    {
      "name": "--header",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --header=<HEADER>",
        "使用居中的 HEADER 替代页眉中的文件名。",
        "-h \"\" 打印空行，不要使用 -h\"\"。"
      ],
      "next": 0
    },
    {
      "name": "--indent",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --indent=<MARGIN>",
        "每行偏移 MARGIN（零）个空格。"
      ],
      "next": 0
    },
    {
      "name": "--join-lines",
      "alias": [
        "-J"
      ],
      "tip": [
        "U: -J, --join-lines",
        "合并完整行，关闭 -W 行截断，无列对齐。"
      ]
    },
    {
      "name": "--length",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --length=<PAGE_LENGTH>",
        "设置页长度为 PAGE_LENGTH（66）行。",
        "如果 PAGE_LENGTH <= 10 则隐含 -t。"
      ],
      "next": 0
    },
    {
      "name": "--merge",
      "alias": [
        "-m"
      ],
      "tip": [
        "U: -m, --merge",
        "并行打印所有文件，每列一个。"
      ]
    },
    {
      "name": "--no-file-warnings",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --no-file-warnings",
        "文件无法打开时省略警告。"
      ]
    },
    {
      "name": "--number-lines",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n[SEP[DIGITS]], --number-lines[=SEP[DIGITS]]",
        "为行编号，使用 DIGITS（5）位数字，然后是 SEP（制表符）。"
      ]
    },
    {
      "name": "--omit-header",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --omit-header",
        "省略页眉和页脚。",
        "如果 PAGE_LENGTH <= 10 则隐含。"
      ]
    },
    {
      "name": "--omit-pagination",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --omit-pagination",
        "省略页眉和页脚，消除换页符设置的任何分页。"
      ]
    },
    {
      "name": "--output-tabs",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i[CHAR[WIDTH]], --output-tabs[=CHAR[WIDTH]]",
        "用字符（制表符）替换空格，制表宽度为（8）。"
      ]
    },
    {
      "name": "--page-width",
      "alias": [
        "-W"
      ],
      "tip": [
        "U: -W, --page-width=<PAGE_WIDTH>",
        "始终设置页宽度为 PAGE_WIDTH（72）个字符。"
      ],
      "next": 0
    },
    {
      "name": "--pages",
      "tip": [
        "U: +FIRST_PAGE[:LAST_PAGE], --pages=FIRST_PAGE[:LAST_PAGE]",
        "从第 FIRST_[LAST_]PAGE 页开始[停止]打印。"
      ],
      "next": 0
    },
    {
      "name": "--sep-string",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S[STRING], --sep-string[=STRING]",
        "用 STRING 分隔列。"
      ]
    },
    {
      "name": "--separator",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s[CHAR], --separator[=CHAR]",
        "用单个字符分隔列。"
      ]
    },
    {
      "name": "--show-control-chars",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --show-control-chars",
        "使用尖号表示法（^G）和八进制反斜杠表示法。"
      ]
    },
    {
      "name": "--show-nonprinting",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --show-nonprinting",
        "使用八进制反斜杠表示法。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --width=<PAGE_WIDTH>",
        "设置页宽度为 PAGE_WIDTH（72）个字符，仅用于多文本列输出。"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
