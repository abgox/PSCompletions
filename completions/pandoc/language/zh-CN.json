      "next": [
        {
          "name": "auto",
          "tip": [
            "自动换行。"
          ]
        },
        {
          "name": "none",
          "tip": [
            "不换行。"
          ]
        },
        {
          "name": "preserve",
          "tip": [
            "保持原始换行。"
