{
  "meta": {
    "url": "https://pandoc.org",
    "description": [
      "Universal document converter."
    ]
  },
  "option": [
    {
      "name": "--bibliography",
      "tip": [
        "U: --bibliography FILE",
        "Set the bibliography file."
      ],
      "next": 0
    },
    {
      "name": "--citeproc",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --citeproc",
        "Enable citation processing."
      ]
    },
    {
      "name": "--columns",
      "tip": [
        "U: --columns NUMBER",
        "Set the line length for wrapping."
      ],
      "next": 0
    },
    {
      "name": "--csl",
      "tip": [
        "U: --csl FILE",
        "Set the CSL file for citation style."
      ],
      "next": 0
    },
    {
      "name": "--data-dir",
      "tip": [
        "U: --data-dir DIRECTORY",
        "Set the user data directory."
      ],
      "next": 0
    },
    {
      "name": "--defaults",
      "tip": [
        "U: --defaults FILE",
        "Read default settings from FILE."
      ],
      "next": 0
    },
    {
      "name": "--fail-if-warnings",
      "tip": [
        "Exit with error if there are warnings."
      ]
    },
    {
      "name": "--filter",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --filter PROGRAM",
        "Use PROGRAM as an external filter."
      ],
      "next": 0
    },
    {
      "name": "--from",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --from FORMAT",
        "Specify input format."
      ],
      "next": 0
    },
    {
      "name": "--highlight-style",
      "tip": [
        "U: --highlight-style STYLE",
        "Set syntax highlighting style."
      ],
      "next": 0
    },
    {
      "name": "--katex",
      "tip": [
        "Use KaTeX to render math."
      ]
    },
    {
      "name": "--list-highlight-languages",
      "tip": [
        "List available highlight languages."
      ]
    },
    {
      "name": "--list-highlight-styles",
      "tip": [
        "List available highlight styles."
      ]
    },
    {
      "name": "--list-input-formats",
      "tip": [
        "List available input formats."
      ]
    },
    {
      "name": "--list-output-formats",
      "tip": [
        "List available output formats."
      ]
    },
    {
      "name": "--log",
      "tip": [
        "U: --log FILE",
        "Write log messages to FILE."
      ],
      "next": 0
    },
    {
      "name": "--lua-filter",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --lua-filter SCRIPTPATH",
        "Use a Lua filter for processing."
      ],
      "next": 0
    },
    {
      "name": "--mathjax",
      "tip": [
        "Use MathJax to render math."
      ]
    },
    {
      "name": "--mathml",
      "tip": [
        "Use MathML to render math."
      ]
    },
    {
      "name": "--metadata",
      "tip": [
        "U: --metadata KEY=VALUE",
        "Set a metadata field."
      ],
      "next": 0
    },
    {
      "name": "--number-sections",
      "alias": [
        "-N"
      ],
      "tip": [
        "U: -N, --number-sections",
        "Number section headings."
      ]
    },
    {
      "name": "--output",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --output FILE",
        "Write output to FILE."
      ],
      "next": 0
    },
    {
      "name": "--pdf-engine",
      "tip": [
        "U: --pdf-engine PROGRAM",
        "Use PROGRAM to generate the PDF."
      ],
      "next": 0
    },
    {
      "name": "--print-default-template",
      "tip": [
        "U: --print-default-template FORMAT",
        "Print the default template for FORMAT."
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "tip": [
        "Suppress warning output."
      ]
    },
    {
      "name": "--resource-path",
      "tip": [
        "U: --resource-path SEARCHPATH",
        "Set the search path for resources."
      ],
      "next": 0
    },
    {
      "name": "--standalone",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --standalone",
        "Produce a standalone document."
      ]
    },
    {
      "name": "--template",
      "tip": [
        "U: --template FILE",
        "Use FILE as a custom template."
      ],
      "next": 0
    },
    {
      "name": "--to",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --to FORMAT",
        "Specify output format."
      ],
      "next": 0
    },
    {
      "name": "--toc",
      "tip": [
        "Include a table of contents."
      ]
    },
    {
      "name": "--toc-depth",
      "tip": [
        "U: --toc-depth NUMBER",
        "Number of levels to include in the table of contents."
      ],
      "next": 0
    },
    {
      "name": "--variable",
      "tip": [
        "U: --variable KEY=VALUE",
        "Set a template variable."
      ],
      "next": 0
    },
    {
      "name": "--verbose",
      "tip": [
        "Provide more verbose output."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Print version information."
      ]
    },
    {
      "name": "--webtex",
      "tip": [
        "Use webTeX to render math."
      ]
    },
    {
      "name": "--wrap",
      "tip": [
        "U: --wrap auto|none|preserve",
        "Set the wrapping mode."
      ],
      "next": [
        {
          "name": "auto",
          "tip": [
            "Wrap automatically."
          ]
        },
        {
          "name": "none",
          "tip": [
            "Don't wrap."
          ]
        },
        {
          "name": "preserve",
          "tip": [
            "Preserve original wrapping."
          ]
        }
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show help."
      ]
    }
  ]
}
