{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Print the number of cores available to the current process."
    ]
  },
  "option": [
    {
      "name": "--all",
      "tip": [
        "print the number of cores available to the system"
      ]
    },
    {
      "name": "--ignore",
      "tip": [
        "U: --ignore <N>",
        "ignore up to N cores"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
