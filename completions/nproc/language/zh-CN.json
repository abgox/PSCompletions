{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "打印当前进程可用的核心数。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--all",
      "tip": [
        "打印系统可用的 CPU 核心数"
      ]
    },
    {
      "name": "--ignore",
      "tip": [
        "U: --ignore <N>",
        "忽略最多 N 个核心"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
