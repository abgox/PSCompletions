      ],
      "next": 0
    },
    {
      "name": "--variable",
      "tip": [
        "U: --variable <NAME=VALUE>",
        "Define a variable"
      ],
      "next": 0
    },
    {
      "name": "--variables-file",
      "tip": [
        "U: --variables-file <FILE>",
        "Define a properties file for variables"
      ],
      "next": 0
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --verbose",
