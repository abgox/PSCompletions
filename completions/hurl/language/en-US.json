      ],
      "next": 0
    },
    {
      "name": "--cookie-jar",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --cookie-jar <FILE>",
        "Write cookies to FILE after running"
      ],
      "next": 0
    },
    {
      "name": "--curl",
      "tip": [
        "U: --curl <FILE>",
        "Export each request to a list of curl commands"
      ],
      "next": 0
    },
    {
      "name": "--delay",
      "tip": [
        "U: --delay <MILLISECONDS>",
