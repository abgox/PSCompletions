      "tip": [
        "U: --error-format <FORMAT>",
        "Control the format of error messages"
      ],
      "next": [
        {
          "name": "long",
          "tip": [
            "Long format"
          ]
        },
        {
          "name": "short",
          "tip": [
            "Short format (default)"
          ]
        }
      ]
    },
    {
      "name": "--file-root",
      "tip": [
        "U: --file-root <DIR>",
