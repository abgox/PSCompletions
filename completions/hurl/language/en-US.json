    {
      "name": "--http1.1",
      "tip": [
        "Use HTTP version 1.1"
      ]
    },
    {
      "name": "--http2",
      "tip": [
        "Use HTTP version 2"
      ]
    },
    {
      "name": "--http3",
      "tip": [
        "Use HTTP version 3"
      ]
