{
  "meta": {
    "url": "https://hurl.dev",
    "description": [
      "Run and test HTTP requests with plain text",
      "A tool for transferring data with URLs"
    ]
  },
  "option": [
    {
      "name": "--aws-sigv4",
      "tip": [
        "U: --aws-sigv4 <PROVIDER>",
        "Use AWS V4 signature authentication"
      ],
      "next": 0
    },
    {
      "name": "--cacert",
      "tip": [
        "U: --cacert <FILE>",
        "CA certificate to verify peer against"
      ],
      "next": 0
    },
    {
      "name": "--cert",
      "alias": [
        "-E"
      ],
      "tip": [
        "U: -E, --cert <CERTIFICATE[:PASSWORD]>",
        "Client certificate file and password"
      ],
      "next": 0
    },
    {
      "name": "--color",
      "tip": [
        "Colorize output"
      ]
    },
    {
      "name": "--compressed",
      "tip": [
        "Request compressed response"
      ]
    },
    {
      "name": "--connect-timeout",
      "tip": [
        "U: --connect-timeout <SECONDS>",
        "Maximum time allowed for connection"
      ],
      "next": 0
    },
    {
      "name": "--connect-to",
      "tip": [
        "U: --connect-to <HOST1:PORT1:HOST2:PORT2>",
