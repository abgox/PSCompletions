    {
      "name": "--json",
      "tip": [
        "Output each Hurl file result to JSON"
      ]
    },
    {
      "name": "--key",
      "tip": [
        "U: --key <KEY>",
        "Private key file name"
      ],
      "next": 0
    },
    {
      "name": "--limit-rate",
      "tip": [
        "U: --limit-rate <SPEED>",
