{
  "meta": {
    "url": "https://www.sqlite.org",
    "description": [
      "SQLite command line interface."
    ]
  },
  "option": [
    {
      "name": "--",
      "tip": [
        "Treat all subsequent arguments as filenames."
      ]
    },
    {
      "name": "-A",
      "tip": [
        "U: -A ARGS",
        "Set mode to column and set column separator."
      ],
      "next": 0
    },
    {
      "name": "-append",
      "tip": [
        "U: -append FILE",
        "Open the database using the append VFS."
      ],
      "next": 0
    },
    {
      "name": "-ascii",
      "tip": [
        "Set mode to ascii."
      ]
    },
    {
      "name": "-bail",
      "tip": [
        "Stop after hitting an error."
      ]
    },
    {
      "name": "-batch",
      "tip": [
        "Force batch I/O mode."
      ]
    },
    {
      "name": "-box",
      "tip": [
        "Set mode to box."
      ]
    },
    {
      "name": "-cmd",
      "tip": [
        "U: -cmd COMMAND",
        "Run COMMAND before reading from stdin."
      ],
      "next": 0
    },
    {
      "name": "-column",
      "tip": [
        "Set mode to column (default)."
      ]
    },
    {
      "name": "-csv",
      "tip": [
        "Set mode to csv."
      ]
    },
    {
      "name": "-deserialize",
      "tip": [
        "Open the database using the deserialize VFS."
      ]
    },
    {
      "name": "-echo",
      "tip": [
        "Echo commands before execution."
      ]
    },
    {
      "name": "-escape",
      "tip": [
        "U: -escape T",
        "Set the string escaping mode."
      ],
      "next": [
        {
          "name": "ascii",
          "tip": [
            "Use ASCII-based escaping."
          ]
        },
        {
          "name": "off",
          "tip": [
            "Disable string escaping."
          ]
        },
        {
          "name": "symbol",
          "tip": [
            "Use symbol-based escaping."
          ]
        }
      ]
    },
    {
      "name": "-header",
      "tip": [
        "Turn headers on."
      ]
    },
    {
      "name": "-html",
      "tip": [
        "Set mode to html."
      ]
    },
    {
      "name": "-ifexists",
      "tip": [
        "Don't open a database that doesn't exist."
      ]
    },
    {
      "name": "-init",
      "tip": [
        "U: -init FILENAME",
        "Read and execute commands from FILENAME."
      ],
      "next": 0
    },
    {
      "name": "-interactive",
      "tip": [
        "Force interactive I/O mode."
      ]
    },
    {
      "name": "-json",
      "tip": [
        "Set mode to json."
      ]
    },
    {
      "name": "-line",
      "tip": [
        "Set mode to line."
      ]
    },
    {
      "name": "-list",
      "tip": [
        "Set mode to list."
      ]
    },
    {
      "name": "-markdown",
      "tip": [
        "Set mode to markdown."
      ]
    },
    {
      "name": "-newline",
      "tip": [
        "U: -newline SEP",
        "Set the row separator string."
      ],
      "next": 0
    },
    {
      "name": "-nofollow",
      "tip": [
        "Don't follow symlinks when opening a database."
      ]
    },
    {
      "name": "-noheader",
      "tip": [
        "Turn headers off."
      ]
    },
    {
      "name": "-noinit",
      "tip": [
        "Don't read any init commands."
      ]
    },
    {
      "name": "-nullvalue",
      "tip": [
        "U: -nullvalue TEXT",
        "Set the string used for NULL values."
      ],
      "next": 0
    },
    {
      "name": "-quote",
      "tip": [
        "Set mode to quote."
      ]
    },
    {
      "name": "-readonly",
      "tip": [
        "Open the database in read-only mode."
      ]
    },
    {
      "name": "-safe",
      "tip": [
        "Like -init, but disable possible harmful operations."
      ]
    },
    {
      "name": "-separator",
      "tip": [
        "U: -separator SEP",
        "Set the column separator string."
      ],
      "next": 0
    },
    {
      "name": "-stats",
      "tip": [
        "Print memory stats before each finalize."
      ]
    },
    {
      "name": "-table",
      "tip": [
        "Set mode to table."
      ]
    },
    {
      "name": "-tabs",
      "tip": [
        "Set mode to tabs."
      ]
    },
    {
      "name": "-version",
      "tip": [
        "Show SQLite version."
      ]
    },
    {
      "name": "-vfs",
      "tip": [
        "U: -vfs NAME",
        "Use NAME as the default VFS."
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "-help",
      "tip": [
        "Show help."
      ]
    }
  ]
}
