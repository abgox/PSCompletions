{
  "meta": {
    "url": "https://www.sqlite.org",
    "description": [
      "SQLite 命令行界面。"
    ]
  },
  "option": [
    {
      "name": "--",
      "tip": [
        "将所有后续参数视为文件名。"
      ]
    },
    {
      "name": "-A",
      "tip": [
        "U: -A ARGS",
        "设置模式为列模式并设置列分隔符。"
      ],
      "next": 0
    },
    {
      "name": "-append",
      "tip": [
        "U: -append FILE",
        "使用追加 VFS 打开数据库。"
      ],
      "next": 0
    },
    {
      "name": "-ascii",
      "tip": [
        "设置模式为 ascii。"
      ]
    },
    {
      "name": "-bail",
      "tip": [
        "遇到错误时停止执行。"
      ]
    },
    {
      "name": "-batch",
      "tip": [
        "强制批处理 I/O 模式。"
      ]
    },
    {
      "name": "-box",
      "tip": [
        "设置模式为 box。"
      ]
    },
    {
      "name": "-cmd",
      "tip": [
        "U: -cmd COMMAND",
        "在读取标准输入之前运行命令。"
      ],
      "next": 0
    },
    {
      "name": "-column",
      "tip": [
        "设置模式为 column（默认）。"
      ]
    },
    {
      "name": "-csv",
      "tip": [
        "设置模式为 csv。"
      ]
    },
    {
      "name": "-deserialize",
      "tip": [
        "使用反序列化 VFS 打开数据库。"
      ]
    },
    {
      "name": "-echo",
      "tip": [
        "执行前回显命令。"
      ]
    },
    {
      "name": "-escape",
      "tip": [
        "U: -escape T",
        "设置字符串转义模式。"
      ],
      "next": [
        {
          "name": "ascii",
          "tip": [
            "使用基于 ASCII 的转义。"
          ]
        },
        {
          "name": "off",
          "tip": [
            "禁用字符串转义。"
          ]
        },
        {
          "name": "symbol",
          "tip": [
            "使用基于符号的转义。"
          ]
        }
      ]
    },
    {
      "name": "-header",
      "tip": [
        "开启表头显示。"
      ]
    },
    {
      "name": "-html",
      "tip": [
        "设置模式为 html。"
      ]
    },
    {
      "name": "-ifexists",
      "tip": [
        "不打开不存在的数据库。"
      ]
    },
    {
      "name": "-init",
      "tip": [
        "U: -init FILENAME",
        "从文件读取并执行命令。"
      ],
      "next": 0
    },
    {
      "name": "-interactive",
      "tip": [
        "强制交互式 I/O 模式。"
      ]
    },
    {
      "name": "-json",
      "tip": [
        "设置模式为 json。"
      ]
    },
    {
      "name": "-line",
      "tip": [
        "设置模式为 line。"
      ]
    },
    {
      "name": "-list",
      "tip": [
        "设置模式为 list。"
      ]
    },
    {
      "name": "-markdown",
      "tip": [
        "设置模式为 markdown。"
      ]
    },
    {
      "name": "-newline",
      "tip": [
        "U: -newline SEP",
        "设置行分隔符字符串。"
      ],
      "next": 0
    },
    {
      "name": "-nofollow",
      "tip": [
        "打开数据库时不跟随符号链接。"
      ]
    },
    {
      "name": "-noheader",
      "tip": [
        "关闭表头显示。"
      ]
    },
    {
      "name": "-noinit",
      "tip": [
        "不读取任何初始化命令。"
      ]
    },
    {
      "name": "-nullvalue",
      "tip": [
        "U: -nullvalue TEXT",
        "设置用于 NULL 值的字符串。"
      ],
      "next": 0
    },
    {
      "name": "-quote",
      "tip": [
        "设置模式为 quote。"
      ]
    },
    {
      "name": "-readonly",
      "tip": [
        "以只读模式打开数据库。"
      ]
    },
    {
      "name": "-safe",
      "tip": [
        "类似 -init，但禁用可能有害的操作。"
      ]
    },
    {
      "name": "-separator",
      "tip": [
        "U: -separator SEP",
        "设置列分隔符字符串。"
      ],
      "next": 0
    },
    {
      "name": "-stats",
      "tip": [
        "在每次 finalize 前打印内存统计。"
      ]
    },
    {
      "name": "-table",
      "tip": [
        "设置模式为 table。"
      ]
    },
    {
      "name": "-tabs",
      "tip": [
        "设置模式为 tabs。"
      ]
    },
    {
      "name": "-version",
      "tip": [
        "显示 SQLite 版本。"
      ]
    },
    {
      "name": "-vfs",
      "tip": [
        "U: -vfs NAME",
        "使用指定名称作为默认 VFS。"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "-help",
      "tip": [
        "显示帮助。"
      ]
    }
  ]
}
