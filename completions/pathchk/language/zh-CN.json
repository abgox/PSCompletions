{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "诊断无效或不可移植的文件名。"
    ]
  },
  "option": [
    {
      "name": "--portability",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --portability",
        "检查所有 POSIX 系统（等同于 -p -P）。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "-P",
      "tip": [
        "检查空名称和前导 \"-\"。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
