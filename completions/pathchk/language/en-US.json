{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "Diagnose invalid or unportable file names."
    ]
  },
  "option": [
    {
      "name": "--portability",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --portability",
        "Check for all POSIX systems (equivalent to -p -P)."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "-P",
      "tip": [
        "Check for empty names and leading \"-\"."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
