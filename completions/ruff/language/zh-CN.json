{
  "meta": {
    "url": "https://github.com/astral-sh/ruff",
    "description": [
      "极速的 Python linter 和代码格式化工具。"
    ]
  },
  "next": [
    {
      "name": "analyze",
      "tip": [
        "对 Python 源代码运行分析。"
      ],
      "next": [
        {
          "name": "graph",
          "tip": [
            "生成 Python 文件依赖项或依赖者的映射。"
          ]
        }
      ]
    },
    {
      "name": "check",
      "tip": [
        "对给定的文件或目录运行 Ruff。"
      ],
      "option": [
        {
          "name": "--add-ignore",
          "tip": [
            "启用自动添加 ruff:ignore 注释到失败行。"
          ]
        },
        {
          "name": "--add-noqa",
          "tip": [
            "启用自动添加 noqa 指令到失败行。"
          ]
        },
        {
          "name": "--cache-dir",
          "tip": [
            "U: --cache-dir <CACHE_DIR>",
            "缓存目录的路径。"
          ],
          "next": 0
        },
        {
          "name": "--diff",
          "tip": [
            "将每个更改文件的差异输出到 stdout。",
            "隐含 --fix-only。"
          ]
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <FILE_PATTERN>",
            "要从分析中省略的路径列表。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--exit-non-zero-on-fix",
          "tip": [
            "如果通过 fix 修改了任何文件，则以非零状态码退出。"
          ]
        },
        {
          "name": "--exit-zero",
          "alias": [
            "-e"
          ],
          "tip": [
            "U: -e, --exit-zero",
            "以状态码 0 退出，即使检测到 lint 违规。"
          ]
        },
        {
          "name": "--extend-exclude",
          "tip": [
            "U: --extend-exclude <FILE_PATTERN>",
            "类似 --exclude，但添加额外的文件和目录。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--extend-select",
          "tip": [
            "U: --extend-select <RULE_CODE>",
            "类似 --select，但在已指定的规则代码上添加额外的规则代码。"
          ],
          "next": 0
