{
  "meta": {
    "url": "https://github.com/astral-sh/ruff",
    "description": [
      "An extremely fast Python linter and code formatter."
    ]
  },
  "next": [
    {
      "name": "analyze",
      "tip": [
        "Run analysis over Python source code."
      ],
      "next": [
        {
          "name": "graph",
          "tip": [
            "Generate a map of Python file dependencies or dependents."
          ]
        }
      ]
    },
    {
      "name": "check",
      "tip": [
        "Run Ruff on the given files or directories."
      ],
      "option": [
        {
          "name": "--add-ignore",
          "tip": [
            "Enable automatic additions of ruff:ignore comments to failing lines."
          ]
        },
        {
          "name": "--add-noqa",
          "tip": [
            "Enable automatic additions of noqa directives to failing lines."
          ]
        },
        {
          "name": "--cache-dir",
          "tip": [
            "U: --cache-dir <CACHE_DIR>",
            "Path to the cache directory."
          ],
          "next": 0
        },
        {
          "name": "--diff",
          "tip": [
            "Output a diff for each changed file to stdout.",
            "Implies --fix-only."
          ]
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <FILE_PATTERN>",
            "List of paths to omit from analysis."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--exit-non-zero-on-fix",
          "tip": [
            "Exit with a non-zero status code if any files were modified via fix."
          ]
        },
        {
          "name": "--exit-zero",
          "alias": [
            "-e"
          ],
          "tip": [
            "U: -e, --exit-zero",
            "Exit with status code 0, even upon detecting lint violations."
          ]
        },
        {
          "name": "--extend-exclude",
          "tip": [
            "U: --extend-exclude <FILE_PATTERN>",
            "Like --exclude, but adds additional files and directories."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--extend-select",
          "tip": [
            "U: --extend-select <RULE_CODE>",
            "Like --select, but adds additional rule codes on top of those already specified."
          ],
          "next": 0
        },
        {
          "name": "--extension",
          "tip": [
            "U: --extension <EXTENSION>",
            "List of mappings from file extension to language."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--fix",
          "tip": [
            "Apply fixes to resolve lint violations.",
            "Use --no-fix to disable or --unsafe-fixes to include unsafe fixes."
          ]
        },
        {
          "name": "--fix-only",
          "tip": [
            "Apply fixes but don't report leftover violations.",
            "Implies --fix."
          ]
        },
        {
          "name": "--fixable",
          "tip": [
            "U: --fixable <RULE_CODE>",
            "List of rule codes to treat as eligible for fix."
          ],
          "next": 0
        },
        {
          "name": "--force-exclude",
          "tip": [
            "Enforce exclusions, even for paths passed directly on the command-line."
          ]
        },
        {
          "name": "--ignore",
          "tip": [
            "U: --ignore <RULE_CODE>",
            "Comma-separated list of rule codes to disable."
          ],
          "next": 0
        },
        {
          "name": "--ignore-noqa",
          "tip": [
            "Ignore any # noqa comments."
          ]
        },
        {
          "name": "--no-cache",
          "alias": [
            "-n"
          ],
          "tip": [
            "U: -n, --no-cache",
            "Disable cache reads."
          ]
        },
