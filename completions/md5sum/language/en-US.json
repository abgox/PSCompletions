{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Compute and check MD5 message digests."
    ]
  },
  "option": [
    {
      "name": "--binary",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --binary",
        "read in binary mode (default)"
      ]
    },
    {
      "name": "--check",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --check",
        "read hashsums from the FILEs and check them"
      ]
    },
    {
      "name": "--ignore-missing",
      "tip": [
        "don't fail or report status for missing files"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "don't print OK for each successfully verified file"
      ]
    },
    {
      "name": "--status",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --status",
        "don't output anything, status code shows success"
      ]
    },
    {
      "name": "--strict",
      "tip": [
        "exit non-zero for improperly formatted checksum lines"
      ]
    },
    {
      "name": "--tag",
      "tip": [
        "create a BSD-style checksum"
      ]
    },
    {
      "name": "--text",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --text",
        "read in text mode"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "--warn",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --warn",
        "warn about improperly formatted checksum lines"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --zero",
        "end each output line with NUL, not newline"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
