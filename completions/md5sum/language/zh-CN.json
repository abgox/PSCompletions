{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "计算和检查消息摘要。",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--binary",
      "alias": [
        "-b"
      ],
      "tip": [
        "以二进制模式读取（默认）"
      ]
    },
    {
      "name": "--check",
      "alias": [
        "-c"
      ],
      "tip": [
        "从 FILE 中读取哈希值并验证"
      ]
    },
    {
      "name": "--ignore-missing",
      "tip": [
        "不为缺失文件失败或报告状态"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "不为每个成功验证的文件打印 OK"
      ]
    },
    {
      "name": "--status",
      "alias": [
        "-s"
      ],
      "tip": [
        "不输出任何内容，状态码显示成功"
      ]
    },
    {
      "name": "--strict",
      "tip": [
        "对格式不正确的校验和行以非零状态退出"
      ]
    },
    {
      "name": "--tag",
      "tip": [
        "创建 BSD 风格的校验和"
      ]
    },
    {
      "name": "--text",
      "alias": [
        "-t"
      ],
      "tip": [
        "以文本模式读取"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--warn",
      "alias": [
        "-w"
      ],
      "tip": [
        "对格式不正确的校验和行发出警告"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "以 NUL 而非换行符结束每个输出行"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
