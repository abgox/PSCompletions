{
    "install": [
        "Alias: i\n",
        "{{$PSCompletions.config.sym}}Install a package\n",
        "e.g. npm install axios"
    ],
    "install -g": [
        "{{$PSCompletions.config.sym_opt}}Install a package globally\n",
        "e.g. npm i -g typescript"
    ],

    "install -S": [
        "Alias: --save\n",
        "write to the dependencies of package.json\n",
        "e.g. npm i [-S] axios "
    ],
    "install -D": [
        "Alias: --save-dev\n",
        "write to the devDependencies of package.json\n",
        "e.g. npm i -D sass "
    ],
    "uninstall": [
        "{{$PSCompletions.config.sym}}Uninstall a package\n",
        "e.g. npm uninstall axios"
    ],
    "uninstall -g": "{{$PSCompletions.config.sym}}Uninstall globally",
    "update": [
        "Update a package\n",
        "e.g. npm Update typescript"
    ],
    "search": [
        "Search for packages\n",
        "e.g. npm search [search terms ...]"
    ],
    "init": [
        "{{$PSCompletions.config.sym}}Initialize a package.json file\n",
        "e.g. npm init"
    ],
    "init -y": [
        "Alias: --yes\n",
        "{{$PSCompletions.config.sym_opt}}Initialize a package.json file(without confirm)\n",
        "e.g. npm init -y"
    ],
    "init -f": [
        "Alias: --force\n",
        "{{$PSCompletions.config.sym_opt}}Force initialize a package.json file"
    ],
    "list": [
        "Alias: ls\n",
        "{{$PSCompletions.config.sym}}List installed packages"
    ],
    "list -g": "List installed packages globally",
    "test": "run this projects tests",
    "cache": "{{$PSCompletions.config.sym}}Manipulates packages cache",
    "cache add": [
        "Add packages cache\n",
        "e.g. npm cache add <package-spec>"
    ],
    "cache clean": [
        "Clean packages cache\n",
        "e.g. npm cache clean [<key>]"
    ],
    "cache ls": [
        "List packages cache\n",
        "e.g. npm cache ls [<name>@<version>]"
    ],
    "cache Verify": [
        "Verify package's cache\n",
        "e.g. npm cache verify"
    ],
    "config": [
        "Alias: c\n",
        "{{$PSCompletions.config.sym}}Manage the npm configuration files"
    ],
    "config set": [
        "Set the npm configuration\n",
        "e.g. npm config set <key>=<value> [<key>=<value> ...]"
    ],
    "config get": [
        "Get the npm configuration\n",
        "e.g. npm config get [<key> [<key> ...]]"
    ],
    "config delete": [
        "Delete the npm configuration\n",
        "e.g. npm config delete <key> [<key> ...]"
    ],
    "config list": [
        "List the npm configuration\n",
        "e.g. npm config list [--json]"
    ],
    "config edit": [
        "Edit the npm configuration\n",
        "e.g. npm config edit"
    ],
    "config fix": [
        "Fix the npm configuration\n",
        "e.g. npm config fix"
    ],
    "run": [
        "run the script named <foo>\n",
        "e.g. npm run <foo>"
    ],
    "root": "Display npm root",
    "view": "View registry info",
    "outdated": "Check for outdated packages",
    "-l": "display usage info for all commands",
    "-v": [
        "Alias: --version\n",
        "Print the current version of Volta"
    ],
    "help": "Show official help",
    "npm_core_info": {
        "help": "Show help"
    }
}
