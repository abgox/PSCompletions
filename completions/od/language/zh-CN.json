{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "以八进制和其他格式转储文件。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--address-radix",
      "alias": [
        "-A"
      ],
      "tip": [
        "U:  -A, --address-radix <RADIX>",
        "选择打印文件偏移量的基数。"
      ],
      "next": [
        {
          "name": "d",
          "tip": [
            "十进制"
          ]
        },
        {
          "name": "n",
          "tip": [
            "无"
          ]
        },
        {
          "name": "o",
          "tip": [
            "八进制"
          ]
        },
        {
          "name": "x",
          "tip": [
            "十六进制"
          ]
        }
      ]
    },
    {
      "name": "--endian",
      "tip": [
        "U: --endian <big|little>",
        "多字节格式使用的字节序",
        "[可选值：big, little]"
      ],
      "next": [
        {
          "name": "big"
        },
        {
          "name": "little"
        }
      ]
    },
    {
      "name": "--format",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --format <TYPE>",
        "选择输出格式"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "用于可打印的 7 位 ASCII"
          ]
        },
        {
          "name": "c",
          "tip": [
            "用于 UTF-8 字符或未定义字符的八进制"
          ]
        },
        {
          "name": "d",
          "tip": [
            "U: d[SIZE]",
            "用于有符号十进制"
          ]
        },
        {
          "name": "f",
          "tip": [
            "U: f[SIZE]",
            "用于浮点数"
          ]
        },
        {
          "name": "o",
          "tip": [
            "U: o[SIZE]",
            "用于八进制"
          ]
        },
        {
          "name": "u",
          "tip": [
            "U: u[SIZE]",
            "用于无符号十进制"
          ]
        },
        {
          "name": "x",
          "tip": [
            "U: x[SIZE]",
            "用于十六进制"
          ]
        }
      ]
    },
    {
      "name": "--output-duplicates",
      "alias": [
        "-v"
      ],
      "tip": [
        "不使用 * 来标记行抑制"
      ]
    },
    {
      "name": "--read-bytes",
      "alias": [
        "-N"
      ],
      "tip": [
        "U: -N, --read-bytes <BYTES>",
        "将转储限制为 BYTES 个输入字节。"
      ],
      "next": 0
    },
    {
      "name": "--skip-bytes",
      "alias": [
        "-j"
      ],
      "tip": [
        "U: -j, --skip-bytes <BYTES>",
        "在格式化和写入之前跳过 BYTES 个输入字节。"
      ],
      "next": 0
    },
    {
      "name": "--strings",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --strings <BYTES>",
        "未实现：输出至少 BYTES 个图形字符的字符串。",
        "未指定 BYTES 时，默认为 3。"
      ],
      "next": 0
    },
    {
      "name": "--traditional",
      "tip": [
        "具有一个输入、偏移量和标签的兼容模式。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --width [<BYTES>]",
        "每行输出 BYTES 个字节。未指定 BYTES 时，默认为 32。"
      ],
      "next": 0
    },
    {
      "name": "-a",
      "tip": [
        "命名字符，忽略高位比特"
      ]
    },
    {
      "name": "-b",
      "tip": [
        "八进制字节"
      ]
    },
    {
      "name": "-c",
      "tip": [
        "ASCII 字符或反斜杠转义序列"
      ]
    },
    {
      "name": "-d",
      "tip": [
        "无符号十进制 2 字节单位"
      ]
    },
    {
      "name": "-D",
      "tip": [
        "无符号十进制 4 字节单位"
      ]
    },
    {
      "name": "-e",
      "tip": [
        "浮点双精度（64 位）单位"
      ]
    },
    {
      "name": "-f",
      "tip": [
        "浮点双精度（32 位）单位"
      ]
    },
    {
      "name": "-F",
      "tip": [
        "浮点双精度（64 位）单位"
      ]
    },
    {
      "name": "-h",
      "tip": [
        "十六进制 2 字节单位"
      ]
    },
    {
      "name": "-H",
      "tip": [
        "十六进制 4 字节单位"
      ]
    },
    {
      "name": "-i",
      "tip": [
        "十进制 4 字节单位"
      ]
    },
    {
      "name": "-I",
      "tip": [
        "十进制 8 字节单位"
      ]
    },
    {
      "name": "-l",
      "tip": [
        "十进制 8 字节单位"
      ]
    },
    {
      "name": "-L",
      "tip": [
        "十进制 8 字节单位"
      ]
    },
    {
      "name": "-o",
      "tip": [
        "八进制 2 字节单位"
      ]
    },
    {
      "name": "-O",
      "tip": [
        "八进制 4 字节单位"
      ]
    },
    {
      "name": "-s",
      "tip": [
        "十进制 2 字节单位"
      ]
    },
    {
      "name": "-x",
      "tip": [
        "十六进制 2 字节单位"
      ]
    },
    {
      "name": "-X",
      "tip": [
        "十六进制 4 字节单位"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
