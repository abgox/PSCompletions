{
  "meta": {
    "url": "https://github.com/sharkdp/bat",
    "description": [
      "Cat clone with syntax highlighting and Git integration."
    ]
  },
  "next": [
    {
      "name": "cache",
      "tip": [
        "U: cache [OPTIONS]",
        "Customize syntaxes and themes."
      ],
      "option": [
        {
          "name": "--acknowledgements",
          "tip": [
            "Show acknowledgements."
          ]
        },
        {
          "name": "--build",
          "tip": [
            "Build the cache from scratch."
          ]
        },
        {
          "name": "--clear",
          "tip": [
            "Remove the generated cache files."
          ]
        },
        {
          "name": "--config-dir",
          "tip": [
            "Show the configuration directory."
          ]
        },
        {
          "name": "--data-dir",
          "tip": [
            "Show the data directory."
          ]
        },
        {
          "name": "--init",
          "tip": [
            "Initialize the cache by reading from bat's default syntaxes and themes."
          ]
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--acknowledgements",
      "tip": [
        "Show acknowledgements."
      ]
    },
    {
      "name": "--diagnostic",
      "tip": [
        "Show diagnostic information for bug reports."
      ]
    },
    {
      "name": "--list-languages",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --list-languages",
        "Display a list of supported languages."
      ]
    },
    {
      "name": "--list-themes",
      "tip": [
        "Display a list of supported themes."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version information."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--binary",
      "tip": [
        "U: --binary <behavior>",
        "How to treat binary content."
      ],
      "next": [
        {
          "name": "as-text"
        },
        {
          "name": "no-printing"
        }
      ]
    },
    {
      "name": "--chop-long-lines",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --chop-long-lines",
        "Truncate all lines longer than screen width."
      ]
    },
    {
      "name": "--color",
      "tip": [
        "U: --color <when>",
        "When to use colored output."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--decorations",
      "tip": [
        "U: --decorations <when>",
        "When to use decorations specified via --style."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--diff",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --diff",
        "Only show lines added/removed/modified with respect to the Git index."
      ]
    },
    {
      "name": "--diff-context",
      "tip": [
        "U: --diff-context <N>",
        "Include N lines of context around added/removed/modified lines."
      ],
      "next": 0
    },
    {
      "name": "--file-name",
      "tip": [
        "U: --file-name <name>",
        "Specify the name to display for a file."
      ],
      "next": 0
    },
    {
      "name": "--force-colorization",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --force-colorization",
        "Alias for --decorations=always --color=always."
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help information."
      ]
    },
    {
      "name": "--highlight-line",
      "alias": [
        "-H"
      ],
      "tip": [
        "U: -H, --highlight-line <N:M>",
        "Highlight the specified line ranges."
      ],
      "next": 0
    },
    {
      "name": "--ignored-suffix",
      "tip": [
        "U: --ignored-suffix <suffix>",
        "Ignore extension for syntax detection."
      ],
      "next": 0
    },
    {
      "name": "--italic-text",
      "tip": [
        "U: --italic-text <when>",
        "When to use ANSI sequences for italic text."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--language",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --language <language>",
        "Explicitly set the language for syntax highlighting."
      ],
      "next": 0
    },
    {
      "name": "--line-range",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --line-range <N:M>",
        "Only print the specified range of lines."
      ],
      "next": 0
    },
    {
      "name": "--map-syntax",
      "alias": [
        "-m"
      ],
      "tip": [
        "U: -m, --map-syntax <glob:syntax>",
        "Map a glob pattern to an existing syntax name."
      ],
      "next": 0
    },
    {
      "name": "--nonprintable-notation",
      "tip": [
        "U: --nonprintable-notation <notation>",
        "Set notation for non-printable characters."
      ],
      "next": [
        {
          "name": "caret"
        },
        {
          "name": "unicode"
        }
      ]
    },
    {
      "name": "--number",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --number",
        "Only show line numbers, no other decorations."
      ]
    },
    {
      "name": "--pager",
      "tip": [
        "U: --pager <command>",
        "Determine which pager is used."
      ],
      "next": 0
    },
    {
      "name": "--paging",
      "tip": [
        "U: --paging <when>",
        "When to use the pager."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--plain",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --plain",
        "Only show plain style, no decorations."
      ],
      "repeat": 2
    },
    {
      "name": "--set-terminal-title",
      "tip": [
        "Sets terminal title to filenames when using a pager."
      ]
    },
    {
      "name": "--show-all",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --show-all",
        "Show non-printable characters like space, tab or newline."
      ]
    },
    {
      "name": "--squeeze-blank",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --squeeze-blank",
        "Squeeze consecutive empty lines into one."
      ]
    },
    {
      "name": "--squeeze-limit",
      "tip": [
        "U: --squeeze-limit <limit>",
        "Maximum number of consecutive empty lines to print."
      ],
      "next": 0
    },
    {
      "name": "--strip-ansi",
      "tip": [
        "U: --strip-ansi <when>",
        "When to strip ANSI escape sequences."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--style",
      "tip": [
        "U: --style <components>",
        "Configure which elements to display."
      ],
      "next": [
        {
          "name": "auto"
        },
        {
          "name": "changes"
        },
        {
          "name": "default"
        },
        {
          "name": "full"
        },
        {
          "name": "grid"
        },
        {
          "name": "header"
        },
        {
          "name": "header-filename"
        },
        {
          "name": "header-filesize"
        },
        {
          "name": "numbers"
        },
        {
          "name": "plain"
        },
        {
          "name": "rule"
        },
        {
          "name": "snip"
        }
      ]
    },
    {
      "name": "--tabs",
      "tip": [
        "U: --tabs <T>",
        "Set the tab width to T spaces."
      ],
      "next": 0
    },
    {
      "name": "--terminal-width",
      "tip": [
        "U: --terminal-width <width>",
        "Explicitly set the width of the terminal."
      ],
      "next": 0
    },
    {
      "name": "--theme",
      "tip": [
        "U: --theme <theme>",
        "Set the theme for syntax highlighting."
      ],
      "next": 0
    },
    {
      "name": "--theme-dark",
      "tip": [
        "U: --theme-dark <theme>",
        "Theme for dark background terminals."
      ],
      "next": 0
    },
    {
      "name": "--theme-light",
      "tip": [
        "U: --theme-light <theme>",
        "Theme for light background terminals."
      ],
      "next": 0
    },
    {
      "name": "--wrap",
      "tip": [
        "U: --wrap <mode>",
        "Specify the text-wrapping mode."
      ],
      "next": [
        {
          "name": "auto"
        },
        {
          "name": "character"
        },
        {
          "name": "never"
        }
      ]
    }
  ]
}
