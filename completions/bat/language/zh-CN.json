        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--style",
      "tip": [
        "U: --style <components>",
        "配置要显示的元素。"
      ],
      "next": [
        {
          "name": "auto"
        },
        {
          "name": "changes"
        },
        {
          "name": "default"
        },
        {
          "name": "full"
        },
        {
          "name": "grid"
        },
        {
          "name": "header"
        },
        {
          "name": "header-filename"
        },
        {
          "name": "header-filesize"
        },
        {
          "name": "numbers"
        },
        {
          "name": "plain"
        },
        {
          "name": "rule"
        },
        {
          "name": "snip"
        }
      ]
    },
    {
      "name": "--tabs",
      "tip": [
        "U: --tabs <T>",
        "将制表符宽度设置为 T 个空格。"
      ],
      "next": 0
    },
    {
      "name": "--terminal-width",
      "tip": [
        "U: --terminal-width <width>",
        "显式设置终端宽度。"
      ],
      "next": 0
    },
    {
      "name": "--theme",
      "tip": [
        "U: --theme <theme>",
        "设置语法高亮的主题。"
      ],
      "next": 0
    },
    {
      "name": "--theme-dark",
      "tip": [
        "U: --theme-dark <theme>",
        "深色背景终端的主题。"
      ],
      "next": 0
    },
    {
      "name": "--theme-light",
      "tip": [
        "U: --theme-light <theme>",
        "浅色背景终端的主题。"
      ],
      "next": 0
