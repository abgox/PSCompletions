    {
      "name": "--wrap",
      "tip": [
        "U: --wrap <mode>",
        "指定文本换行模式。"
      ],
      "next": [
        {
          "name": "auto"
        },
        {
          "name": "character"
        },
        {
          "name": "never"
        }
      ]
