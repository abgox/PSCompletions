      "tip": [
        "U: -m, --map-syntax <glob:syntax>",
        "将 glob 模式映射到现有语法名称。"
      ],
      "next": 0
    },
    {
      "name": "--nonprintable-notation",
      "tip": [
        "U: --nonprintable-notation <notation>",
        "设置不可打印字符的表示法。"
      ],
      "next": [
        {
          "name": "caret"
        },
        {
          "name": "unicode"
        }
      ]
    },
    {
      "name": "--number",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --number",
        "仅显示行号，无其他装饰。"
      ]
    },
    {
      "name": "--pager",
      "tip": [
        "U: --pager <command>",
        "确定使用哪个分页器。"
      ],
      "next": 0
    },
    {
      "name": "--paging",
      "tip": [
        "U: --paging <when>",
        "何时使用分页器。"
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--plain",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --plain",
        "仅显示纯文本样式，无装饰。"
      ],
      "repeat": 2
    },
    {
      "name": "--set-terminal-title",
      "tip": [
        "使用分页器时将终端标题设置为文件名。"
      ]
    },
    {
      "name": "--show-all",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --show-all",
        "显示不可打印字符，如空格、制表符或换行符。"
      ]
    },
    {
      "name": "--squeeze-blank",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --squeeze-blank",
        "将连续空行压缩为一行。"
      ]
