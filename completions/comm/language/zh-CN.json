{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "逐行比较两个已排序的文件。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--check-order",
      "tip": [
        "检查输入是否正确排序，即使所有输入行都可配对"
      ]
    },
    {
      "name": "--nocheck-order",
      "tip": [
        "不检查输入是否正确排序"
      ]
    },
    {
      "name": "--output-delimiter",
      "tip": [
        "U: --output-delimiter <STR>",
        "使用 STR 分隔列"
      ],
      "next": 0
    },
    {
      "name": "--total",
      "tip": [
        "输出摘要"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "行分隔符为 NUL，而非换行符"
      ]
    },
    {
      "name": "-1",
      "tip": [
        "不输出第 1 列（仅在 FILE1 中的行）"
      ]
    },
    {
      "name": "-2",
      "tip": [
        "不输出第 2 列（仅在 FILE2 中的行）"
      ]
    },
    {
      "name": "-3",
      "tip": [
        "不输出第 3 列（两个文件中都出现的行）"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
