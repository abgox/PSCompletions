  "option": [
    {
      "name": "--colorScheme",
      "tip": [
        "U: --colorScheme <scheme-name>",
        "覆盖配置文件的 colorScheme 设置"
      ],
      "next": 0
    },
    {
      "name": "--pos",
      "tip": [
        "指定终端在屏幕上的位置, 格式为 \"x,y\"",
        "(屏幕的左上角是原点: x 是 0, y 是 0)",
        "E: --pos 100,200   --- 从 x 100, y 200 开始。"
      ],
      "next": 0
    },
    {
      "name": "--size",
      "tip": [
        "指定终端的列数和行数, 格式为 \"column,row\"",
        "E: --size 80,25   --- 从 80 列和 25 行开始"
      ],
      "next": 0
    },
    {
      "name": "--tabColor",
      "tip": [
        "U: --tabColor <hex-color>",
        "设置标签页颜色 (例如 #RGB 或 #RRGGBB)"
      ],
      "next": 0
    },
    {
      "name": "--title",
      "tip": [
        "U: --title <title>",
        "设置窗口标题"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "显示 wt 的版本信息"
      ]
    },
    {
      "name": "--window",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --window <window-id>",
        "指定运行给定命令行的终端窗口",
        "可选值: new/-1 (新窗口), last/0 (最近使用的窗口), 或窗口 ID/名称",
        "E: -w 0   --- 在当前窗口运行",
        "   -w 1   --- 在下一个窗口运行",
        "   -w new  --- 在新窗口运行"
      ],
      "next": [
        {
          "name": "0",
          "tip": [
            "在最近使用的窗口运行 (last)"
          ]
        },
        {
          "name": "1",
          "tip": [
            "在下一个窗口运行"
          ]
        },
        {
          "name": "new",
          "tip": [
            "始终在新窗口运行"
          ]
        }
      ]
    },
    {
      "name": "-d",
      "tip": [
        "U: -d <dir>",
        "指定启动目录",
        "E: -d \"D:\\\"   --- 从 D 盘根目录启动"
      ],
      "next": 0
    },
    {
      "name": "-f",
      "tip": [
        "以聚焦模式启动窗口"
      ]
    },
    {
      "name": "-F",
      "tip": [
        "以全屏模式启动窗口"
      ]
    },
    {
      "name": "-M",
      "tip": [
        "以最大化模式启动窗口"
      ]
    },
    {
      "name": "-p",
      "tip": [
        "U: -p <profile>",
        "使用指定的配置文件启动终端",
        "E: -p \"PowerShell\"   --- 使用 PowerShell 启动"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h",
        "-?",
        "/?"
      ],
      "tip": [
        "U: -h, -?, --help, /?",
        "显示帮助信息"
      ]
    }
  ]
