{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "将每个文件的行按顺序对应输出到标准输出。"
    ]
  },
  "option": [
    {
      "name": "--delimiters",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --delimiters <LIST>",
        "使用 LIST 中的字符替代 TAB 作为分隔符"
      ],
      "next": 0
    },
    {
      "name": "--serial",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --serial",
        "逐个处理文件而非并行处理"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --zero-terminated",
        "以 NUL 而非换行符作为行分隔符"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
