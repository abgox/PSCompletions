{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "将每个文件中按顺序对应的行用制表符分隔后写入标准输出。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--delimiters",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --delimiters <LIST>",
        "使用 LIST 中的字符替代 TAB 作为分隔符"
      ],
      "next": 0
    },
    {
      "name": "--serial",
      "alias": [
        "-s"
      ],
      "tip": [
        "逐个处理文件而非并行处理"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "以 NUL 而非换行符作为行分隔符"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
