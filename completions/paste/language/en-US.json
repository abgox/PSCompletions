{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Write sequentially corresponding lines from each FILE to stdout."
    ]
  },
  "option": [
    {
      "name": "--delimiters",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --delimiters <LIST>",
        "reuse characters from LIST instead of TABs"
      ],
      "next": 0
    },
    {
      "name": "--serial",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --serial",
        "paste one file at a time instead of in parallel"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --zero-terminated",
        "line delimiter is NUL, not newline"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
