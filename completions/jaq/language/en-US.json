{
  "meta": {
    "url": "https://github.com/01mf02/jaq",
    "description": [
      "Just Another Query Tool",
      "A jq clone focused on correctness and performance"
    ]
  },
  "option": [
    {
      "name": "--arg",
      "tip": [
        "U: --arg <A> <V>",
        "Set variable $A to string V"
      ],
      "next": 0
    },
    {
      "name": "--argjson",
      "tip": [
        "U: --argjson <A> <V>",
        "Set variable $A to JSON value V"
      ],
      "next": 0
    },
    {
      "name": "--args",
      "tip": [
        "Collect remaining positional arguments into $ARGS.positional"
      ]
    },
    {
      "name": "--color-output",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --color-output",
        "Always color output"
      ]
    },
    {
      "name": "--compact-output",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --compact-output",
        "Print JSON compactly, omitting whitespace"
      ]
    },
    {
      "name": "--exit-status",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --exit-status",
        "Use the last output value as exit status code"
      ]
    },
    {
      "name": "--from",
      "tip": [
        "U: --from <FORMAT>",
        "Read input in given format"
      ],
      "next": 0
    },
    {
      "name": "--from-file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --from-file",
        "Read filter from a file"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--in-place",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --in-place",
        "Overwrite input file with its output"
      ]
    },
    {
      "name": "--indent",
      "tip": [
        "U: --indent <N>",
        "Use N spaces for indentation"
      ],
      "next": 0
    },
    {
      "name": "--join-output",
      "alias": [
        "-j"
      ],
      "tip": [
        "U: -j, --join-output",
        "Do not print a newline after each value"
      ]
    },
    {
      "name": "--library-path",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --library-path <DIR>",
        "Search for modules in given directory"
      ],
      "next": 0
    },
    {
      "name": "--monochrome-output",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --monochrome-output",
        "Do not color output"
      ]
    },
    {
      "name": "--null-input",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --null-input",
        "Use null as single input value"
      ]
    },
    {
      "name": "--raw-input",
      "alias": [
        "-R"
      ],
      "tip": [
        "U: -R, --raw-input",
        "Read lines of the input as sequence of strings"
      ]
    },
    {
      "name": "--raw-input0",
      "tip": [
        "Read input like -R, splitting by NUL instead of newlines"
      ]
    },
    {
      "name": "--raw-output",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --raw-output",
        "Write strings without escaping them with quotes"
      ]
    },
    {
      "name": "--raw-output0",
      "tip": [
        "Write output like -r and print NUL after each output"
      ]
    },
    {
      "name": "--rawfile",
      "tip": [
        "U: --rawfile <A> <F>",
        "Set variable $A to string from file F"
      ],
      "next": 0
    },
    {
      "name": "--run-tests",
      "tip": [
        "U: --run-tests <FILE>",
        "Run tests from a file"
      ],
      "next": 0
    },
    {
      "name": "--slurp",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --slurp",
        "Read all input values into one array"
      ]
    },
    {
      "name": "--slurpfile",
      "tip": [
        "U: --slurpfile <A> <F>",
        "Set variable $A to array from JSON file F"
      ],
      "next": 0
    },
    {
      "name": "--sort-keys",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --sort-keys",
        "Print objects sorted by their keys"
      ]
    },
    {
      "name": "--tab",
      "tip": [
        "Use tabs for indentation rather than spaces"
      ]
    },
    {
      "name": "--to",
      "tip": [
        "U: --to <FORMAT>",
        "Write output in given format"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version"
      ]
    }
  ]
}
