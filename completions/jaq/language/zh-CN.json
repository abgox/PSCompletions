{
  "meta": {
    "url": "https://github.com/01mf02/jaq",
    "description": [
      "Just Another Query Tool ",
      "专注于正确性和性能的 jq 克隆"
    ]
  },
  "option": [
    {
      "name": "--arg",
      "tip": [
        "U: --arg <A> <V>",
        "将变量 $A 设置为字符串 V"
      ],
      "next": 0
    },
    {
      "name": "--argjson",
      "tip": [
        "U: --argjson <A> <V>",
        "将变量 $A 设置为 JSON 值 V"
      ],
      "next": 0
    },
    {
      "name": "--args",
      "tip": [
        "将剩余的位置参数收集到 $ARGS.positional 中"
      ]
    },
    {
      "name": "--color-output",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --color-output",
        "始终为输出着色"
      ]
    },
    {
      "name": "--compact-output",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --compact-output",
        "紧凑打印 JSON，省略空白"
      ]
    },
    {
      "name": "--exit-status",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --exit-status",
        "将最后一个输出值用作退出状态码"
      ]
    },
    {
      "name": "--from",
      "tip": [
        "U: --from <FORMAT>",
        "以指定格式读取输入"
      ],
      "next": 0
    },
    {
      "name": "--from-file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --from-file",
        "从文件读取过滤器"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息"
      ]
    },
    {
      "name": "--in-place",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --in-place",
        "用输出覆盖输入文件"
      ]
    },
    {
      "name": "--indent",
      "tip": [
        "U: --indent <N>",
        "使用 N 个空格进行缩进"
      ],
      "next": 0
    },
    {
      "name": "--join-output",
      "alias": [
        "-j"
      ],
      "tip": [
        "U: -j, --join-output",
        "不在每个值后打印换行符"
      ]
    },
    {
      "name": "--library-path",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --library-path <DIR>",
        "在指定目录中搜索模块"
      ],
      "next": 0
    },
    {
      "name": "--monochrome-output",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --monochrome-output",
        "不为输出着色"
      ]
    },
    {
      "name": "--null-input",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --null-input",
        "使用 null 作为唯一的输入值"
      ]
    },
    {
      "name": "--raw-input",
      "alias": [
        "-R"
      ],
      "tip": [
        "U: -R, --raw-input",
        "将输入的每一行读取为字符串序列"
      ]
    },
    {
      "name": "--raw-input0",
      "tip": [
        "类似 -R 读取输入，但按 NUL 而非换行符分割"
      ]
    },
    {
      "name": "--raw-output",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --raw-output",
        "写入字符串时不使用引号转义"
      ]
    },
    {
      "name": "--raw-output0",
      "tip": [
        "类似 -r 写入输出，但每次输出后打印 NUL"
      ]
    },
    {
      "name": "--rawfile",
      "tip": [
        "U: --rawfile <A> <F>",
        "将变量 $A 设置为文件 F 中的字符串"
      ],
      "next": 0
    },
    {
      "name": "--run-tests",
      "tip": [
        "U: --run-tests <FILE>",
        "从文件运行测试"
      ],
      "next": 0
    },
    {
      "name": "--slurp",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --slurp",
        "将所有输入值读取到一个数组中"
      ]
    },
    {
      "name": "--slurpfile",
      "tip": [
        "U: --slurpfile <A> <F>",
        "将变量 $A 设置为 JSON 文件 F 中的数组"
      ],
      "next": 0
    },
    {
      "name": "--sort-keys",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --sort-keys",
        "按键排序打印对象"
      ]
    },
    {
      "name": "--tab",
      "tip": [
        "使用制表符而非空格进行缩进"
      ]
    },
    {
      "name": "--to",
      "tip": [
        "U: --to <FORMAT>",
        "以指定格式写入输出"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本号"
      ]
    }
  ]
}
