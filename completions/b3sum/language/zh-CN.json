{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "计算并校验消息摘要。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--binary",
      "alias": [
        "-b"
      ],
      "tip": [
        "以二进制模式读取 (默认)"
      ]
    },
    {
      "name": "--check",
      "alias": [
        "-c"
      ],
      "tip": [
        "从文件中读取哈希值并进行校验"
      ]
    },
    {
      "name": "--ignore-missing",
      "tip": [
        "对缺失的文件不报错或报告状态"
      ]
    },
    {
      "name": "--length",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --length <BITS>",
        "摘要长度 (以位为单位);",
        "不得超过 blake2 算法的最大值 (512), 且必须是 8 的倍数"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "对每个成功验证的文件不输出 OK"
      ]
    },
    {
      "name": "--status",
      "alias": [
        "-s"
      ],
      "tip": [
        "不输出任何内容, 通过状态码表示成功"
      ]
    },
    {
      "name": "--strict",
      "tip": [
        "对格式不正确的校验和行以非零状态退出"
      ]
    },
    {
      "name": "--tag",
      "tip": [
        "创建 BSD 风格的校验和"
      ]
    },
    {
      "name": "--text",
      "alias": [
        "-t"
      ],
      "tip": [
        "以文本模式读取"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--warn",
      "alias": [
        "-w"
      ],
      "tip": [
        "对格式不正确的校验和行发出警告"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "以 NUL 而非换行符结束每行输出"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
