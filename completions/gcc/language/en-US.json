{
  "meta": {
    "url": "https://gcc.gnu.org",
    "description": [
      "The GNU Compiler Collection"
    ]
  },
  "option": [
    {
      "name": "--sysroot",
      "tip": [
        "U: --sysroot=<directory>",
        "Use <directory> as the root directory for headers and libraries."
      ],
      "next": 0
    },
    {
      "name": "-arch",
      "tip": [
        "U: -arch <arch>",
        "Build for specified architecture."
      ],
      "next": [
        {
          "name": "aarch64",
          "tip": [
            "AArch64 architecture"
          ]
        },
        {
          "name": "x86_64",
          "tip": [
            "x86_64 architecture"
          ]
        }
      ]
    },
    {
      "name": "-B",
      "tip": [
        "U: -B <directory>",
        "Add <directory> to the compiler's search paths."
      ],
      "next": 0
    },
    {
      "name": "-c",
      "tip": [
        "Compile and assemble, but do not link."
      ]
    },
    {
      "name": "-D",
      "tip": [
        "U: -D<name>[=<value>]",
        "Define a preprocessing macro."
      ],
      "next": 0
    },
    {
      "name": "-dumpmachine",
      "tip": [
        "Display the compiler's target processor."
      ]
    },
    {
      "name": "-dumpspecs",
      "tip": [
        "Display all of the built in spec strings."
      ]
    },
    {
      "name": "-dumpversion",
      "tip": [
        "Display the version of the compiler."
      ]
    },
    {
      "name": "-E",
      "tip": [
        "Preprocess only; do not compile, assemble or link."
      ]
    },
    {
      "name": "-foffload",
      "tip": [
        "U: -foffload=<targets>",
        "Specify offloading targets."
      ],
      "next": 0
    },
    {
      "name": "-g",
      "tip": [
        "U: -g[level]",
        "Produce debugging info in default format.",
        "Level can be 0-3 or stabs+DWARF."
      ],
      "next": [
        {
          "name": "0",
          "tip": [
            "Produce no debug info"
          ]
        },
        {
          "name": "1",
          "tip": [
            "Minimal debug info"
          ]
        },
        {
          "name": "2",
          "tip": [
            "Default debug info"
          ]
        },
        {
          "name": "3",
          "tip": [
            "Extra debug info"
          ]
        }
      ]
    },
    {
      "name": "-I",
      "tip": [
        "U: -I<directory>",
        "Add <directory> to the include search path."
      ],
      "next": 0
    },
    {
      "name": "-include",
      "tip": [
        "U: -include <file>",
        "Include the contents of <file> before other files."
      ],
      "next": 0
    },
    {
      "name": "-l",
      "tip": [
        "U: -l<library>",
        "Search for library when linking."
      ],
      "next": 0
    },
    {
      "name": "-L",
      "tip": [
        "U: -L<directory>",
        "Add <directory> to the library search path."
      ],
      "next": 0
    },
    {
      "name": "-no-canonical-prefixes",
      "tip": [
        "Do not canonicalize paths when building relative prefixes to other gcc components."
      ]
    },
    {
      "name": "-nodefaultlibs",
      "tip": [
        "Do not use the standard system libraries when linking."
      ]
    },
    {
      "name": "-nostartfiles",
      "tip": [
        "Do not use the standard startup files when linking."
      ]
    },
    {
      "name": "-nostdlib",
      "tip": [
        "Do not use the standard startup files or libraries when linking."
      ]
    },
    {
      "name": "-o",
      "tip": [
        "U: -o <file>",
        "Place the output into <file>."
      ],
      "next": 0
    },
    {
      "name": "-O",
      "tip": [
        "U: -O<level>",
        "Set optimization level.",
        "Use -O0 to -O3, -Os, -Ofast, -Og, or -Oz."
      ],
      "next": [
        {
          "name": "0",
          "tip": [
            "No optimization"
          ]
        },
        {
          "name": "1",
          "tip": [
            "Optimization level 1"
          ]
        },
        {
          "name": "2",
          "tip": [
            "Optimization level 2"
          ]
        },
        {
          "name": "3",
          "tip": [
            "Optimization level 3 (aggressive)"
          ]
        },
        {
          "name": "fast",
          "tip": [
            "Optimize for speed, disregarding standards compliance"
          ]
        },
        {
          "name": "g",
          "tip": [
            "Optimize for debugging experience"
          ]
        },
        {
          "name": "s",
          "tip": [
            "Optimize for size"
          ]
        },
        {
          "name": "z",
          "tip": [
            "Optimize for size aggressively"
          ]
        }
      ]
    },
    {
      "name": "-pass-exit-codes",
      "tip": [
        "Exit with highest error code from a phase."
      ]
    },
    {
      "name": "-pie",
      "tip": [
        "Create a dynamically linked position independent executable."
      ]
    },
    {
      "name": "-pipe",
      "tip": [
        "Use pipes rather than intermediate files."
      ]
    },
    {
      "name": "-print-file-name",
      "tip": [
        "U: -print-file-name=<lib>",
        "Display the full path to library <lib>."
      ],
      "next": 0
    },
    {
      "name": "-print-libgcc-file-name",
      "tip": [
        "Display the name of the compiler's companion library."
      ]
    },
    {
      "name": "-print-multi-directory",
      "tip": [
        "Display the root directory for versions of libgcc."
      ]
    },
    {
      "name": "-print-multi-lib",
      "tip": [
        "Display the mapping between command line options and multiple library search directories."
      ]
    },
    {
      "name": "-print-multi-os-directory",
      "tip": [
        "Display the relative path to OS libraries."
      ]
    },
    {
      "name": "-print-multiarch",
      "tip": [
        "Display the target's normalized GNU triplet."
      ]
    },
    {
      "name": "-print-prog-name",
      "tip": [
        "U: -print-prog-name=<prog>",
        "Display the full path to compiler component <prog>."
      ],
      "next": 0
    },
    {
      "name": "-print-search-dirs",
      "tip": [
        "Display the directories in the compiler's search path."
      ]
    },
    {
      "name": "-print-sysroot",
      "tip": [
        "Display the target libraries directory."
      ]
    },
    {
      "name": "-print-sysroot-headers-suffix",
      "tip": [
        "Display the sysroot suffix used to find headers."
      ]
    },
    {
      "name": "-S",
      "tip": [
        "Compile only; do not assemble or link."
      ]
    },
    {
      "name": "-save-temps",
      "tip": [
        "Do not delete intermediate files."
      ]
    },
    {
      "name": "-shared",
      "tip": [
        "Create a shared library."
