    {
      "name": "-time",
      "tip": [
        "Time the execution of each subprocess."
      ]
    },
    {
      "name": "-U",
      "tip": [
        "U: -U<name>",
        "Undefine a preprocessing macro."
      ],
      "next": 0
    },
    {
      "name": "-W",
      "tip": [
        "U: -W<warning>",
        "Enable specific warning.",
        "Use -Wno-<warning> to disable."
      ],
      "next": 0
    },
    {
      "name": "-Wa",
      "tip": [
        "U: -Wa,<options>",
        "Pass comma-separated <options> on to the assembler."
