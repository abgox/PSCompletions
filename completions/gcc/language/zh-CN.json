{
  "meta": {
    "url": "https://gcc.gnu.org",
    "description": [
      "GNU 编译器套件"
    ]
  },
  "option": [
    {
      "name": "--sysroot",
      "tip": [
        "U: --sysroot=<directory>",
        "使用 <directory> 作为头文件和库的根目录。"
      ],
      "next": 0
    },
    {
      "name": "-arch",
      "tip": [
        "U: -arch <arch>",
        "为指定架构构建。"
      ],
      "next": [
        {
          "name": "aarch64",
          "tip": [
            "AArch64 架构"
          ]
        },
        {
          "name": "x86_64",
          "tip": [
            "x86_64 架构"
          ]
        }
      ]
    },
    {
      "name": "-B",
      "tip": [
        "U: -B <directory>",
        "将 <directory> 添加到编译器的搜索路径。"
      ],
      "next": 0
    },
    {
      "name": "-c",
      "tip": [
        "编译并汇编，但不链接。"
      ]
    },
    {
      "name": "-D",
      "tip": [
        "U: -D<name>[=<value>]",
        "定义预处理宏。"
      ],
      "next": 0
    },
    {
      "name": "-dumpmachine",
      "tip": [
        "显示编译器的目标处理器。"
      ]
    },
    {
      "name": "-dumpspecs",
      "tip": [
        "显示所有内置的规格字符串。"
      ]
    },
    {
      "name": "-dumpversion",
      "tip": [
        "显示编译器的版本。"
      ]
    },
    {
      "name": "-E",
      "tip": [
        "仅预处理；不编译、汇编或链接。"
      ]
    },
    {
      "name": "-foffload",
      "tip": [
        "U: -foffload=<targets>",
        "指定卸载目标。"
      ],
      "next": 0
    },
    {
      "name": "-g",
      "tip": [
        "U: -g[level]",
        "以默认格式生成调试信息。",
        "级别可以是 0-3 或 stabs+DWARF。"
      ],
      "next": [
        {
          "name": "0",
          "tip": [
            "不生成调试信息"
          ]
        },
        {
          "name": "1",
          "tip": [
            "最小调试信息"
          ]
        },
        {
          "name": "2",
          "tip": [
            "默认调试信息"
          ]
        },
        {
          "name": "3",
          "tip": [
            "额外调试信息"
          ]
        }
      ]
    },
    {
      "name": "-I",
      "tip": [
        "U: -I<directory>",
        "将 <directory> 添加到包含搜索路径。"
      ],
      "next": 0
    },
    {
      "name": "-include",
      "tip": [
        "U: -include <file>",
        "在其他文件之前包含 <file> 的内容。"
      ],
      "next": 0
    },
    {
      "name": "-l",
      "tip": [
        "U: -l<library>",
        "链接时搜索库。"
      ],
      "next": 0
    },
    {
      "name": "-L",
      "tip": [
        "U: -L<directory>",
        "将 <directory> 添加到库搜索路径。"
      ],
      "next": 0
    },
    {
      "name": "-no-canonical-prefixes",
      "tip": [
        "构建到其他 gcc 组件的相对前缀时不规范化路径。"
      ]
    },
    {
      "name": "-nodefaultlibs",
      "tip": [
        "链接时不使用标准系统库。"
      ]
    },
    {
      "name": "-nostartfiles",
      "tip": [
        "链接时不使用标准启动文件。"
      ]
    },
    {
      "name": "-nostdlib",
      "tip": [
        "链接时不使用标准启动文件或库。"
      ]
    },
    {
      "name": "-o",
      "tip": [
        "U: -o <file>",
        "将输出放入 <file>。"
      ],
      "next": 0
    },
    {
      "name": "-O",
      "tip": [
        "U: -O<level>",
        "设置优化级别。",
        "使用 -O0 到 -O3、-Os、-Ofast、-Og 或 -Oz。"
      ],
      "next": [
        {
          "name": "0",
          "tip": [
            "不优化"
          ]
        },
        {
          "name": "1",
          "tip": [
            "优化级别 1"
          ]
        },
        {
          "name": "2",
          "tip": [
            "优化级别 2"
          ]
        },
        {
          "name": "3",
          "tip": [
            "优化级别 3（激进）"
          ]
        },
        {
          "name": "fast",
          "tip": [
            "优化速度，忽略标准合规性"
          ]
        },
        {
          "name": "g",
          "tip": [
            "优化调试体验"
          ]
        },
        {
          "name": "s",
          "tip": [
            "优化大小"
          ]
        },
        {
          "name": "z",
          "tip": [
            "激进优化大小"
          ]
        }
      ]
    },
    {
      "name": "-pass-exit-codes",
      "tip": [
        "以阶段中最高错误代码退出。"
      ]
    },
    {
      "name": "-pie",
      "tip": [
        "创建动态链接的位置无关可执行文件。"
      ]
    },
    {
      "name": "-pipe",
      "tip": [
        "使用管道而不是中间文件。"
      ]
    },
    {
      "name": "-print-file-name",
      "tip": [
        "U: -print-file-name=<lib>",
        "显示库 <lib> 的完整路径。"
      ],
      "next": 0
    },
    {
      "name": "-print-libgcc-file-name",
      "tip": [
        "显示编译器伴随库的名称。"
      ]
    },
    {
      "name": "-print-multi-directory",
      "tip": [
        "显示 libgcc 版本的根目录。"
      ]
    },
    {
      "name": "-print-multi-lib",
      "tip": [
        "显示命令行选项与多个库搜索目录之间的映射。"
      ]
    },
    {
      "name": "-print-multi-os-directory",
      "tip": [
        "显示 OS 库的相对路径。"
      ]
    },
    {
      "name": "-print-multiarch",
      "tip": [
        "显示目标的标准化 GNU 三元组。"
      ]
    },
    {
      "name": "-print-prog-name",
      "tip": [
        "U: -print-prog-name=<prog>",
        "显示编译器组件 <prog> 的完整路径。"
      ],
      "next": 0
    },
    {
      "name": "-print-search-dirs",
      "tip": [
        "显示编译器搜索路径中的目录。"
      ]
    },
    {
      "name": "-print-sysroot",
      "tip": [
        "显示目标库目录。"
      ]
    },
    {
      "name": "-print-sysroot-headers-suffix",
      "tip": [
        "显示用于查找头文件的 sysroot 后缀。"
      ]
    },
    {
      "name": "-S",
      "tip": [
        "仅编译；不汇编或链接。"
      ]
    },
    {
      "name": "-save-temps",
      "tip": [
        "不删除中间文件。"
      ]
    },
    {
      "name": "-shared",
      "tip": [
        "创建共享库。"
      ]
    },
    {
      "name": "-specs",
      "tip": [
        "U: -specs=<file>",
        "用 <file> 的内容覆盖内置规格。"
      ],
      "next": 0
