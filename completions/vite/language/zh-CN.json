{
  "meta": {
    "url": "https://github.com/vitejs/vite",
    "description": [
      "下一代前端工具链。"
    ]
  },
  "next": [
    {
      "name": "build",
      "tip": [
        "为生产环境构建。"
      ],
      "option": [
        {
          "name": "--app",
          "tip": [
            "等同于 `builder: {}`。"
          ]
        },
        {
          "name": "--assetsDir",
          "tip": [
            "U: --assetsDir <dir>",
            "outDir 下放置资源的目录。",
            "默认: assets"
          ],
          "next": 0
        },
        {
          "name": "--assetsInlineLimit",
          "tip": [
            "U: --assetsInlineLimit <number>",
