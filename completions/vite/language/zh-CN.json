          "next": [
            {
              "name": "false",
              "tip": [
                "禁用源映射。"
              ]
            },
            {
              "name": "hidden",
              "tip": [
                "生成单独的源映射。"
              ]
            },
            {
              "name": "inline",
              "tip": [
                "内联源映射。"
              ]
            },
            {
              "name": "true",
              "tip": [
                "启用源映射。"
              ]
            }
          ]
        },
        {
          "name": "--ssr",
          "tip": [
            "U: --ssr [entry]",
            "为服务器端渲染构建指定入口。"
          ],
          "next": 0
