        {
          "name": "--manifest",
          "tip": [
            "U: --manifest [name]",
            "生成构建清单 json。"
          ],
          "next": 0
        },
        {
          "name": "--minify",
          "tip": [
            "U: --minify [minifier]",
            "启用/禁用压缩，或指定要使用的压缩器。",
            "可选值: true, false, 'oxc', 'terser', 'esbuild'",
            "默认: oxc"
          ],
          "next": [
            {
              "name": "esbuild",
              "tip": [
                "使用 esbuild 压缩器。"
              ]
            },
            {
              "name": "false",
              "tip": [
                "禁用压缩。"
              ]
            },
            {
              "name": "oxc",
              "tip": [
                "使用 oxc 压缩器。"
              ]
            },
            {
              "name": "terser",
              "tip": [
                "使用 terser 压缩器。"
              ]
            },
            {
              "name": "true",
              "tip": [
                "启用压缩。"
              ]
            }
          ]
        },
        {
          "name": "--outDir",
          "tip": [
            "U: --outDir <dir>",
            "输出目录。",
            "默认: dist"
          ],
          "next": 0
        },
        {
          "name": "--sourcemap",
          "tip": [
            "U: --sourcemap [output]",
