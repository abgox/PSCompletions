            "Default: oxc"
          ],
          "next": [
            {
              "name": "esbuild",
              "tip": [
                "Use esbuild minifier."
              ]
            },
            {
              "name": "false",
              "tip": [
                "Disable minification."
              ]
            },
            {
              "name": "oxc",
              "tip": [
                "Use oxc minifier."
              ]
            },
            {
              "name": "terser",
              "tip": [
                "Use terser minifier."
              ]
            },
            {
              "name": "true",
              "tip": [
                "Enable minification."
              ]
            }
