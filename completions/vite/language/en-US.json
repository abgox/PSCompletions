            {
              "name": "false",
              "tip": [
                "Disable source maps."
              ]
            },
            {
              "name": "hidden",
              "tip": [
                "Generate separate source maps."
              ]
            },
            {
              "name": "inline",
              "tip": [
                "Inline source maps."
              ]
            },
            {
              "name": "true",
              "tip": [
                "Enable source maps."
              ]
            }
          ]
