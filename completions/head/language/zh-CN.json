{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "打印每个 'FILE' 的前 10 行到标准输出。",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--bytes",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --bytes <[-]NUM>",
        "打印每个文件的前 NUM 个字节；",
        "使用前导 '-'，打印除每个文件最后 NUM 个字节外的所有内容"
      ],
      "next": 0
    },
    {
      "name": "--lines",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --lines <[-]NUM>",
        "打印前 NUM 行而非前 10 行；",
        "使用前导 '-'，打印除每个文件最后 NUM 行外的所有内容"
      ],
      "next": 0
    },
    {
      "name": "--silent",
      "alias": [
        "--quiet",
        "-q"
      ],
      "tip": [
        "从不打印显示文件名的标题"
      ]
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "始终打印显示文件名的标题"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "行分隔符是 NUL 而非换行符"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
