{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "将每个文件中的制表符转换为空格。"
    ]
  },
  "option": [
    {
      "name": "--initial",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --initial",
        "不转换非空格字符后的制表符。"
      ]
    },
    {
      "name": "--tabs",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --tabs=<N or LIST>",
        "设置制表符间隔为 N 个字符，默认为 8。",
        "使用逗号分隔的制表位列表。"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
