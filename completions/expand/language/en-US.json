{
  "meta": {
    "url": "https://www.gnu.org/software/coreutils/",
    "description": [
      "Convert tabs in each FILE to spaces."
    ]
  },
  "option": [
    {
      "name": "--initial",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --initial",
        "Do not convert tabs after non blanks."
      ]
    },
    {
      "name": "--tabs",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --tabs=<N or LIST>",
        "Have tabs N characters apart, not 8.",
        "Use comma separated list of tab positions."
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
