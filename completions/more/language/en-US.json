{
  "meta": {
    "url": "https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/more",
    "description": [
      "Display the contents of a text file one screen at a time."
    ]
  },
  "option": [
    {
      "name": "--clean-print",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --clean-print",
        "Do not scroll, display text and clean line ends."
      ]
    },
    {
      "name": "--exit-on-eof",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --exit-on-eof",
        "Exit on End-Of-File."
      ]
    },
    {
      "name": "--from-line",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --from-line <number>",
        "Start displaying each file at line number."
      ],
      "next": 0
    },
    {
      "name": "--lines",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --lines <number>",
        "The number of lines per screen full."
      ],
      "next": 0
    },
    {
      "name": "--logical",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --logical",
        "Do not pause after any line containing a ^L (form feed)."
      ]
    },
    {
      "name": "--no-pause",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --no-pause",
        "Count logical lines, rather than screen lines."
      ]
    },
    {
      "name": "--number",
      "tip": [
        "U: --number <number>",
        "Same as --lines option argument."
      ],
      "next": 0
    },
    {
      "name": "--pattern",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --pattern <pattern>",
        "The string to be searched in each file before starting to display it."
      ],
      "next": 0
    },
    {
      "name": "--print-over",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --print-over",
        "Do not scroll, clear screen and display text."
      ]
    },
    {
      "name": "--silent",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --silent",
        "Display help instead of ringing bell when an illegal key is pressed."
      ]
    },
    {
      "name": "--squeeze",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --squeeze",
        "Squeeze multiple blank lines into one."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help."
      ]
    }
  ]
}
