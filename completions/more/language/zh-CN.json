{
  "meta": {
    "url": "https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/more",
    "description": [
      "逐屏显示文本文件内容。"
    ]
  },
  "option": [
    {
      "name": "--clean-print",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --clean-print",
        "不滚动，显示文本并清理行尾。"
      ]
    },
    {
      "name": "--exit-on-eof",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --exit-on-eof",
        "在文件结束时退出。"
      ]
    },
    {
      "name": "--from-line",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --from-line <number>",
        "从指定行号开始显示每个文件。"
      ],
      "next": 0
    },
    {
      "name": "--lines",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --lines <number>",
        "每屏显示的行数。"
      ],
      "next": 0
    },
    {
      "name": "--logical",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --logical",
        "在包含 ^L（换页符）的行后不停顿。"
      ]
    },
    {
      "name": "--no-pause",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --no-pause",
        "计算逻辑行而非屏幕行。"
      ]
    },
    {
      "name": "--number",
      "tip": [
        "U: --number <number>",
        "与 --lines 选项参数相同。"
      ],
      "next": 0
    },
    {
      "name": "--pattern",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --pattern <pattern>",
        "在开始显示前在每个文件中搜索的字符串。"
      ],
      "next": 0
    },
    {
      "name": "--print-over",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --print-over",
        "不滚动，清屏并显示文本。"
      ]
    },
    {
      "name": "--silent",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --silent",
        "按非法键时显示帮助而非响铃。"
      ]
    },
    {
      "name": "--squeeze",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --squeeze",
        "将多个空行压缩为一行。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
