{
  "meta": {
    "url": "https://github.com/jesseduffield/lazygit",
    "description": [
      "A simple terminal UI for git commands."
    ]
  },
  "next": [
    {
      "name": "completion",
      "tip": [
        "U: lazygit completion [bash|zsh|fish|powershell]",
        "Generate shell completion script."
      ],
      "next": [
        {
          "name": "bash"
        },
        {
          "name": "fish"
        },
        {
          "name": "powershell"
        },
        {
          "name": "zsh"
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config",
        "Print the default config."
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --debug",
        "Run in debug mode with logging."
      ]
    },
    {
      "name": "--filter",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --filter <path>",
        "Path to filter on in `git log -- <path>`."
      ],
      "next": 0
    },
    {
      "name": "--git-dir",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --git-dir <path>",
        "Equivalent of the --git-dir git argument."
      ],
      "next": 0
    },
    {
      "name": "--logs",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --logs",
        "Tail lazygit logs."
      ]
    },
    {
      "name": "--path",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --path <path>",
        "Path of git repo. (equivalent to --work-tree=<path> --git-dir=<path>/.git/)"
      ],
      "next": 0
    },
    {
      "name": "--print-config-dir",
      "alias": [
        "-cd"
      ],
      "tip": [
        "U: -cd, --print-config-dir",
        "Print the config directory."
      ]
    },
    {
      "name": "--profile",
      "tip": [
        "Start the profiler and serve it on http port 6060."
      ]
    },
    {
      "name": "--screen-mode",
      "alias": [
        "-sm"
      ],
      "tip": [
        "U: -sm, --screen-mode <mode>",
        "The initial screen-mode."
      ],
      "next": [
        {
          "name": "full"
        },
        {
          "name": "half"
        },
        {
          "name": "normal"
        }
      ]
    },
    {
      "name": "--use-config-dir",
      "alias": [
        "-ucd"
      ],
      "tip": [
        "U: -ucd, --use-config-dir <dir>",
        "Override default config directory with provided directory."
      ],
      "next": 0
    },
    {
      "name": "--use-config-file",
      "alias": [
        "-ucf"
      ],
      "tip": [
        "U: -ucf, --use-config-file <files>",
        "Comma separated list to custom config file(s)."
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Print the current version."
      ]
    },
    {
      "name": "--work-tree",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --work-tree <path>",
        "Equivalent of the --work-tree git argument."
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Displays help with available flag, subcommand, and positional value parameters."
      ]
    }
  ]
}
