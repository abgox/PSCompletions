{
  "meta": {
    "url": "https://github.com/jesseduffield/lazygit",
    "description": [
      "Lazygit - 一个简单的 git 命令终端 UI。"
    ]
  },
  "root": [
    {
      "name": "completion",
      "tip": [
        "U: lazygit completion [bash|zsh|fish|powershell]",
        "生成 shell 补全脚本。"
      ],
      "next": [
        {
          "name": "bash"
        },
        {
          "name": "fish"
        },
        {
          "name": "powershell"
        },
        {
          "name": "zsh"
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config",
        "打印默认配置。"
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --debug",
        "以调试模式运行并记录日志。"
      ]
    },
    {
      "name": "--filter",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --filter <path>",
        "在 `git log -- <path>` 中过滤的路径。"
      ],
      "next": 0
    },
    {
      "name": "--git-dir",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --git-dir <path>",
        "等同于 git 的 --git-dir 参数。"
      ],
      "next": 0
    },
    {
      "name": "--logs",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --logs",
        "跟踪 lazygit 日志。"
      ]
    },
    {
      "name": "--path",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --path <path>",
        "git 仓库路径。（等同于 --work-tree=<path> --git-dir=<path>/.git/）"
      ],
      "next": 0
    },
    {
      "name": "--print-config-dir",
      "alias": [
        "-cd"
      ],
      "tip": [
        "U: -cd, --print-config-dir",
        "打印配置目录。"
      ]
    },
    {
      "name": "--profile",
      "tip": [
        "启动分析器并在 http 端口 6060 上提供服务。"
      ]
    },
    {
      "name": "--screen-mode",
      "alias": [
        "-sm"
      ],
      "tip": [
        "U: -sm, --screen-mode <mode>",
        "初始屏幕模式。"
      ],
      "next": [
        {
          "name": "full"
        },
        {
          "name": "half"
        },
        {
          "name": "normal"
        }
      ]
    },
    {
      "name": "--use-config-dir",
      "alias": [
        "-ucd"
      ],
      "tip": [
        "U: -ucd, --use-config-dir <dir>",
        "使用提供的目录覆盖默认配置目录。"
      ],
      "next": 0
    },
    {
      "name": "--use-config-file",
      "alias": [
        "-ucf"
      ],
      "tip": [
        "U: -ucf, --use-config-file <files>",
        "自定义配置文件的逗号分隔列表。"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "打印当前版本。"
      ]
    },
    {
      "name": "--work-tree",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --work-tree <path>",
        "等同于 git 的 --work-tree 参数。"
      ],
      "next": 0
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示可用标志、子命令和位置值参数的帮助。"
      ]
    }
  ]
}
