{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "对于具有相同连接字段的每对输入行，写一行到标准输出。",
      "默认连接字段是第一个，由空格分隔。",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--check-order",
      "tip": [
        "检查输入是否正确排序，即使所有输入行都可配对"
      ]
    },
    {
      "name": "--header",
      "tip": [
        "将每个文件的第一行视为字段标题，打印它们而不尝试配对"
      ]
    },
    {
      "name": "--ignore-case",
      "alias": [
        "-i"
      ],
      "tip": [
        "比较字段时忽略大小写差异"
      ]
    },
    {
      "name": "--nocheck-order",
      "tip": [
        "不检查输入是否正确排序"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "行分隔符是 NUL 而非换行符"
      ]
    },
    {
      "name": "-1",
      "tip": [
        "U: -1 <FIELD>",
        "在文件 1 的此 FIELD 上连接"
      ],
      "next": 0
    },
    {
      "name": "-2",
      "tip": [
        "U: -2 <FIELD>",
        "在文件 2 的此 FIELD 上连接"
      ],
      "next": 0
    },
    {
      "name": "-a",
      "tip": [
        "U: -a <FILENUM>",
        "同时打印文件 FILENUM 中无法配对的行，其中 FILENUM 为 1 或 2，对应 FILE1 或 FILE2",
        "[possible values: 1, 2]"
      ],
      "next": [
        {
          "name": "1"
        },
        {
          "name": "2"
        }
      ]
    },
    {
      "name": "-e",
      "tip": [
        "U: -e <EMPTY>",
        "用 EMPTY 替换缺失的输入字段"
      ],
      "next": 0
    },
    {
      "name": "-j",
      "tip": [
        "U: -j <FIELD>",
        "等同于 '-1 FIELD -2 FIELD'"
      ],
      "next": 0
    },
    {
      "name": "-o",
      "tip": [
        "U: -o <FORMAT>",
        "构建输出行时遵循 FORMAT"
      ],
      "next": 0
    },
    {
      "name": "-t",
      "tip": [
        "U: -t <CHAR>",
        "使用 CHAR 作为输入和输出字段分隔符"
      ],
      "next": 0
    },
    {
      "name": "-v",
      "tip": [
        "U: -v <FILENUM>",
        "类似 -a FILENUM，但抑制已连接的输出行",
        "[possible values: 1, 2]"
      ],
      "next": [
        {
          "name": "1"
        },
        {
          "name": "2"
        }
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
