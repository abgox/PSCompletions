{
  "meta": {
    "url": "https://maven.apache.org",
    "description": [
      "Apache Maven, a software project management tool."
    ]
  },
  "option": [
    {
      "name": "--show-version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --show-version",
        "Display version information WITHOUT stopping build."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Display version information."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--activate-profiles",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --activate-profiles <arg>",
        "Comma-delimited list of profiles to activate."
      ],
      "next": 0
    },
    {
      "name": "--also-make",
      "alias": [
        "-am"
      ],
      "tip": [
        "U: -am, --also-make",
        "If project list is specified, also build projects required by the list."
      ]
    },
    {
      "name": "--also-make-dependents",
      "alias": [
        "-amd"
      ],
      "tip": [
        "U: -amd, --also-make-dependents",
        "If project list is specified, also build projects that depend on projects on the list."
      ]
    },
    {
      "name": "--batch-mode",
      "alias": [
        "-B"
      ],
      "tip": [
        "U: -B, --batch-mode",
        "Run in non-interactive (batch) mode."
      ]
    },
    {
      "name": "--builder",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --builder <arg>",
        "The id of the build strategy to use."
      ],
      "next": 0
    },
    {
      "name": "--check-plugin-updates",
      "alias": [
        "-cpu"
      ],
      "tip": [
        "U: -cpu, --check-plugin-updates",
        "Ineffective, only kept for backward compatibility."
      ]
    },
    {
      "name": "--color",
      "tip": [
        "U: --color <arg>",
        "Defines the color mode of the output."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-X"
      ],
      "tip": [
        "U: -X, --debug",
        "Produce execution debug output."
      ]
    },
    {
      "name": "--define",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --define <arg>",
        "Define a user property."
      ],
      "next": 0
    },
    {
      "name": "--encrypt-master-password",
      "alias": [
        "-emp"
      ],
      "tip": [
        "U: -emp, --encrypt-master-password <arg>",
        "Encrypt master security password."
      ],
      "next": 0
    },
    {
      "name": "--encrypt-password",
      "alias": [
        "-ep"
      ],
      "tip": [
        "U: -ep, --encrypt-password <arg>",
        "Encrypt server password."
      ],
      "next": 0
    },
    {
      "name": "--errors",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --errors",
        "Produce execution error messages."
      ]
    },
    {
      "name": "--fail-at-end",
      "alias": [
        "-fae"
      ],
      "tip": [
        "U: -fae, --fail-at-end",
        "Only fail the build afterwards; allow all non-impacted builds to continue."
      ]
    },
    {
      "name": "--fail-fast",
      "alias": [
        "-ff"
      ],
      "tip": [
        "U: -ff, --fail-fast",
        "Stop at first failure in reactorized builds."
      ]
    },
    {
      "name": "--fail-never",
      "alias": [
        "-fn"
      ],
      "tip": [
        "U: -fn, --fail-never",
        "NEVER fail the build, regardless of project result."
      ]
    },
    {
      "name": "--file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --file <arg>",
        "Force the use of an alternate POM file."
      ],
      "next": 0
    },
    {
      "name": "--global-settings",
      "alias": [
        "-gs"
      ],
      "tip": [
        "U: -gs, --global-settings <arg>",
        "Alternate path for the global settings file."
      ],
      "next": 0
    },
    {
      "name": "--global-toolchains",
      "alias": [
        "-gt"
      ],
      "tip": [
        "U: -gt, --global-toolchains <arg>",
        "Alternate path for the global toolchains file."
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Display help information."
      ]
    },
    {
      "name": "--ignore-transitive-repositories",
      "alias": [
        "-itr"
      ],
      "tip": [
        "U: -itr, --ignore-transitive-repositories",
        "If set, Maven will ignore remote repositories introduced by transitive dependencies."
      ]
    },
    {
      "name": "--lax-checksums",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --lax-checksums",
        "Warn if checksums don't match."
      ]
    },
    {
      "name": "--log-file",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --log-file <arg>",
        "Log file where all build output will go."
      ],
      "next": 0
    },
    {
      "name": "--no-plugin-registry",
      "alias": [
        "-npr"
      ],
      "tip": [
        "U: -npr, --no-plugin-registry",
        "Ineffective, only kept for backward compatibility."
      ]
    },
    {
      "name": "--no-plugin-updates",
      "alias": [
        "-npu"
      ],
      "tip": [
        "U: -npu, --no-plugin-updates",
        "Ineffective, only kept for backward compatibility."
      ]
    },
    {
      "name": "--no-snapshot-updates",
      "alias": [
        "-nsu"
      ],
      "tip": [
        "U: -nsu, --no-snapshot-updates",
        "Suppress SNAPSHOT updates."
      ]
    },
    {
      "name": "--no-transfer-progress",
      "alias": [
        "-ntp"
      ],
      "tip": [
        "U: -ntp, --no-transfer-progress",
        "Do not display transfer progress when downloading or uploading."
      ]
    },
    {
      "name": "--non-recursive",
      "alias": [
        "-N"
      ],
      "tip": [
        "U: -N, --non-recursive",
        "Do not recurse into sub-projects."
      ]
    },
    {
      "name": "--offline",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --offline",
        "Work offline."
      ]
    },
    {
      "name": "--projects",
      "alias": [
        "-pl"
      ],
      "tip": [
        "U: -pl, --projects <arg>",
        "Comma-delimited list of specified reactor projects to build."
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "Quiet output - only show errors."
      ]
    },
    {
      "name": "--raw-streams",
      "tip": [
        "Ignored (Maven4 option)."
      ]
    },
    {
      "name": "--resume-from",
      "alias": [
        "-rf"
      ],
      "tip": [
        "U: -rf, --resume-from <arg>",
        "Resume reactor from specified project."
      ],
      "next": 0
    },
    {
      "name": "--settings",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --settings <arg>",
        "Alternate path for the user settings file."
      ],
      "next": 0
    },
    {
      "name": "--strict-checksums",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --strict-checksums",
        "Fail the build if checksums don't match."
      ]
    },
    {
      "name": "--threads",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --threads <arg>",
        "Thread count, for instance 4 (int) or 2C/2.5C (int/float)."
      ],
      "next": 0
    },
    {
      "name": "--toolchains",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --toolchains <arg>",
        "Alternate path for the user toolchains file."
      ],
      "next": 0
    },
    {
      "name": "--update-plugins",
      "alias": [
        "-up"
      ],
      "tip": [
        "U: -up, --update-plugins",
        "Ineffective, only kept for backward compatibility."
      ]
    },
    {
      "name": "--update-snapshots",
      "alias": [
        "-U"
      ],
      "tip": [
        "U: -U, --update-snapshots",
        "Forces a check for missing releases and updated snapshots on remote repositories."
      ]
    }
  ]
}
