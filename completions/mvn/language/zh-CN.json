{
  "meta": {
    "url": "https://maven.apache.org",
    "description": [
      "Apache Maven - 一个软件项目管理和理解工具。"
    ]
  },
  "option": [
    {
      "name": "--show-version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --show-version",
        "显示版本信息但不停止构建。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--activate-profiles",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --activate-profiles <arg>",
        "要激活的配置文件的逗号分隔列表。"
      ],
      "next": 0
    },
    {
      "name": "--also-make",
      "alias": [
        "-am"
      ],
      "tip": [
        "U: -am, --also-make",
        "如果指定了项目列表，也构建列表所需的项目。"
      ]
    },
    {
      "name": "--also-make-dependents",
      "alias": [
        "-amd"
      ],
      "tip": [
        "U: -amd, --also-make-dependents",
        "如果指定了项目列表，也构建依赖于列表中项目的项目。"
      ]
    },
    {
      "name": "--batch-mode",
      "alias": [
        "-B"
      ],
      "tip": [
        "U: -B, --batch-mode",
        "以非交互（批处理）模式运行。"
      ]
    },
    {
      "name": "--builder",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --builder <arg>",
        "要使用的构建策略的 ID。"
      ],
      "next": 0
    },
    {
      "name": "--check-plugin-updates",
      "alias": [
        "-cpu"
      ],
      "tip": [
        "U: -cpu, --check-plugin-updates",
        "无效，仅保留用于向后兼容。"
      ]
    },
    {
      "name": "--color",
      "tip": [
        "U: --color <arg>",
        "定义输出的颜色模式。"
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-X"
      ],
      "tip": [
        "U: -X, --debug",
        "生成执行调试输出。"
      ]
    },
    {
      "name": "--define",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --define <arg>",
        "定义用户属性。"
      ],
      "next": 0
    },
    {
      "name": "--encrypt-master-password",
      "alias": [
        "-emp"
      ],
      "tip": [
        "U: -emp, --encrypt-master-password <arg>",
        "加密主安全密码。"
      ],
      "next": 0
    },
    {
      "name": "--encrypt-password",
      "alias": [
        "-ep"
      ],
      "tip": [
        "U: -ep, --encrypt-password <arg>",
        "加密服务器密码。"
      ],
      "next": 0
    },
    {
      "name": "--errors",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --errors",
        "生成执行错误消息。"
      ]
    },
    {
      "name": "--fail-at-end",
      "alias": [
        "-fae"
      ],
      "tip": [
        "U: -fae, --fail-at-end",
        "仅在之后失败构建；允许所有未受影响的构建继续。"
      ]
    },
    {
      "name": "--fail-fast",
      "alias": [
        "-ff"
      ],
      "tip": [
        "U: -ff, --fail-fast",
        "在反应器化构建中遇到第一个失败即停止。"
      ]
    },
    {
      "name": "--fail-never",
      "alias": [
        "-fn"
      ],
      "tip": [
        "U: -fn, --fail-never",
        "永不失败构建，无论项目结果如何。"
      ]
    },
    {
      "name": "--file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --file <arg>",
        "强制使用替代的 POM 文件。"
      ],
      "next": 0
    },
    {
      "name": "--global-settings",
      "alias": [
        "-gs"
      ],
      "tip": [
        "U: -gs, --global-settings <arg>",
        "全局设置文件的替代路径。"
      ],
      "next": 0
    },
    {
      "name": "--global-toolchains",
      "alias": [
        "-gt"
      ],
      "tip": [
        "U: -gt, --global-toolchains <arg>",
        "全局工具链文件的替代路径。"
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    },
    {
      "name": "--ignore-transitive-repositories",
      "alias": [
        "-itr"
      ],
      "tip": [
        "U: -itr, --ignore-transitive-repositories",
        "如果设置，Maven 将忽略传递依赖引入的远程仓库。"
      ]
    },
    {
      "name": "--lax-checksums",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --lax-checksums",
        "如果校验和不匹配则发出警告。"
      ]
    },
    {
      "name": "--log-file",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --log-file <arg>",
        "所有构建输出将进入的日志文件。"
      ],
      "next": 0
    },
    {
      "name": "--no-plugin-registry",
      "alias": [
        "-npr"
      ],
      "tip": [
        "U: -npr, --no-plugin-registry",
        "无效，仅保留用于向后兼容。"
      ]
    },
    {
      "name": "--no-plugin-updates",
      "alias": [
        "-npu"
      ],
      "tip": [
        "U: -npu, --no-plugin-updates",
        "无效，仅保留用于向后兼容。"
      ]
    },
    {
      "name": "--no-snapshot-updates",
      "alias": [
        "-nsu"
      ],
      "tip": [
        "U: -nsu, --no-snapshot-updates",
        "抑制 SNAPSHOT 更新。"
      ]
    },
    {
      "name": "--no-transfer-progress",
      "alias": [
        "-ntp"
      ],
      "tip": [
        "U: -ntp, --no-transfer-progress",
        "下载或上传时不显示传输进度。"
      ]
    },
    {
      "name": "--non-recursive",
      "alias": [
        "-N"
      ],
      "tip": [
        "U: -N, --non-recursive",
        "不递归到子项目。"
      ]
    },
    {
      "name": "--offline",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --offline",
        "离线工作。"
      ]
    },
    {
      "name": "--projects",
      "alias": [
        "-pl"
      ],
      "tip": [
        "U: -pl, --projects <arg>",
        "要构建的指定反应器项目的逗号分隔列表。"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "安静输出 - 仅显示错误。"
      ]
    },
    {
      "name": "--raw-streams",
      "tip": [
        "忽略（Maven4 选项）。"
      ]
    },
    {
      "name": "--resume-from",
      "alias": [
        "-rf"
      ],
      "tip": [
        "U: -rf, --resume-from <arg>",
        "从指定项目恢复反应器。"
      ],
      "next": 0
    },
    {
      "name": "--settings",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --settings <arg>",
        "用户设置文件的替代路径。"
      ],
      "next": 0
    },
    {
      "name": "--strict-checksums",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --strict-checksums",
        "如果校验和不匹配则构建失败。"
      ]
    },
    {
      "name": "--threads",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --threads <arg>",
        "线程数，例如 4（整数）或 2C/2.5C（整数/浮点数）。"
      ],
      "next": 0
    },
    {
      "name": "--toolchains",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --toolchains <arg>",
        "用户工具链文件的替代路径。"
      ],
      "next": 0
    },
    {
      "name": "--update-plugins",
      "alias": [
        "-up"
      ],
      "tip": [
        "U: -up, --update-plugins",
        "无效，仅保留用于向后兼容。"
      ]
    },
    {
      "name": "--update-snapshots",
      "alias": [
        "-U"
      ],
      "tip": [
        "U: -U, --update-snapshots",
        "强制检查远程仓库中缺少的版本和更新的快照。"
      ]
    }
  ]
}
