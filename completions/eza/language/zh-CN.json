{
  "meta": {
    "url": "https://eza.rocks",
    "description": [
      "ls 的现代替代品。"
    ]
  },
  "option": [
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "打印版本。"
      ]
    }
  ],
  "global_option": [
    {
