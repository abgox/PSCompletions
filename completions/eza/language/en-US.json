{
  "meta": {
    "url": "https://eza.rocks",
    "description": [
      "A modern replacement for ls."
    ]
  },
  "option": [
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Print version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--absolute",
      "tip": [
        "U: --absolute [<on|off|follow>]",
        "Display entries with their absolute path."
      ],
      "next": [
        {
          "name": "follow"
        },
        {
          "name": "off"
        },
        {
          "name": "on"
        }
      ]
    },
    {
      "name": "--accessed",
      "alias": [
        "-u"
      ],
      "tip": [
        "U: -u, --accessed",
        "Show the accessed timestamp field."
      ]
    },
    {
      "name": "--across",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --across",
        "Sort the grid across, rather than downwards."
      ]
    },
    {
      "name": "--all",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --all",
        "Show hidden files. Use twice to also show '.' and '..'."
      ],
      "repeat": 2
    },
    {
      "name": "--almost-all",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --almost-all",
        "Equivalent to --all; included for compatibility with ls -A."
      ]
    },
    {
      "name": "--binary",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --binary",
        "Show file sizes with binary prefixes."
      ]
    },
    {
      "name": "--blocksize",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --blocksize",
        "List size of allocated file system blocks."
      ]
    },
    {
      "name": "--bytes",
      "alias": [
        "-B"
      ],
      "tip": [
        "U: -B, --bytes",
        "Show file sizes in bytes, without any prefixes."
      ]
    },
    {
      "name": "--changed",
      "tip": [
        "Show the changed timestamp field."
      ]
    },
    {
      "name": "--classify",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --classify [<WHEN>]",
        "Display type indicator by file names."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--code",
      "tip": [
        "U: --code [=MODE]",
        "Summarise lines of code by language."
      ],
      "next": [
        {
          "name": "both"
        },
        {
          "name": "lines"
        },
        {
          "name": "percent"
        }
      ]
    },
    {
      "name": "--color",
      "tip": [
        "U: --color [<WHEN>]",
        "When to use colours."
      ],
      "next": [
        {
          "name": "always"
        },
        {
          "name": "auto"
        },
        {
          "name": "never"
        }
      ]
    },
    {
      "name": "--color-scale",
