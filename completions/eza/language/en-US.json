    {
      "name": "--group-directories-last",
      "tip": [
        "List directories after other files."
      ]
    },
    {
      "name": "--header",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --header",
        "Add a header row to each column."
      ]
