      "name": "--follow-symlinks",
      "tip": [
        "Drill down into symbolic links that point to directories."
      ]
    },
    {
      "name": "--git",
      "tip": [
        "List each file's Git status, if tracked or ignored."
      ]
    },
    {
      "name": "--git-ignore",
      "tip": [
        "Ignore files mentioned in .gitignore."
      ]
    },
    {
      "name": "--git-repos",
      "tip": [
        "List root of git-tree status."
      ]
    },
    {
      "name": "--git-repos-no-status",
      "tip": [
        "List root of git-tree branch name (much faster)."
      ]
    },
    {
      "name": "--grid",
      "alias": [
        "-G"
      ],
      "tip": [
        "U: -G, --grid",
        "Display entries as a grid (default)."
      ]
