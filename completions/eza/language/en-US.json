        {
          "name": "fixed"
        },
        {
          "name": "gradient"
        }
      ]
    },
    {
      "name": "--context",
      "alias": [
        "-Z"
      ],
      "tip": [
        "U: -Z, --context",
        "List each file's security context."
      ]
    },
    {
      "name": "--created",
      "alias": [
        "-U"
      ],
      "tip": [
        "U: -U, --created",
        "Show the created timestamp field."
      ]
