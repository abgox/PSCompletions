{
  "meta": {
    "url": "https://fx.wtf",
    "description": [
      "Terminal JSON viewer"
    ]
  },
  "option": [
    {
      "name": "--comp",
      "tip": [
        "U: --comp <SHELL>",
        "Print completion script for the given shell"
      ],
      "next": [
        {
          "name": "bash",
          "tip": [
            "Bash completion"
          ]
        },
        {
          "name": "fish",
          "tip": [
            "Fish completion"
          ]
        },
        {
          "name": "powershell",
          "tip": [
            "PowerShell completion"
          ]
        },
        {
          "name": "zsh",
          "tip": [
            "Zsh completion"
          ]
        }
      ]
    },
    {
      "name": "--game-of-life",
      "tip": [
        "Play the game of life"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--no-inline",
      "tip": [
        "Disable inlining in output"
      ]
    },
    {
      "name": "--raw",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --raw",
        "Treat input as a raw string"
      ]
    },
    {
      "name": "--slurp",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --slurp",
        "Read all inputs into an array"
      ]
    },
    {
      "name": "--strict",
      "tip": [
        "Strict mode"
      ]
    },
    {
      "name": "--themes",
      "tip": [
        "Print available themes"
      ]
    },
    {
      "name": "--toml",
      "tip": [
        "Parse input as TOML"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Print version"
      ]
    },
    {
      "name": "--yaml",
      "tip": [
        "Parse input as YAML"
      ]
    }
  ]
}
