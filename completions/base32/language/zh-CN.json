{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "编码/解码数据并输出到标准输出。"
    ]
  },
  "option": [
    {
      "name": "--decode",
      "alias": [
        "-d",
        "-D"
      ],
      "tip": [
        "U: -d, -D, --decode",
        "解码数据"
      ]
    },
    {
      "name": "--ignore-garbage",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore-garbage",
        "解码时忽略非字母字符"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--wrap",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --wrap <COLS>",
        "在 COLS 个字符后换行（默认 76，0 表示禁用换行）"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
