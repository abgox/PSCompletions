{
  "meta": {
    "url": "https://chocolatey.org/",
    "description": [
      "Chocolatey software manager."
    ]
  },
  "next": [
    {
      "name": "cache",
      "tip": [
        "Manage the local HTTP caches used to store queries. (v2.1.0+)"
      ]
    },
    {
      "name": "config",
      "tip": [
        "Retrieve and configure config file settings."
      ]
    },
    {
      "name": "export",
      "tip": [
        "Exports list of currently installed packages."
      ]
    },
    {
      "name": "features",
      "alias": [
        "feature"
      ],
      "tip": [
        "U: feature|features",
        "View and configure choco features."
      ]
    },
    {
      "name": "help",
      "tip": [
        "Displays top level help information for choco."
      ]
    },
    {
      "name": "info",
      "tip": [
        "Retrieves package information.",
        "Shorthand for choco search pkgname --exact --verbose"
      ]
    },
    {
      "name": "install",
      "tip": [
        "Installs packages using configured sources."
      ]
    },
    {
      "name": "license",
      "tip": [
        "U: license [info]",
        "Show information about the current Chocolatey CLI license.",
        "(v2.5.0+)"
      ]
    },
    {
      "name": "list",
      "tip": [
        "Lists local packages."
      ]
    },
    {
      "name": "new",
      "tip": [
        "Creates template files for creating a new Chocolatey package."
      ]
    },
    {
      "name": "outdated",
      "tip": [
        "Retrieves information about packages that are outdated.",
        "Similar to upgrade all --noop"
      ]
    },
    {
      "name": "pack",
      "tip": [
        "Packages nuspec, scripts, and other Chocolatey package resources into a nupkg file."
      ]
    },
    {
      "name": "pin",
      "tip": [
        "Suppress upgrades for a package."
      ]
    },
    {
      "name": "push",
      "tip": [
        "Pushes a compiled nupkg to a source."
      ]
    },
    {
      "name": "rule",
      "tip": [
        "U: rule [list|get]",
        "View or list implemented package rules.",
        "(v2.3.0+)"
      ]
    },
    {
      "name": "search",
      "alias": [
        "find"
      ],
      "tip": [
        "U: search|find",
        "Searches remote packages."
      ]
    },
    {
      "name": "setapikey",
      "alias": [
        "apikey"
      ],
      "tip": [
        "U: apikey|setapikey",
        "Retrieves, saves or deletes an API key for a particular source."
      ]
    },
    {
      "name": "sources",
      "alias": [
        "source"
      ],
      "tip": [
        "U: source|sources",
        "View and configure default sources."
      ]
    },
    {
      "name": "support",
      "tip": [
        "Provides support information.",
        "(v2.5.0+)"
      ]
    },
    {
      "name": "templates",
      "alias": [
        "template"
      ],
      "tip": [
        "U: template|templates",
        "Get information about installed templates."
      ]
    },
    {
      "name": "uninstall",
      "tip": [
        "Uninstalls a package."
      ]
    },
    {
      "name": "unpackself",
      "tip": [
        "Re-installs Chocolatey base files."
      ]
    },
    {
      "name": "upgrade",
      "tip": [
        "Upgrades packages from various sources."
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: --version, -v",
        "Prints out the Chocolatey version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--cache-location",
      "alias": [
        "--cachelocation",
        "--cache",
        "-c"
      ],
      "tip": [
        "U: --cachelocation, --cache, -c, --cache-location=<path>",
        "Location for download cache."
      ]
    },
    {
      "name": "--confirm",
      "alias": [
        "--yes",
        "-y"
      ],
      "tip": [
        "U: -y, --yes, --confirm",
        "Confirm all prompts. Implies --accept-license."
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --debug",
        "Show debug messaging."
      ]
    },
    {
      "name": "--execution-timeout",
      "alias": [
        "--timeout"
      ],
      "tip": [
        "U: --timeout, --execution-timeout=<seconds>",
        "The time to allow a command to finish before timing out."
      ]
    },
    {
      "name": "--force",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --force",
        "Force the behavior."
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-?",
        "-h"
      ],
      "tip": [
        "U: --help, -h, -?",
        "Show the help."
      ],
      "next": [
        {
          "name": "--online",
          "tip": [
            "Open help for specified command in default browser application."
          ]
        }
      ]
    },
    {
      "name": "--ignore-http-cache"
    },
    {
      "name": "--limit-output",
      "alias": [
        "--limitoutput",
        "-r"
      ],
      "tip": [
        "U: -r, --limitoutput, -r, --limit-output",
        "Limit the output to essential information."
      ]
    },
    {
      "name": "--log-file"
    },
    {
      "name": "--no-progress",
      "tip": [
        "Do not show download progress percentages."
      ]
    },
    {
      "name": "--proxy"
    },
    {
      "name": "--proxy-password"
    },
    {
      "name": "--proxy-user"
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --verbose",
        "Show verbose messaging."
      ]
    }
  ]
}
