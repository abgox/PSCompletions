{
  "meta": {
    "url": "https://chocolatey.org/",
    "description": [
      "Chocolatey 软件管理器。"
    ]
  },
  "next": [
    {
      "name": "cache",
      "tip": [
        "管理用于存储查询的本地 HTTP 缓存(v2.1.0+)。"
      ]
    },
    {
      "name": "config",
      "tip": [
        "检索和配置配置文件设置。"
      ]
    },
    {
      "name": "export",
      "tip": [
        "导出当前安装的软件包的列表。"
      ]
    },
    {
      "name": "features",
      "alias": [
        "feature"
      ],
      "tip": [
        "U: feature|features",
        "查看和配置 choco 功能。"
      ]
    },
    {
      "name": "help",
      "tip": [
        "显示 choco 的顶级帮助信息。"
      ]
    },
    {
      "name": "info",
      "tip": [
        "检索包信息。",
        "它是 choco search pkgname --exact --verbose 的简写"
      ]
    },
    {
      "name": "install",
      "tip": [
        "使用配置的源安装软件包。"
      ]
    },
    {
      "name": "license",
      "tip": [
        "U: license [info]",
        "显示有关当前 Chocolatey CLI 许可证的信息。",
        "(v2.5.0+)"
      ]
    },
    {
      "name": "list",
      "tip": [
        "列出本地的包。"
      ]
    },
    {
      "name": "new",
      "tip": [
        "创建用于创建新的 Chocolatey 包的模板文件。"
      ]
    },
    {
      "name": "outdated",
      "tip": [
        "检索有关已过期的包的信息。",
        "类似于升级所有 --noop。"
      ]
    },
    {
      "name": "pack",
      "tip": [
        "将 nuspec、脚本和其他 Chocolatey 包资源打包到 nupkg 文件中。"
      ]
    },
    {
      "name": "pin",
      "tip": [
        "禁止包的升级。"
      ]
    },
    {
      "name": "push",
      "tip": [
        "将已编译的 nupkg 推送到源。"
      ]
    },
    {
      "name": "rule",
      "tip": [
        "U: rule [list|get]",
        "查看或列出已实现的包规则。",
        "(v2.3.0+)"
      ]
    },
    {
      "name": "search",
      "alias": [
        "find"
      ],
      "tip": [
        "U: search|find",
        "搜索软件包。"
      ]
    },
    {
      "name": "setapikey",
      "alias": [
        "apikey"
      ],
      "tip": [
        "U: apikey|setapikey",
        "检索、保存或删除特定源的 API 密钥。"
      ]
    },
    {
      "name": "sources",
      "alias": [
        "source"
      ],
      "tip": [
        "U: source|sources",
        "查看和配置默认源。"
      ]
    },
    {
      "name": "support",
      "tip": [
        "提供支持信息。",
        "(v2.5.0+)"
      ]
    },
    {
      "name": "templates",
      "alias": [
        "template"
      ],
      "tip": [
        "U: template|templates",
        "获取有关已安装模板的信息。"
      ]
    },
    {
      "name": "uninstall",
      "tip": [
        "卸载软件包。"
      ]
    },
    {
      "name": "unpackself",
      "tip": [
        "重新安装 Chocolatey 基本文件。"
      ]
    },
    {
      "name": "upgrade",
      "tip": [
        "从各种来源升级软件包。"
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: --version, -v",
        "打印出 Chocolatey 版本。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--cache-location",
      "alias": [
        "--cachelocation",
        "--cache",
        "-c"
      ],
      "tip": [
        "U: --cachelocation, --cache, -c, --cache-location=<path>",
        "下载缓存的位置。"
      ]
    },
    {
      "name": "--confirm",
      "alias": [
        "--yes",
        "-y"
      ],
      "tip": [
        "U: -y, --yes, --confirm",
        "确认所有提示。隐含 --accept-license。"
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --debug",
        "显示调试消息。"
      ]
    },
    {
      "name": "--execution-timeout",
      "alias": [
        "--timeout"
      ],
      "tip": [
        "U: --timeout, --execution-timeout=<seconds>",
        "允许命令完成的时间(秒)。"
      ]
    },
    {
      "name": "--force",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --force",
        "强制执行。"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-?",
        "-h"
      ],
      "tip": [
        "U: --help, -h, -?",
        "显示帮助信息。"
      ],
      "next": [
        {
          "name": "--online",
          "tip": [
            "在默认浏览器应用程序中打开指定命令的帮助。"
          ]
        }
      ]
    },
    {
      "name": "--ignore-http-cache"
    },
    {
      "name": "--limit-output",
      "alias": [
        "--limitoutput",
        "-r"
      ],
      "tip": [
        "U: -r, --limitoutput, -r, --limit-output",
        "将输出限制为基本信息。"
      ]
    },
    {
      "name": "--log-file"
    },
    {
      "name": "--no-progress",
      "tip": [
        "不显示下载进度百分比。"
      ]
    },
    {
      "name": "--proxy"
    },
    {
      "name": "--proxy-password"
    },
    {
      "name": "--proxy-user"
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --verbose",
        "显示详细消息。"
      ]
    }
  ]
}
