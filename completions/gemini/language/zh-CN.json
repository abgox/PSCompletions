      "Gemini CLI - Google 的 AI 编程助手。"
    ]
  },
  "root": [
    {
      "name": "extensions",
      "alias": [
        "extension"
      ],
      "tip": [
        "管理 Gemini CLI 扩展。"
      ],
      "next": [
        {
          "name": "config",
          "tip": [
            "U: config [name] [setting]",
            "配置扩展设置。"
          ]
        },
        {
          "name": "disable",
          "tip": [
            "U: disable [--scope] <name>",
            "禁用扩展。"
          ]
        },
        {
          "name": "enable",
          "tip": [
            "U: enable [--scope] <name>",
            "启用扩展。"
          ]
        },
        {
          "name": "install",
          "tip": [
            "U: install <source> [--auto-update] [--pre-release]",
            "从 git 仓库 URL 或本地路径安装扩展。"
          ]
