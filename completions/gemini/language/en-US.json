{
  "meta": {
    "url": "https://github.com/google-gemini/gemini-cli",
    "description": [
      "Gemini CLI - Google's AI-powered coding assistant in the terminal."
    ]
  },
  "next": [
    {
      "name": "extensions",
      "alias": [
        "extension"
      ],
      "tip": [
        "U: extension|extensions",
        "Manage Gemini CLI extensions."
      ],
      "next": [
        {
          "name": "config",
          "tip": [
            "U: config [name] [setting]",
            "Configure extension settings."
          ]
        },
        {
          "name": "disable",
          "tip": [
            "U: disable [--scope] <name>",
            "Disable an extension."
          ]
        },
        {
          "name": "enable",
          "tip": [
            "U: enable [--scope] <name>",
            "Enable an extension."
          ]
        },
        {
          "name": "install",
          "tip": [
            "U: install <source> [--auto-update] [--pre-release]",
            "Install an extension from a git repository URL or a local path."
          ]
        },
        {
          "name": "link",
          "tip": [
            "U: link <path>",
            "Link an extension from a local path."
          ]
        },
        {
          "name": "list",
          "tip": [
            "List installed extensions."
          ]
        },
        {
          "name": "new",
          "tip": [
            "U: new <path> [template]",
            "Create a new extension from a boilerplate example."
          ]
        },
        {
          "name": "uninstall",
          "tip": [
            "U: uninstall [names..]",
            "Uninstall one or more extensions."
          ]
        },
        {
          "name": "update",
          "tip": [
            "U: update [<name>] [--all]",
            "Update all extensions or a named extension to the latest version."
          ]
        },
        {
          "name": "validate",
          "tip": [
            "U: validate <path>",
            "Validate an extension from a local path."
          ]
        }
      ]
    },
    {
      "name": "gemma",
      "tip": [
        "Manage local Gemma model routing."
      ]
    },
    {
      "name": "hooks",
