    {
      "name": "--raw-output",
      "tip": [
        "Disable sanitization of model output.",
        "WARNING: This can be a security risk if the model output is untrusted."
      ]
    },
    {
      "name": "--resume",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --resume [SESSION]",
