      "next": [
        {
          "name": "json",
          "tip": [
            "JSON output."
          ]
        },
        {
          "name": "stream-json",
          "tip": [
            "Streaming JSON output."
          ]
        },
        {
          "name": "text",
          "tip": [
            "Plain text output."
          ]
        }
      ]
