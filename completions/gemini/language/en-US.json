      "tip": [
        "Manage MCP servers."
      ],
      "next": [
        {
          "name": "add",
          "tip": [
            "U: add <name> <commandOrUrl> [args...]",
            "Add an MCP server."
          ]
        },
        {
          "name": "disable",
          "tip": [
            "U: disable <name>",
            "Disable an MCP server."
          ]
        },
        {
          "name": "enable",
          "tip": [
            "U: enable <name>",
            "Enable an MCP server."
          ]
        },
        {
          "name": "list",
          "tip": [
            "List all configured MCP servers."
          ]
        },
        {
          "name": "remove",
          "tip": [
            "U: remove <name>",
            "Remove an MCP server."
          ]
        }
      ]
    },
    {
      "name": "skills",
      "alias": [
        "skill"
      ],
      "tip": [
        "U: skill|skills",
        "Manage agent skills."
      ],
      "next": [
        {
          "name": "disable",
          "tip": [
            "U: disable <name> [--scope]",
            "Disable an agent skill."
          ]
        },
        {
          "name": "enable",
          "tip": [
            "U: enable <name>",
            "Enable an agent skill."
          ]
        },
        {
          "name": "install",
          "tip": [
            "U: install <source> [--scope] [--path]",
            "Install an agent skill from a git repository URL or a local path."
          ]
        },
        {
          "name": "link",
          "tip": [
            "U: link <path>",
            "Link an agent skill from a local path."
          ]
        },
        {
          "name": "list",
          "tip": [
            "U: list [--all]",
            "List discovered agent skills."
          ]
        },
        {
          "name": "uninstall",
          "tip": [
            "U: uninstall <name> [--scope]",
            "Uninstall an agent skill by name."
          ]
        }
      ]
    }
