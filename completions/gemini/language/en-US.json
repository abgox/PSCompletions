        {
          "name": "auto_edit",
          "tip": [
            "Auto-approve edit tools."
          ]
        },
        {
          "name": "default",
          "tip": [
            "Prompt for approval."
          ]
        },
        {
          "name": "plan",
          "tip": [
            "Read-only mode."
          ]
        },
        {
          "name": "yolo",
          "tip": [
            "Auto-approve all tools."
          ]
        }
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
