{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "将每个文件（或未给出文件时的标准输入）写入标准输出，同时断开长行。",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--bytes",
      "alias": [
        "-b"
      ],
      "tip": [
        "使用字节而非列来计数",
        "（意味着换行符等控制字符不会被特殊处理）"
      ]
    },
    {
      "name": "--spaces",
      "alias": [
        "-s"
      ],
      "tip": [
        "在单词边界处断行而非硬截断"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --width <WIDTH>",
        "设置 WIDTH 为最大行宽而非 80"
      ],
      "next": 0
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
