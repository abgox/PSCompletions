{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "将每个文件写入标准输出，同时拆分长行。"
    ]
  },
  "option": [
    {
      "name": "--bytes",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bytes",
        "使用字节而非列来计数",
        "（意味着换行符等控制字符不会被特殊处理）"
      ]
    },
    {
      "name": "--spaces",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --spaces",
        "在单词边界处断行而非硬截断"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --width <WIDTH>",
        "设置 WIDTH 为最大行宽而非 80"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
