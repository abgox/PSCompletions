{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Encode/decode data and print to standard output."
    ]
  },
  "option": [
    {
      "name": "--decode",
      "alias": [
        "-d",
        "-D"
      ],
      "tip": [
        "U: -d, -D, --decode",
        "decode data"
      ]
    },
    {
      "name": "--ignore-garbage",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore-garbage",
        "when decoding, ignore non-alphabetic characters"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "--wrap",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --wrap <COLS>",
        "wrap encoded lines after COLS character (default 76, 0 to disable wrapping)"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
