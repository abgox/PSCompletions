{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Estimate file space usage."
    ]
  },
  "option": [
    {
      "name": "--all",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --all",
        "write counts for all files, not just directories"
      ]
    },
    {
      "name": "--apparent-size",
      "tip": [
        "print apparent sizes, rather than disk usage although the apparent size is usually smaller,",
        "it may be larger due to holes in ('sparse') files, internal fragmentation, indirect blocks, and the like"
      ]
    },
    {
      "name": "--block-size",
      "alias": [
        "-B"
      ],
      "tip": [
        "U: -B, --block-size <SIZE>",
        "scale sizes by SIZE before printing them;",
        "E: -B M   --- prints sizes in units of 1,048,576 bytes"
      ],
      "next": [
        {
          "name": "E",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "EB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "G",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "GB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "K",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "KB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "M",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "MB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "P",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "PB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "T",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "TB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "Y",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "YB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "Z",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "ZB",
          "tip": [
            "powers of 1000"
          ]
        }
      ]
    },
    {
      "name": "--bytes",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bytes",
        "equivalent to '--apparent-size --block-size=1'"
      ]
    },
    {
      "name": "--count-links",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --count-links",
        "count sizes many times if hard linked"
      ]
    },
    {
      "name": "--dereference",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --dereference",
        "follow all symbolic links"
      ]
    },
    {
      "name": "--dereference-args",
      "alias": [
        "-D",
        "-H"
      ],
      "tip": [
        "U: -D, -H, --dereference-args",
        "follow only symlinks that are listed on the command line"
      ]
    },
    {
      "name": "--exclude",
      "tip": [
        "U: --exclude <PATTERN>",
        "exclude files that match PATTERN"
      ],
      "next": 0
    },
    {
      "name": "--exclude-from",
      "alias": [
        "-X"
      ],
      "tip": [
        "U: -X, --exclude-from <FILE>",
        "exclude files that match any pattern in FILE"
      ],
      "next": 0
    },
    {
      "name": "--files0-from",
      "tip": [
        "summarize device usage of the NUL-terminated file names specified in file F;",
        "if F is -, then read names from standard input"
      ],
      "next": 0
    },
    {
      "name": "--human-readable",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --human-readable",
        "print sizes in human readable format (e.g., 1K 234M 2G)"
      ]
    },
    {
      "name": "--inodes",
      "tip": [
        "list inode usage information instead of block usage like --block-size=1K"
      ]
    },
    {
      "name": "--max-depth",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --max-depth <N>",
        "print the total for a directory (or file, with --all) only if it is N or fewer levels below the command line argument;",
        "--max-depth=0 is the same as --summarize"
      ],
      "next": [
        {
          "name": "0"
        },
        {
          "name": "1"
        }
      ]
    },
    {
      "name": "--no-dereference",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --no-dereference",
        "don't follow any symbolic links (this is the default)"
      ]
    },
    {
      "name": "--null",
      "alias": [
        "-0"
      ],
      "tip": [
        "U: -0, --null",
        "end each output line with 0 byte rather than newline"
      ]
    },
    {
      "name": "--one-file-system",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --one-file-system",
        "skip directories on different file systems"
      ]
    },
    {
      "name": "--separate-dirs",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --separate-dirs",
        "do not include size of subdirectories"
      ]
    },
    {
      "name": "--si",
      "tip": [
        "like -h, but use powers of 1000 not 1024"
      ]
    },
    {
      "name": "--summarize",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --summarize",
        "display only a total for each argument"
      ]
    },
    {
      "name": "--threshold",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --threshold <SIZE>",
        "exclude entries smaller than SIZE if positive, or entries greater than SIZE if negative"
      ],
      "next": 0
    },
    {
      "name": "--time",
      "tip": [
        "U: --time[=<WORD>...]",
        "show time of the last modification of any file in the directory, or any of its subdirectories.",
        "If WORD is given, show time as WORD instead of modification time: atime, access, use, ctime, status, birth or creation",
        "[possible values: atime, ctime, creation]"
      ],
      "next": [
        {
          "name": "atime"
        },
        {
          "name": "creation"
        },
        {
          "name": "ctime"
        }
      ]
    },
    {
      "name": "--time-style",
      "tip": [
        "U: --time-style <STYLE>",
        "show times using style STYLE: full-iso, long-iso, iso, +FORMAT FORMAT is interpreted like 'date'"
      ],
      "next": 0
    },
    {
      "name": "--total",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --total",
        "produce a grand total"
      ]
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --verbose",
        "verbose mode (option not present in GNU/Coreutils)"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "-k",
      "tip": [
        "like --block-size=1K"
      ]
    },
    {
      "name": "-m",
      "tip": [
        "like --block-size=1M"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "tip": [
        "Show the help."
      ]
    }
  ]
}
