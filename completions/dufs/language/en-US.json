{
  "meta": {
    "url": "https://github.com/sigoden/dufs",
    "description": [
      "Distinctive utility file server."
    ]
  },
  "option": [
    {
      "name": "--allow-all",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --allow-all",
        "Allow all operations."
      ]
    },
    {
      "name": "--allow-archive",
      "tip": [
        "Allow download folders as archive file."
      ]
    },
    {
      "name": "--allow-delete",
      "tip": [
        "Allow delete files/folders."
      ]
    },
    {
      "name": "--allow-hash",
      "tip": [
        "Allow ?hash query to get file sha256 hash."
      ]
    },
    {
      "name": "--allow-search",
      "tip": [
        "Allow search files/folders."
      ]
    },
    {
      "name": "--allow-symlink",
      "tip": [
        "Allow symlink to files/folders outside root directory."
      ]
    },
    {
      "name": "--allow-upload",
      "tip": [
        "Allow upload files/folders."
      ]
    },
    {
      "name": "--assets",
      "tip": [
        "U: --assets <path>",
        "Set the path to the assets directory for overriding the built-in assets."
      ],
      "next": 0
    },
    {
      "name": "--auth",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --auth <rules>",
        "Add auth roles.",
        "E: --auth user:pass@/dir1:rw,/dir2"
      ],
      "next": 0
    },
    {
      "name": "--bind",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bind <addrs>",
        "Specify bind address or unix socket."
      ],
      "next": 0
    },
    {
      "name": "--completions",
      "tip": [
        "U: --completions <shell>",
        "Print shell completion script for <shell>."
      ],
      "next": [
        {
          "name": "bash"
        },
        {
          "name": "elvish"
        },
        {
          "name": "fish"
        },
        {
          "name": "powershell"
        },
        {
          "name": "zsh"
        }
      ]
    },
    {
      "name": "--compress",
      "tip": [
        "U: --compress <level>",
        "Set zip compress level."
      ],
      "next": [
        {
          "name": "high"
        },
        {
          "name": "low"
        },
        {
          "name": "medium"
        },
        {
          "name": "none"
        }
      ]
    },
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config <file>",
        "Specify configuration file."
      ],
      "next": 0
    },
    {
      "name": "--enable-cors",
      "tip": [
        "Enable CORS, sets Access-Control-Allow-Origin: *."
      ]
    },
    {
      "name": "--hidden",
      "tip": [
        "U: --hidden <value>",
        "Hide paths from directory listings.",
        "E: --hidden tmp,*.log,*.lock"
      ],
      "next": 0
    },
    {
      "name": "--log-file",
      "tip": [
        "U: --log-file <file>",
        "Specify the file to save logs to, other than stdout/stderr."
      ],
      "next": 0
    },
    {
      "name": "--log-format",
      "tip": [
        "U: --log-format <format>",
        "Customize http log format."
      ],
      "next": 0
    },
    {
      "name": "--path-prefix",
      "tip": [
        "U: --path-prefix <path>",
        "Specify a path prefix."
      ],
      "next": 0
    },
    {
      "name": "--port",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --port <port>",
        "Specify port to listen on.",
        "E: --port 8080"
      ],
      "next": 0
    },
    {
      "name": "--render-index",
      "tip": [
        "Serve index.html when requesting a directory, returns 404 if not found index.html."
      ]
    },
    {
      "name": "--render-spa",
      "tip": [
        "Serve SPA (Single Page Application)."
      ]
    },
    {
      "name": "--render-try-index",
      "tip": [
        "Serve index.html when requesting a directory, returns directory listing if not found index.html."
      ]
    },
    {
      "name": "--tls-cert",
      "tip": [
        "U: --tls-cert <path>",
        "Path to an SSL/TLS certificate to serve with HTTPS."
      ],
      "next": 0
    },
    {
      "name": "--tls-key",
      "tip": [
        "U: --tls-key <path>",
        "Path to the SSL/TLS certificate's private key."
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help."
      ]
    }
  ]
}
