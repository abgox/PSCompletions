{
  "meta": {
    "url": "https://github.com/sigoden/dufs",
    "description": [
      "独特的实用文件服务器。"
    ]
  },
  "option": [
    {
      "name": "--allow-all",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --allow-all",
        "允许所有操作。"
      ]
    },
    {
      "name": "--allow-archive",
      "tip": [
        "允许将文件夹下载为归档文件。"
      ]
    },
    {
      "name": "--allow-delete",
      "tip": [
        "允许删除文件/文件夹。"
      ]
    },
    {
      "name": "--allow-hash",
      "tip": [
        "允许通过 ?hash 查询获取文件的 sha256 哈希值。"
      ]
    },
    {
      "name": "--allow-search",
      "tip": [
        "允许搜索文件/文件夹。"
      ]
    },
    {
      "name": "--allow-symlink",
      "tip": [
        "允许创建指向根目录外文件/文件夹的符号链接。"
      ]
    },
    {
      "name": "--allow-upload",
      "tip": [
        "允许上传文件/文件夹。"
      ]
    },
    {
      "name": "--assets",
      "tip": [
        "U: --assets <path>",
        "设置 assets 目录路径以覆盖内置 assets。"
      ],
      "next": 0
    },
    {
      "name": "--auth",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --auth <rules>",
        "添加认证角色。",
        "E: --auth user:pass@/dir1:rw,/dir2"
      ],
      "next": 0
    },
    {
      "name": "--bind",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bind <addrs>",
        "指定绑定地址或 unix socket。"
      ],
      "next": 0
    },
    {
      "name": "--completions",
      "tip": [
        "U: --completions <shell>",
        "打印指定 shell 的补全脚本。"
      ],
      "next": [
        {
          "name": "bash"
        },
        {
          "name": "elvish"
        },
        {
          "name": "fish"
        },
        {
          "name": "powershell"
        },
        {
          "name": "zsh"
        }
      ]
    },
    {
      "name": "--compress",
      "tip": [
        "U: --compress <level>",
        "设置 zip 压缩级别。"
      ],
      "next": [
        {
          "name": "high"
        },
        {
          "name": "low"
        },
        {
          "name": "medium"
        },
        {
          "name": "none"
        }
      ]
    },
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config <file>",
        "指定配置文件。"
      ],
      "next": 0
    },
    {
      "name": "--enable-cors",
      "tip": [
        "启用 CORS，设置 Access-Control-Allow-Origin: *。"
      ]
    },
    {
      "name": "--hidden",
      "tip": [
        "U: --hidden <value>",
        "从目录列表中隐藏路径。",
        "E: --hidden tmp,*.log,*.lock"
      ],
      "next": 0
    },
    {
      "name": "--log-file",
      "tip": [
        "U: --log-file <file>",
        "指定日志保存文件，而非 stdout/stderr。"
      ],
      "next": 0
    },
    {
      "name": "--log-format",
      "tip": [
        "U: --log-format <format>",
        "自定义 http 日志格式。"
      ],
      "next": 0
    },
    {
      "name": "--path-prefix",
      "tip": [
        "U: --path-prefix <path>",
        "指定路径前缀。"
      ],
      "next": 0
    },
    {
      "name": "--port",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --port <port>",
        "指定监听端口。",
        "E: --port 8080"
      ],
      "next": 0
    },
    {
      "name": "--render-index",
      "tip": [
        "请求目录时提供 index.html，如果未找到 index.html 则返回 404。"
      ]
    },
    {
      "name": "--render-spa",
      "tip": [
        "提供 SPA（单页应用程序）服务。"
      ]
    },
    {
      "name": "--render-try-index",
      "tip": [
        "请求目录时提供 index.html，如果未找到 index.html 则返回目录列表。"
      ]
    },
    {
      "name": "--tls-cert",
      "tip": [
        "U: --tls-cert <path>",
        "用于 HTTPS 的 SSL/TLS 证书路径。"
      ],
      "next": 0
    },
    {
      "name": "--tls-key",
      "tip": [
        "U: --tls-key <path>",
        "SSL/TLS 证书私钥路径。"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助。"
      ]
    }
  ]
}
