{
  "meta": {
    "url": "https://github.com/remy/nodemon",
    "description": [
      "Monitor for changes and automatically restart Node.js server."
    ]
  },
  "option": [
    {
      "name": "--config",
      "tip": [
        "U: --config <file>",
        "Alternate nodemon.json config file to use"
      ],
      "next": 0
    },
    {
      "name": "--cwd",
      "tip": [
        "U: --cwd <dir>",
        "Change into <dir> before running the script"
      ],
      "next": 0
    },
    {
      "name": "--delay",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --delay <n>",
        "Debounce restart for \"n\" seconds"
      ],
      "next": 0
    },
    {
      "name": "--dump",
      "tip": [
        "Print full debug configuration"
      ]
    },
    {
      "name": "--exec",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --exec <app>",
        "Execute script with \"app\", ie. -x \"python -v\""
      ],
      "next": 0
    },
    {
      "name": "--exitcrash",
      "tip": [
        "Exit on crash, allows nodemon to work with other watchers"
      ]
    },
    {
      "name": "--ext",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --ext <ext>",
        "Extensions to look for, ie. \"js,pug,hbs\""
      ],
      "next": 0
    },
    {
      "name": "--ignore",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore <path>",
        "Ignore specific files or directories"
      ],
      "next": 0
    },
    {
      "name": "--legacy-watch",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --legacy-watch",
        "Use polling to watch for changes (typically needed when watching over a network/Docker)"
      ]
    },
    {
      "name": "--no-colors",
      "tip": [
        "Disable color output"
      ]
    },
    {
      "name": "--no-stdin",
      "alias": [
        "-I"
      ],
      "tip": [
        "U: -I, --no-stdin",
        "Nodemon passes stdin directly to child process"
      ]
    },
    {
      "name": "--no-update-notifier",
      "tip": [
        "Opt-out of update version check"
      ]
    },
    {
      "name": "--on-change-only",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --on-change-only",
        "Execute script on change only, not startup"
      ]
    },
    {
      "name": "--polling-interval",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --polling-interval <ms>",
        "Combined with -L, milliseconds to poll for (default 100)"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "Minimise nodemon messages to start/stop only"
      ]
    },
    {
      "name": "--signal",
      "tip": [
        "U: --signal <signal>",
        "Use specified kill signal instead of default (ex. SIGTERM)"
      ],
      "next": 0
    },
    {
      "name": "--spawn",
      "tip": [
        "Force nodemon to use spawn (over fork) [node only]"
      ]
    },
    {
      "name": "--verbose",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --verbose",
        "Show detail on what is causing restarts"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Show the current nodemon version"
      ]
    },
    {
      "name": "--watch",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --watch <path>",
        "Watch directory \"path\" or files. Use once for each directory or file to watch"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help"
      ]
    }
  ]
}
