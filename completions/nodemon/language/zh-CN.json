{
  "meta": {
    "url": "https://github.com/remy/nodemon",
    "description": [
      "监控文件变化并自动重启 Node.js 服务器。"
    ]
  },
  "option": [
    {
      "name": "--config",
      "tip": [
        "U: --config <file>",
        "使用备用 nodemon.json 配置文件"
      ],
      "next": 0
    },
    {
      "name": "--cwd",
      "tip": [
        "U: --cwd <dir>",
        "在运行脚本之前切换到 <dir> 目录"
      ],
      "next": 0
    },
    {
      "name": "--delay",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --delay <n>",
        "将重启防抖 \"n\" 秒"
      ],
      "next": 0
    },
    {
      "name": "--dump",
      "tip": [
        "打印完整的调试配置"
      ]
    },
    {
      "name": "--exec",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --exec <app>",
        "使用 \"app\" 执行脚本，例如 -x \"python -v\""
      ],
      "next": 0
    },
    {
      "name": "--exitcrash",
      "tip": [
        "崩溃时退出，允许 nodemon 与其他监视器一起工作"
      ]
    },
    {
      "name": "--ext",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --ext <ext>",
        "要监视的扩展名，例如 \"js,pug,hbs\""
      ],
      "next": 0
    },
    {
      "name": "--ignore",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore <path>",
        "忽略特定文件或目录"
      ],
      "next": 0
    },
    {
      "name": "--legacy-watch",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --legacy-watch",
        "使用轮询监视更改（通常在网络/Docker 上监视时需要）"
      ]
    },
    {
      "name": "--no-colors",
      "tip": [
        "禁用彩色输出"
      ]
    },
    {
      "name": "--no-stdin",
      "alias": [
        "-I"
      ],
      "tip": [
        "U: -I, --no-stdin",
        "nodemon 将标准输入直接传递给子进程"
      ]
    },
    {
      "name": "--no-update-notifier",
      "tip": [
        "退出更新版本检查"
      ]
    },
    {
      "name": "--on-change-only",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --on-change-only",
        "仅在更改时执行脚本，不在启动时执行"
      ]
    },
    {
      "name": "--polling-interval",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --polling-interval <ms>",
        "与 -L 配合使用，轮询间隔毫秒数（默认 100）"
      ],
      "next": 0
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "最小化 nodemon 消息，仅显示启动/停止"
      ]
    },
    {
      "name": "--signal",
      "tip": [
        "U: --signal <signal>",
        "使用指定的终止信号代替默认值（例如 SIGTERM）"
      ],
      "next": 0
    },
    {
      "name": "--spawn",
      "tip": [
        "强制 nodemon 使用 spawn（而不是 fork）[仅限 node]"
      ]
    },
    {
      "name": "--verbose",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --verbose",
        "显示导致重启的详细信息"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "显示当前 nodemon 版本"
      ]
    },
    {
      "name": "--watch",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --watch <path>",
        "监视目录 \"path\" 或文件。每个目录或文件使用一次"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息"
      ]
    }
  ]
}
