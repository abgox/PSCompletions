{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "从文件名中移除最后一个组成部分。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "以 NUL 而不是换行符分隔输出"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
