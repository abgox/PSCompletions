{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "去除文件名的最后一个组件。"
    ]
  },
  "option": [
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --zero",
        "以 NUL 而不是换行符分隔输出"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
