{
  "meta": {
    "url": "https://github.com/uutils/coreutils",
    "description": [
      "Strip last component from file name.",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "Show the version."
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "separate output with NUL rather than newline"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "Show the help."
      ]
    }
  ]
}
