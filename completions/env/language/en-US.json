{
  "meta": {
    "url": "https://github.com/uutils/coreutils",
    "description": [
      "Set each NAME to VALUE in the environment and run COMMAND.",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--argv0",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --argv0 <a>",
        "Override the zeroth argument passed to the command being executed.",
        "Without this option a default value of `command` is used."
      ],
      "next": 0
    },
    {
      "name": "--chdir",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --chdir <DIR>",
        "change working directory to DIR"
      ],
      "next": 0
    },
    {
      "name": "--debug",
      "alias": [
        "-v"
      ],
      "tip": [
        "print verbose information for each processing step"
      ]
    },
    {
      "name": "--file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --file <FILE>",
        "read and set variables from a \".env\"-style configuration file (prior to any unset and/or set)"
      ],
      "next": 0
    },
    {
      "name": "--ignore-environment",
      "alias": [
        "-i"
      ],
      "tip": [
        "start with an empty environment"
      ]
    },
    {
      "name": "--null",
      "alias": [
        "-0"
      ],
      "tip": [
        "end each output line with a 0 byte rather than a newline (only valid when printing the environment)"
      ]
    },
    {
      "name": "--split-string",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --split-string <S>",
        "process and split S into separate arguments;",
        "used to pass multiple arguments on shebang lines"
      ],
      "next": 0
    },
    {
      "name": "--unset",
      "alias": [
        "-u"
      ],
      "tip": [
        "U: -u, --unset <NAME>",
        "remove variable from the environment"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "Show the version."
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "Show the help."
      ]
    }
  ]
}
