{
  "meta": {
    "url": "https://github.com/chmln/sd",
    "description": [
      "An intuitive find & replace CLI",
      "sed alternative"
    ]
  },
  "option": [
    {
      "name": "--across",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --across",
        "Process each input as a whole rather than line by line"
      ]
    },
    {
      "name": "--fixed-strings",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --fixed-strings",
        "Treat FIND and REPLACE_WITH args as literal strings"
      ]
    },
    {
      "name": "--flags",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --flags <FLAGS>",
        "Regex flags (c=case-sensitive, e=no multiline, i=case-insensitive, m=multiline, s=dotall, w=word)"
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--max-replacements",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --max-replacements <LIMIT>",
        "Limit the number of replacements per file (0 = unlimited)"
      ],
      "next": 0
    },
    {
      "name": "--preview",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --preview",
        "Display changes in a human reviewable format"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version"
      ]
    }
  ]
}
