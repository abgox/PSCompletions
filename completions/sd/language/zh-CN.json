{
  "meta": {
    "url": "https://github.com/chmln/sd",
    "description": [
      "直觉化的查找与替换 CLI",
      "sed 替代工具"
    ]
  },
  "option": [
    {
      "name": "--across",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --across",
        "将每个输入作为整体处理，而非逐行处理"
      ]
    },
    {
      "name": "--fixed-strings",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --fixed-strings",
        "将 FIND 和 REPLACE_WITH 参数作为字面字符串处理"
      ]
    },
    {
      "name": "--flags",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --flags <FLAGS>",
        "正则标志（c=区分大小写, e=非多行, i=不区分大小写, m=多行, s=点匹配换行, w=单词）"
      ],
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息"
      ]
    },
    {
      "name": "--max-replacements",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --max-replacements <LIMIT>",
        "限制每个文件的替换次数（0 = 不限）"
      ],
      "next": 0
    },
    {
      "name": "--preview",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --preview",
        "以人类可审查的格式显示更改"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本号"
      ]
    }
  ]
}
