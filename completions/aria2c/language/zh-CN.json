    {
      "name": "--http-passwd",
      "tip": [
        "设置 HTTP 密码。影响所有 URL"
      ]
    },
    {
      "name": "--http-proxy",
      "tip": [
        "U: --http-proxy <PROXY>",
        "使用 HTTP 代理服务器"
      ],
      "next": 0
    },
    {
      "name": "--http-proxy-passwd",
      "tip": [
        "U: --http-proxy-passwd <PASSWD>",
        "设置 --http-proxy 的密码"
      ],
      "next": 0
    },
    {
      "name": "--http-proxy-user",
      "tip": [
        "U: --http-proxy-user <USER>",
        "设置 --http-proxy 的用户名"
      ],
      "next": 0
    },
    {
      "name": "--http-user",
      "tip": [
        "设置 HTTP 用户名。影响所有 URL"
      ]
    },
    {
