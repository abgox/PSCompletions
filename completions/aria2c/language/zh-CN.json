{
  "meta": {
    "url": "https://aria2.github.io",
    "description": [
      "轻量级多协议多源下载工具。"
    ]
  },
  "option": [
    {
      "name": "--all-proxy",
      "tip": [
        "U: --all-proxy <PROXY>",
        "对所有协议使用代理服务器"
      ],
      "next": 0
    },
    {
      "name": "--all-proxy-passwd",
      "tip": [
        "U: --all-proxy-passwd <PASSWD>",
        "设置 --all-proxy 的密码"
      ],
      "next": 0
    },
    {
      "name": "--all-proxy-user",
      "tip": [
        "U: --all-proxy-user <USER>",
        "设置 --all-proxy 的用户名"
      ],
      "next": 0
    },
    {
      "name": "--allow-overwrite",
      "tip": [
        "如果对应的控制文件不存在则从头重新下载",
        "Default: false"
      ]
    },
    {
      "name": "--allow-piece-length-change",
      "tip": [
        "恢复下载时允许分片长度变化",
        "Default: false"
      ]
    },
    {
      "name": "--always-resume",
      "tip": [
        "始终恢复下载。如果为 true，aria2 始终尝试恢复",
        "Default: true"
      ]
    },
    {
      "name": "--async-dns",
      "tip": [
        "启用异步 DNS",
        "Default: true"
      ]
    },
    {
      "name": "--async-dns-server",
      "tip": [
        "U: --async-dns-server <IPADDRESS>",
        "异步 DNS 解析器使用的 DNS 服务器地址的逗号分隔列表"
      ],
      "next": 0
    },
    {
      "name": "--auto-file-renaming",
      "tip": [
        "如果同名文件已存在则自动重命名",
        "Default: true"
      ]
    },
    {
      "name": "--auto-save-interval",
      "tip": [
        "U: --auto-save-interval <SEC>",
        "每隔 SEC 秒保存一次控制文件 (*.aria2)",
        "Default: 60"
      ],
      "next": 0
    },
    {
      "name": "--bt-detach-seed-only",
      "tip": [
        "在计算并发活动下载数时排除仅做种的下载",
        "Default: false"
      ]
    },
    {
      "name": "--bt-enable-hook-after-hash-check",
      "tip": [
        "允许在 BitTorrent 下载的哈希检查后调用钩子命令",
        "Default: true"
      ]
    },
    {
      "name": "--bt-enable-lpd",
      "tip": [
        "启用本地 Peer 发现",
        "Default: false"
      ]
    },
    {
      "name": "--bt-exclude-tracker",
      "tip": [
        "U: --bt-exclude-tracker <URI>",
        "要移除的 BitTorrent tracker 公告 URI 的逗号分隔列表"
      ],
      "next": 0
    },
    {
      "name": "--bt-external-ip",
      "tip": [
        "U: --bt-external-ip <IPADDRESS>",
        "指定在 BitTorrent 下载和 DHT 中使用的外部 IP 地址"
      ],
      "next": 0
    },
    {
      "name": "--bt-force-encryption",
      "tip": [
        "要求 BitTorrent 消息负载使用 arc4 加密",
        "Default: false"
      ]
    },
    {
      "name": "--bt-hash-check-seed",
      "tip": [
        "哈希检查且文件完整后继续做种",
        "Default: true"
      ]
    },
    {
      "name": "--bt-load-saved-metadata",
      "tip": [
        "从 DHT 获取 torrent 元数据前先尝试读取 --bt-save-metadata 保存的文件",
        "Default: false"
      ]
    },
    {
      "name": "--bt-lpd-interface",
      "tip": [
        "U: --bt-lpd-interface <INTERFACE>",
        "为本地 Peer 发现使用指定接口"
      ],
      "next": 0
    },
    {
      "name": "--bt-max-open-files",
      "tip": [
        "U: --bt-max-open-files <NUM>",
        "指定多文件 BitTorrent/Metalink 下载中全局最大打开文件数",
        "Default: 100"
      ],
      "next": 0
    },
    {
      "name": "--bt-max-peers",
      "tip": [
        "U: --bt-max-peers <NUM>",
        "指定每个种子的最大 peer 数。0 表示不限制",
        "Default: 55"
      ],
      "next": 0
    },
    {
      "name": "--bt-metadata-only",
      "tip": [
        "仅下载元数据。仅在使用 BitTorrent Magnet URI 时有效",
        "Default: false"
      ]
    },
    {
      "name": "--bt-min-crypto-level",
      "tip": [
        "U: --bt-min-crypto-level <plain|arc4>",
        "设置加密方法的最低级别",
        "Default: plain"
      ],
      "next": [
        {
          "name": "arc4",
          "tip": [
            "ARC4 加密"
          ]
        },
        {
          "name": "plain",
          "tip": [
            "普通加密"
          ]
        }
      ]
    },
    {
      "name": "--bt-prioritize-piece",
      "tip": [
        "U: --bt-prioritize-piece <head[=SIZE],tail[=SIZE]>",
        "尝试优先下载每个文件的首尾分片"
      ],
      "next": 0
    },
    {
      "name": "--bt-remove-unselected-file",
      "tip": [
        "BitTorrent 下载完成时删除未选择的文件",
        "Default: false"
      ]
    },
    {
      "name": "--bt-request-peer-speed-limit",
      "tip": [
        "U: --bt-request-peer-speed-limit <SPEED>",
        "如果整体下载速度低于 SPEED，aria2 会增加 peer 数量",
        "Default: 50K"
      ],
      "next": 0
    },
    {
      "name": "--bt-require-crypto",
      "tip": [
        "如果为 true，aria2 不接受传统 BitTorrent 握手",
        "Default: false"
      ]
    },
    {
      "name": "--bt-save-metadata",
      "tip": [
        "将元数据保存为 .torrent 文件。仅在使用 BitTorrent Magnet URI 时有效",
        "Default: false"
      ]
    },
    {
      "name": "--bt-seed-unverified",
      "tip": [
        "不验证分片哈希即对先前下载的文件进行做种",
        "Default: false"
      ]
    },
    {
      "name": "--bt-stop-timeout",
      "tip": [
        "U: --bt-stop-timeout <SEC>",
        "如果下载速度在连续 SEC 秒内为 0 则停止 BitTorrent 下载",
        "Default: 0"
      ],
      "next": 0
    },
    {
      "name": "--bt-tracker",
      "tip": [
        "U: --bt-tracker <URI>",
        "额外 BitTorrent tracker 公告 URI 的逗号分隔列表"
      ],
      "next": 0
    },
    {
      "name": "--bt-tracker-connect-timeout",
      "tip": [
        "U: --bt-tracker-connect-timeout <SEC>",
        "设置连接 tracker 的超时时间 (秒)",
        "Default: 60"
      ],
      "next": 0
    },
    {
      "name": "--bt-tracker-interval",
      "tip": [
        "U: --bt-tracker-interval <SEC>",
        "设置 tracker 请求之间的间隔 (秒)",
        "Default: 0"
      ],
      "next": 0
    },
    {
      "name": "--bt-tracker-timeout",
      "tip": [
        "U: --bt-tracker-timeout <SEC>",
        "设置超时时间 (秒)",
        "Default: 60"
      ],
      "next": 0
    },
    {
      "name": "--ca-certificate",
      "tip": [
        "U: --ca-certificate <FILE>",
        "使用 FILE 中的证书颁发机构来验证对等方"
      ],
      "next": 0
    },
    {
      "name": "--certificate",
      "tip": [
        "U: --certificate <FILE>",
        "使用 FILE 中的客户端证书"
      ],
      "next": 0
    },
    {
      "name": "--check-certificate",
      "tip": [
        "使用 --ca-certificate 指定的证书验证对等方",
        "Default: true"
      ]
    },
    {
      "name": "--check-integrity",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --check-integrity",
        "通过验证分片哈希或整个文件的哈希来检查文件完整性",
        "Default: false"
      ]
    },
    {
      "name": "--checksum",
      "tip": [
        "U: --checksum <TYPE=DIGEST>",
        "设置校验和。TYPE 是哈希类型，DIGEST 是十六进制摘要"
      ],
      "next": 0
    },
    {
      "name": "--conditional-get",
      "tip": [
        "仅在本地文件比远程文件旧时下载",
        "Default: false"
      ]
    },
    {
      "name": "--conf-path",
      "tip": [
        "U: --conf-path <PATH>",
        "将配置文件路径更改为 PATH"
      ],
      "next": 0
    },
    {
      "name": "--connect-timeout",
      "tip": [
        "U: --connect-timeout <SEC>",
        "设置连接超时时间 (秒)",
        "Default: 60"
      ],
      "next": 0
    },
    {
      "name": "--console-log-level",
      "tip": [
        "U: --console-log-level <LEVEL>",
        "设置输出到控制台的日志级别",
        "Default: notice"
      ],
      "next": [
        {
          "name": "debug",
          "tip": [
            "调试级别"
          ]
        },
        {
          "name": "error",
          "tip": [
            "错误级别"
          ]
        },
        {
          "name": "info",
          "tip": [
            "信息级别"
          ]
        },
        {
          "name": "notice",
          "tip": [
            "通知级别"
          ]
        },
        {
          "name": "warn",
          "tip": [
            "警告级别"
          ]
        }
      ]
    },
    {
      "name": "--content-disposition-default-utf8",
      "tip": [
        "将 Content-Disposition 头中的引号字符串作为 UTF-8 而非 ISO-8859-1 处理",
        "Default: false"
      ]
    },
    {
      "name": "--continue",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --continue",
        "继续下载部分下载的文件",
        "Default: false"
      ]
    },
    {
      "name": "--daemon",
      "alias": [
        "-D"
      ],
      "tip": [
        "U: -D, --daemon",
        "以守护进程方式运行",
        "Default: false"
      ]
    },
    {
      "name": "--deferred-input",
      "tip": [
        "如果为 true，aria2 启动时不会读取所有 URI，而是逐个读取",
        "Default: false"
      ]
    },
    {
      "name": "--dht-entry-point",
      "tip": [
        "U: --dht-entry-point <HOST:PORT>",
        "设置 IPv4 DHT 网络的入口点"
      ],
      "next": 0
    },
    {
      "name": "--dht-entry-point6",
      "tip": [
        "U: --dht-entry-point6 <HOST:PORT>",
        "设置 IPv6 DHT 网络的入口点"
      ],
      "next": 0
    },
    {
      "name": "--dht-file-path",
      "tip": [
        "U: --dht-file-path <PATH>",
        "将 IPv4 DHT 路由表文件更改为 PATH"
      ],
      "next": 0
    },
    {
      "name": "--dht-file-path6",
      "tip": [
        "U: --dht-file-path6 <PATH>",
        "将 IPv6 DHT 路由表文件更改为 PATH"
      ],
      "next": 0
    },
    {
      "name": "--dht-listen-addr6",
      "tip": [
        "U: --dht-listen-addr6 <ADDR>",
        "指定 IPv6 DHT 绑定套接字的地址"
      ],
      "next": 0
    },
    {
      "name": "--dht-listen-port",
      "tip": [
        "U: --dht-listen-port <PORT...>",
        "设置 DHT (IPv4, IPv6) 和 UDP tracker 使用的 UDP 监听端口",
        "Default: 6881-6999"
      ],
      "next": 0
    },
    {
      "name": "--dht-message-timeout",
      "tip": [
        "U: --dht-message-timeout <SEC>",
        "设置超时时间 (秒)",
        "Default: 10"
      ],
      "next": 0
    },
    {
      "name": "--dir",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --dir <DIR>",
        "存储下载文件的目录"
      ],
      "next": 0
    },
    {
      "name": "--disable-ipv6",
      "tip": [
        "禁用 IPv6",
        "Default: false"
      ]
    },
    {
      "name": "--disk-cache",
      "tip": [
        "U: --disk-cache <SIZE>",
        "启用磁盘缓存。SIZE 可以包含 K 或 M",
        "Default: 16M"
      ],
      "next": 0
    },
    {
      "name": "--download-result",
      "tip": [
        "U: --download-result <OPT>",
        "更改\"下载结果\"的显示格式",
        "Default: default"
      ],
      "next": [
        {
          "name": "default",
          "tip": [
            "打印 GID、状态、平均下载速度和路径/URI"
          ]
        },
        {
          "name": "full",
          "tip": [
            "打印 GID、状态、速度、进度百分比和路径/URI"
          ]
        },
        {
          "name": "hide",
          "tip": [
            "隐藏下载结果"
          ]
        }
      ]
    },
    {
      "name": "--dry-run",
      "tip": [
        "如果为 true，aria2 仅检查远程文件是否可用而不下载数据",
        "Default: false"
      ]
    },
    {
      "name": "--dscp",
      "tip": [
        "U: --dscp <DSCP>",
        "设置 BitTorrent 流量出站 IP 包中的 DSCP 值 (用于 QoS)",
        "Default: 0"
      ],
      "next": 0
    },
    {
      "name": "--enable-async-dns6",
      "tip": [
        "在异步 DNS 解析器中启用 IPv6 名称解析",
        "(已弃用)"
      ]
    },
    {
      "name": "--enable-color",
      "tip": [
        "为终端启用彩色输出",
        "Default: true"
      ]
    },
    {
      "name": "--enable-dht",
      "tip": [
        "启用 IPv4 DHT 功能。同时启用 UDP tracker 支持",
        "Default: true"
      ]
    },
    {
      "name": "--enable-dht6",
      "tip": [
        "启用 IPv6 DHT 功能",
        "Default: false"
      ]
    },
    {
      "name": "--enable-http-keep-alive",
      "tip": [
        "启用 HTTP/1.1 持久连接",
        "Default: true"
      ]
    },
    {
      "name": "--enable-http-pipelining",
      "tip": [
        "启用 HTTP/1.1 管道化",
        "Default: false"
      ]
    },
    {
      "name": "--enable-mmap",
      "tip": [
        "将文件映射到内存",
        "Default: false"
      ]
    },
    {
      "name": "--enable-peer-exchange",
      "tip": [
        "启用 Peer Exchange 扩展",
        "Default: true"
      ]
    },
    {
      "name": "--enable-rpc",
      "tip": [
        "启用 JSON-RPC/XML-RPC 服务器",
        "Default: false"
      ]
    },
    {
      "name": "--event-poll",
      "tip": [
        "U: --event-poll <POLL>",
        "指定事件轮询方法",
        "Default: select"
      ],
      "next": [
        {
          "name": "select",
          "tip": [
            "使用 select() 进行轮询"
          ]
        }
      ]
    },
    {
      "name": "--file-allocation",
      "tip": [
        "U: --file-allocation <METHOD>",
        "指定文件分配方式",
        "Default: prealloc"
      ],
      "next": [
        {
          "name": "falloc",
          "tip": [
            "几乎立即分配大文件 (ext4, btrfs, xfs, NTFS)"
          ]
        },
        {
          "name": "none",
          "tip": [
            "不预分配文件空间"
          ]
        },
        {
          "name": "prealloc",
          "tip": [
            "下载开始前预分配文件空间"
          ]
        },
        {
          "name": "trunc",
          "tip": [
            "使用 ftruncate() 将文件截断到指定长度"
          ]
        }
      ]
    },
    {
      "name": "--follow-metalink",
      "tip": [
        "U: --follow-metalink <VALUE>",
        "下载 metalink 文件时解析并下载其内容",
        "Default: true"
      ],
      "next": [
        {
          "name": "false",
          "tip": [
            "将 metalink 文件下载到磁盘但不解析"
          ]
        },
        {
          "name": "mem",
          "tip": [
            "将 metalink 保留在内存中而不写入磁盘"
          ]
        },
        {
          "name": "true",
          "tip": [
            "解析 metalink 并下载内容"
          ]
        }
      ]
    },
    {
      "name": "--follow-torrent",
      "tip": [
        "U: --follow-torrent <VALUE>",
        "下载 .torrent 文件时解析并下载其内容",
        "Default: true"
      ],
      "next": [
        {
          "name": "false",
          "tip": [
            "将 .torrent 文件下载到磁盘但不解析"
          ]
        },
        {
          "name": "mem",
          "tip": [
            "将 torrent 保留在内存中而不写入磁盘"
          ]
        },
        {
          "name": "true",
          "tip": [
            "解析 torrent 并下载内容"
          ]
        }
      ]
    },
    {
      "name": "--force-save",
      "tip": [
        "即使下载已完成或已删除，也通过 --save-session 选项保存",
        "Default: false"
      ]
    },
    {
      "name": "--force-sequential",
      "alias": [
        "-Z"
      ],
      "tip": [
        "U: -Z, --force-sequential",
        "按命令行顺序依次获取 URI",
        "Default: false"
      ]
    },
    {
      "name": "--ftp-passwd",
      "tip": [
        "设置 FTP 密码。影响所有 URL"
      ]
    },
    {
      "name": "--ftp-pasv",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --ftp-pasv",
        "使用 FTP 被动模式。如果为 false 则使用主动模式",
        "Default: true"
      ]
    },
    {
      "name": "--ftp-proxy",
      "tip": [
        "U: --ftp-proxy <PROXY>",
        "使用 FTP 代理服务器"
      ],
      "next": 0
    },
    {
      "name": "--ftp-proxy-passwd",
      "tip": [
        "U: --ftp-proxy-passwd <PASSWD>",
        "设置 --ftp-proxy 的密码"
      ],
      "next": 0
    },
    {
      "name": "--ftp-proxy-user",
      "tip": [
        "U: --ftp-proxy-user <USER>",
        "设置 --ftp-proxy 的用户名"
      ],
      "next": 0
    },
    {
      "name": "--ftp-reuse-connection",
      "tip": [
