      ],
      "next": [
        {
          "name": "ascii",
          "tip": [
            "ASCII 传输类型"
          ]
        },
        {
          "name": "binary",
          "tip": [
            "二进制传输类型"
          ]
        }
      ]
    },
    {
      "name": "--ftp-user",
      "tip": [
        "设置 FTP 用户名。影响所有 URL"
      ]
    },
    {
      "name": "--gid",
      "tip": [
        "U: --gid <GID>",
        "手动设置 GID。GID 必须是 16 个字符的十六进制字符串"
