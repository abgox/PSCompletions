{
  "meta": {
    "url": "https://github.com/abgox/scoop-tools",
    "description": [
      "A PowerShell script that allows you to temporarily use the replaced proxy URL to download app packages."
    ]
  },
  "global_option": [
    {
      "name": "--arch",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --arch <32bit|64bit|arm64>",
        "Use the specified architecture, if the app supports it"
      ],
      "next": [
        {
          "name": "32bit"
        },
        {
          "name": "64bit"
        },
        {
          "name": "arm64"
        }
      ]
    },
    {
      "name": "--global",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --global",
        "Install the app globally"
      ]
    },
    {
      "name": "--independent",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --independent",
        "Don't install dependencies automatically"
      ]
    },
    {
      "name": "--no-cache",
      "alias": [
        "-k"
      ],
      "tip": [
        "U: -k, --no-cache",
        "Don't use the download cache"
      ]
    },
    {
      "name": "--no-update-scoop",
      "alias": [
        "-u"
      ],
      "tip": [
        "U: -u, --no-update-scoop",
        "Don't update Scoop before installing if it's outdated"
      ]
    },
    {
      "name": "--skip-hash-check",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --skip-hash-check",
        "Skip hash validation (use with caution!)"
      ]
    }
  ],
  "info": {
    "tip": {
      "warning": {
        "config": "Scoop does not have a root_path configuration. Please set it first: scoop config root_path <scoop_path>"
      }
    }
  }
}
