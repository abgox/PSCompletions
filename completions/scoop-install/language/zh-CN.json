{
  "meta": {
    "url": "https://gitee.com/abgox/scoop-tools",
    "description": [
      "一个 PowerShell 脚本，它允许你临时使用替换之后的代理 url 来下载安装包。"
    ]
  },
  "global_option": [
    {
      "name": "--arch",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --arch <32bit|64bit|arm64>",
        "使用指定的架构（如果应用支持）"
      ],
      "next": [
        {
          "name": "32bit"
        },
        {
          "name": "64bit"
        },
        {
          "name": "arm64"
        }
      ]
    },
    {
      "name": "--global",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --global",
        "全局安装应用"
      ]
    },
    {
      "name": "--independent",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --independent",
        "不自动安装依赖"
      ]
    },
    {
      "name": "--no-cache",
      "alias": [
        "-k"
      ],
      "tip": [
        "U: -k, --no-cache",
        "不使用下载缓存"
      ]
    },
    {
      "name": "--no-update-scoop",
      "alias": [
        "-u"
      ],
      "tip": [
        "U: -u, --no-update-scoop",
        "安装前不更新过时的 Scoop"
      ]
    },
    {
      "name": "--skip-hash-check",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --skip-hash-check",
        "跳过哈希验证（谨慎使用！）"
      ]
    }
  ],
  "info": {
    "tip": {
      "warning": {
        "config": "Scoop 未配置 root_path, 请先进行配置: scoop config root_path <scoop_path>"
      }
    }
  }
}
