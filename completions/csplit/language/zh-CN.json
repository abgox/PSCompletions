{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "根据上下文行将文件分割成多个部分。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--digits",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --digits <DIGITS>",
        "使用指定的位数而不是 2"
      ],
      "next": 0
    },
    {
      "name": "--elide-empty-files",
      "alias": [
        "-z"
      ],
      "tip": [
        "删除空的输出文件"
      ]
    },
    {
      "name": "--keep-files",
      "alias": [
        "-k"
      ],
      "tip": [
        "出错时不删除输出文件"
      ]
    },
    {
      "name": "--prefix",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --prefix <PREFIX>",
        "使用 PREFIX 而不是 'xx'"
      ],
      "next": 0
    },
    {
      "name": "--silent",
      "alias": [
        "--quiet",
        "-s"
      ],
      "tip": [
        "不打印输出文件大小的计数"
      ]
    },
    {
      "name": "--suffix-format",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --suffix-format <FORMAT>",
        "使用 sprintf FORMAT 而不是 %02d"
      ],
      "next": 0
    },
    {
      "name": "--suppress-matched",
      "tip": [
        "不输出匹配 PATTERN 的行"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
