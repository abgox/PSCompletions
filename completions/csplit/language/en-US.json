{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Split a file into sections determined by context lines."
    ]
  },
  "option": [
    {
      "name": "--digits",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --digits <DIGITS>",
        "use specified number of digits instead of 2"
      ],
      "next": 0
    },
    {
      "name": "--elide-empty-files",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --elide-empty-files",
        "remove empty output files"
      ]
    },
    {
      "name": "--keep-files",
      "alias": [
        "-k"
      ],
      "tip": [
        "U: -k, --keep-files",
        "do not remove output files on errors"
      ]
    },
    {
      "name": "--prefix",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --prefix <PREFIX>",
        "use PREFIX instead of 'xx'"
      ],
      "next": 0
    },
    {
      "name": "--silent",
      "alias": [
        "--quiet",
        "-s"
      ],
      "tip": [
        "U: --quiet, -s, --silent",
        "do not print counts of output file sizes"
      ]
    },
    {
      "name": "--suffix-format",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --suffix-format <FORMAT>",
        "use sprintf FORMAT instead of %02d"
      ],
      "next": 0
    },
    {
      "name": "--suppress-matched",
      "tip": [
        "suppress the lines matching PATTERN"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
