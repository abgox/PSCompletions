{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Print the prime factors of the given NUMBER(s)."
    ]
  },
  "option": [
    {
      "name": "--exponents",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --exponents",
        "Print factors in the form p^e"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "tip": [
        "Show the help."
      ]
    }
  ]
}
