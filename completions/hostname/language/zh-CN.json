{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "显示或设置系统主机名。"
    ]
  },
  "option": [
    {
      "name": "--domain",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --domain",
        "如果可能，显示 DNS 域名"
      ]
    },
    {
      "name": "--fqdn",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --fqdn",
        "显示 FQDN（完全限定域名）（默认）"
      ]
    },
    {
      "name": "--ip-address",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ip-address",
        "显示主机的网络地址"
      ]
    },
    {
      "name": "--short",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --short",
        "如果可能，显示短主机名（第一个点之前的部分）"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本信息"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息"
      ]
    }
  ]
}
