{
  "meta": {
    "url": "https://github.com/jesseduffield/lazydocker",
    "description": [
      "The lazier way to manage everything docker."
    ]
  },
  "option": [
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config",
        "Print the current default config."
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --debug",
        "Run in debug mode."
      ]
    },
    {
      "name": "--file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --file <file>",
        "Specify alternate compose files."
      ],
      "next": 0
    },
    {
      "name": "--project",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --project <name>",
        "Specify a docker compose project name."
      ],
      "next": 0
    },
    {
      "name": "--version",
      "tip": [
        "Displays the program version string."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Displays help with available flag, subcommand, and positional value parameters."
      ]
    }
  ]
}
