{
  "meta": {
    "url": "https://github.com/jesseduffield/lazydocker",
    "description": [
      "Lazydocker - 管理所有 docker 的更懒惰方式。"
    ]
  },
  "option": [
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config",
        "打印当前默认配置。"
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --debug",
        "以调试模式运行。"
      ]
    },
    {
      "name": "--file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --file <file>",
        "指定替代的 compose 文件。"
      ],
      "next": 0
    },
    {
      "name": "--project",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --project <name>",
        "指定 docker compose 项目名称。"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "tip": [
        "显示程序版本字符串。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示可用标志、子命令和位置值参数的帮助。"
      ]
    }
  ]
}
