{
  "meta": {
    "url": "https://ngrok.com/",
    "description": [
      "Unified Ingress Platform for developers.",
      "Connect localhost to the internet for testing applications and APIs."
    ]
  },
  "next": [
    {
      "name": "api",
      "tip": [
        "use ngrok agent as an api client"
      ]
    },
    {
      "name": "completion",
