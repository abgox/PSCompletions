        "generates shell completion code for bash or zsh"
      ]
    },
    {
      "name": "config",
      "tip": [
        "update or migrate ngrok's configuration file"
      ]
    },
    {
      "name": "credits",
      "tip": [
        "prints author and licensing information"
      ]
    },
    {
      "name": "diagnose",
      "tip": [
        "diagnose connection issues"
      ]
    },
    {
      "name": "help",
      "tip": [
        "Help about any command"
      ]
    },
    {
      "name": "http",
      "tip": [
        "start an HTTP tunnel"
      ]
    },
    {
      "name": "service",
      "tip": [
        "run and control an ngrok service on a target operating system"
      ]
    },
    {
      "name": "start",
      "tip": [
        "start endpoints or tunnels by name from the configuration file"
      ]
    },
    {
      "name": "tcp",
      "tip": [
        "start a TCP tunnel"
      ]
    },
    {
      "name": "tls",
      "tip": [
        "start a TLS tunnel"
      ]
    },
    {
