      "tip": [
        "start a tunnel for use with a tunnel-group backend"
      ]
    },
    {
      "name": "update",
      "tip": [
        "update ngrok to the latest version"
      ]
    },
    {
      "name": "version",
      "tip": [
        "print the version string"
      ]
    }
  ],
  "option": [
    {
      "name": "--metadata",
      "tip": [
        "Opaque user-defined metadata for the tunnel session."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--config",
      "tip": [
        "path to config files",
        "they are merged if multiple"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
