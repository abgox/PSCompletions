{
  "meta": {
    "url": "https://github.com/ouch-org/ouch",
    "description": [
      "A command-line utility for easily compressing and decompressing files and directories",
      "Supported formats: tar, zip, gz, 7z, xz, lzma, bz2, bz3, lz4, zst, rar, br"
    ]
  },
  "next": [
    {
      "name": "compress",
      "alias": [
        "c"
      ],
      "tip": [
        "U: compress [OPTIONS] <FILES>... <OUTPUT>",
        "Compress one or more files into one output file"
      ],
      "option": [
        {
          "name": "--fast",
          "tip": [
            "Fastest compression level possible"
          ]
        },
        {
          "name": "--follow-symlinks",
          "alias": [
            "-S"
          ],
          "tip": [
            "U: -S, --follow-symlinks",
            "Read from target files instead of from symlinks"
          ]
        },
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "Specify the format of the archive"
          ],
          "next": 0
        },
        {
          "name": "--gitignore",
          "alias": [
            "-g"
          ],
          "tip": [
            "U: -g, --gitignore",
            "Ignore files matched by git's ignore files"
          ]
        },
        {
          "name": "--hidden",
          "alias": [
            "-H"
          ],
          "tip": [
            "U: -H, --hidden",
            "Ignore hidden files"
          ]
        },
        {
          "name": "--level",
          "alias": [
            "-l"
          ],
          "tip": [
            "U: -l, --level <LEVEL>",
            "Compression level, applied to all formats"
          ],
          "next": 0
        },
        {
          "name": "--password",
          "alias": [
            "-p"
          ],
          "tip": [
            "U: -p, --password <PASSWORD>",
            "Compress with password"
          ],
          "next": 0
        },
        {
          "name": "--slow",
          "tip": [
            "Slowest and best compression level possible"
          ]
        },
        {
          "name": "--threads",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --threads <THREADS>",
            "Concurrent working threads"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "decompress",
      "alias": [
        "d"
      ],
      "tip": [
        "U: decompress [OPTIONS] <FILES>...",
        "Decompress one or more files, optionally into another folder"
      ],
      "option": [
        {
          "name": "--dir",
          "alias": [
            "-d"
          ],
          "tip": [
            "U: -d, --dir <OUTPUT_DIR>",
            "Decompress inside OUTPUT_DIR instead of the basename-derived subdirectory"
          ],
          "next": 0
        },
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "Specify the format of the archive"
          ],
          "next": 0
        },
        {
          "name": "--gitignore",
          "alias": [
            "-g"
          ],
          "tip": [
            "U: -g, --gitignore",
            "Ignore files matched by git's ignore files"
          ]
        },
        {
          "name": "--here",
          "tip": [
            "Extract directly into the current directory"
          ]
        },
        {
          "name": "--hidden",
          "alias": [
            "-H"
          ],
          "tip": [
            "U: -H, --hidden",
            "Ignore hidden files"
          ]
        },
        {
          "name": "--password",
          "alias": [
            "-p"
          ],
          "tip": [
            "U: -p, --password <PASSWORD>",
            "Decompress with password"
          ],
          "next": 0
        },
        {
          "name": "--remove",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --remove",
            "Remove the source file after successful decompression"
          ]
        },
        {
          "name": "--threads",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --threads <THREADS>",
            "Concurrent working threads"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "list",
      "alias": [
        "ls",
        "l"
      ],
      "tip": [
        "U: list [OPTIONS] <ARCHIVES>...",
        "List contents of an archive"
      ],
      "option": [
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "Specify the format of the archive"
          ],
          "next": 0
        },
        {
          "name": "--gitignore",
          "alias": [
            "-g"
          ],
          "tip": [
            "U: -g, --gitignore",
            "Ignore files matched by git's ignore files"
          ]
        },
        {
          "name": "--hidden",
          "alias": [
            "-H"
          ],
          "tip": [
            "U: -H, --hidden",
            "Ignore hidden files"
          ]
        },
        {
          "name": "--password",
          "alias": [
            "-p"
          ],
          "tip": [
            "U: -p, --password <PASSWORD>",
            "List with password"
          ],
          "next": 0
        },
        {
          "name": "--tree",
          "alias": [
            "-t"
          ],
          "tip": [
            "U: -t, --tree",
            "Show archive contents as a tree"
          ]
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--accessible",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --accessible",
        "Activate accessibility mode, reducing visual noise"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--no",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --no",
        "Skip [Y/n] questions, default to no"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "Silence output"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version"
      ]
    },
    {
      "name": "--yes",
      "alias": [
        "-y"
      ],
      "tip": [
        "U: -y, --yes",
        "Skip [Y/n] questions, default to yes"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    }
  ]
}
