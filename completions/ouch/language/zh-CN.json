{
  "meta": {
    "url": "https://github.com/ouch-org/ouch",
    "description": [
      "一个用于轻松压缩和解压文件与目录的命令行工具",
      "支持格式：tar、zip、gz、7z、xz、lzma、bz2、bz3、lz4、zst、rar、br"
    ]
  },
  "next": [
    {
      "name": "compress",
      "alias": [
        "c"
      ],
      "tip": [
        "U: compress [OPTIONS] <FILES>... <OUTPUT>",
        "将一个或多个文件压缩为一个输出文件"
      ],
      "option": [
        {
          "name": "--fast",
          "tip": [
            "最快压缩级别"
          ]
        },
        {
          "name": "--follow-symlinks",
          "alias": [
            "-S"
          ],
          "tip": [
            "U: -S, --follow-symlinks",
            "读取目标文件而非符号链接"
          ]
        },
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "指定归档文件的格式"
          ],
          "next": 0
        },
        {
          "name": "--gitignore",
          "alias": [
            "-g"
          ],
          "tip": [
            "U: -g, --gitignore",
            "忽略 git 忽略文件中匹配的文件"
          ]
        },
        {
          "name": "--hidden",
          "alias": [
            "-H"
          ],
          "tip": [
            "U: -H, --hidden",
            "忽略隐藏文件"
          ]
        },
        {
          "name": "--level",
          "alias": [
            "-l"
          ],
          "tip": [
            "U: -l, --level <LEVEL>",
            "压缩级别，应用于所有格式"
          ],
          "next": 0
        },
        {
          "name": "--password",
          "alias": [
            "-p"
          ],
          "tip": [
            "U: -p, --password <PASSWORD>",
            "使用密码压缩"
          ],
          "next": 0
        },
        {
          "name": "--slow",
          "tip": [
            "最慢但最佳的压缩级别"
          ]
        },
        {
          "name": "--threads",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --threads <THREADS>",
            "并发工作线程数"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "decompress",
      "alias": [
        "d"
      ],
      "tip": [
        "U: decompress [OPTIONS] <FILES>...",
        "解压一个或多个文件，可选输出到其他文件夹"
      ],
      "option": [
        {
          "name": "--dir",
          "alias": [
            "-d"
          ],
          "tip": [
            "U: -d, --dir <OUTPUT_DIR>",
            "解压到 OUTPUT_DIR 目录而非基于文件名的子目录"
          ],
          "next": 0
        },
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "指定归档文件的格式"
          ],
          "next": 0
        },
        {
          "name": "--gitignore",
          "alias": [
            "-g"
          ],
          "tip": [
            "U: -g, --gitignore",
            "忽略 git 忽略文件中匹配的文件"
          ]
        },
        {
          "name": "--here",
          "tip": [
            "直接解压到当前目录"
          ]
        },
        {
          "name": "--hidden",
          "alias": [
            "-H"
          ],
          "tip": [
            "U: -H, --hidden",
            "忽略隐藏文件"
          ]
        },
        {
          "name": "--password",
          "alias": [
            "-p"
          ],
          "tip": [
            "U: -p, --password <PASSWORD>",
            "使用密码解压"
          ],
          "next": 0
        },
        {
          "name": "--remove",
          "alias": [
            "-r"
          ],
          "tip": [
            "U: -r, --remove",
            "解压成功后删除源文件"
          ]
        },
        {
          "name": "--threads",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --threads <THREADS>",
            "并发工作线程数"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "list",
      "alias": [
        "ls",
        "l"
      ],
      "tip": [
        "U: list [OPTIONS] <ARCHIVES>...",
        "列出归档文件的内容"
      ],
      "option": [
        {
          "name": "--format",
          "alias": [
            "-f"
          ],
          "tip": [
            "U: -f, --format <FORMAT>",
            "指定归档文件的格式"
          ],
          "next": 0
        },
        {
          "name": "--gitignore",
          "alias": [
            "-g"
          ],
          "tip": [
            "U: -g, --gitignore",
            "忽略 git 忽略文件中匹配的文件"
          ]
        },
        {
          "name": "--hidden",
          "alias": [
            "-H"
          ],
          "tip": [
            "U: -H, --hidden",
            "忽略隐藏文件"
          ]
        },
        {
          "name": "--password",
          "alias": [
            "-p"
          ],
          "tip": [
            "U: -p, --password <PASSWORD>",
            "使用密码列出内容"
          ],
          "next": 0
        },
        {
          "name": "--tree",
          "alias": [
            "-t"
          ],
          "tip": [
            "U: -t, --tree",
            "以树形结构显示归档内容"
          ]
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--accessible",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --accessible",
        "启用无障碍模式，减少视觉干扰"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息"
      ]
    },
    {
      "name": "--no",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --no",
        "跳过 [Y/n] 确认，默认选择否"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "静默输出"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本信息"
      ]
    },
    {
      "name": "--yes",
      "alias": [
        "-y"
      ],
      "tip": [
        "U: -y, --yes",
        "跳过 [Y/n] 确认，默认选择是"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息"
      ]
    }
  ]
}
