{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "显示每个文件所在文件系统的信息，默认显示所有文件系统。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--all",
      "alias": [
        "-a"
      ],
      "tip": [
        "包含虚拟文件系统"
      ]
    },
    {
      "name": "--block-size",
      "alias": [
        "-B"
      ],
      "tip": [
        "U: -B, --block-size <SIZE>",
        "打印前按 SIZE 缩放大小;",
        "E: -B M   --- 以 1,048,576 字节为单位打印大小"
      ],
      "next": [
        {
          "name": "E",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "EB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "G",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "GB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "K",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "KB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "M",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "MB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "P",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "PB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "T",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "TB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "Y",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "YB",
          "tip": [
            "1000 的幂"
          ]
        },
        {
          "name": "Z",
          "tip": [
            "1024 的幂"
          ]
        },
        {
          "name": "ZB",
          "tip": [
            "1000 的幂"
          ]
        }
      ]
    },
    {
      "name": "--exclude-type",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --exclude-type <TYPE>",
        "仅列出非指定类型的文件系统"
      ],
      "next": 0
    },
    {
      "name": "--human-readable",
      "alias": [
        "-h"
      ],
      "tip": [
        "以人类可读格式打印大小 (例如 1K 234M 2G)"
      ]
    },
    {
      "name": "--inodes",
      "alias": [
        "-i"
      ],
      "tip": [
        "列出 inode 信息而非块使用情况"
      ]
    },
    {
      "name": "--local",
      "alias": [
        "-l"
      ],
      "tip": [
        "仅列出本地文件系统"
      ]
    },
    {
      "name": "--no-sync",
      "tip": [
        "获取使用信息前不调用 sync (默认)"
      ]
    },
    {
      "name": "--output",
      "tip": [
        "U: --output[=<FIELD_LIST>...]",
        "使用 FIELD_LIST 定义的输出格式，省略 FIELD_LIST 则打印所有字段。",
        "[默认: source size used avail pcent target]",
        "[可选值: source, fstype, itotal, iused, iavail, ipcent, size, used, avail, pcent, file, target]"
      ]
    },
    {
      "name": "--portability",
      "alias": [
        "-P"
      ],
      "tip": [
        "使用 POSIX 输出格式"
      ]
    },
    {
      "name": "--print-type",
      "alias": [
        "-T"
      ],
      "tip": [
        "打印文件系统类型"
      ]
    },
    {
      "name": "--si",
      "alias": [
        "-H"
      ],
      "tip": [
        "同上，但使用 1000 的幂而非 1024"
      ]
    },
    {
      "name": "--sync",
      "tip": [
        "获取使用信息前调用 sync (仅非 Windows)"
      ]
    },
    {
      "name": "--total",
      "tip": [
        "生成总计"
      ]
    },
    {
      "name": "--type",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --type <TYPE>",
        "仅列出指定类型的文件系统"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "-k",
      "tip": [
        "等同于 --block-size=1K"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
