{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Show information about file system space usage."
    ]
  },
  "option": [
    {
      "name": "--all",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --all",
        "include dummy file systems"
      ]
    },
    {
      "name": "--block-size",
      "alias": [
        "-B"
      ],
      "tip": [
        "U: -B, --block-size <SIZE>",
        "scale sizes by SIZE before printing them;",
        "E: -B M   --- prints sizes in units of 1,048,576 bytes"
      ],
      "next": [
        {
          "name": "E",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "EB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "G",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "GB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "K",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "KB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "M",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "MB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "P",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "PB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "T",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "TB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "Y",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "YB",
          "tip": [
            "powers of 1000"
          ]
        },
        {
          "name": "Z",
          "tip": [
            "powers of 1024"
          ]
        },
        {
          "name": "ZB",
          "tip": [
            "powers of 1000"
          ]
        }
      ]
    },
    {
      "name": "--exclude-type",
      "alias": [
        "-x"
      ],
      "tip": [
        "U: -x, --exclude-type <TYPE>",
        "limit listing to file systems not of type TYPE"
      ],
      "next": 0
    },
    {
      "name": "--human-readable",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --human-readable",
        "print sizes in human readable format (e.g. 1K 234M 2G)"
      ]
    },
    {
      "name": "--inodes",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --inodes",
        "list inode information instead of block usage"
      ]
    },
    {
      "name": "--local",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --local",
        "limit listing to local file systems"
      ]
    },
    {
      "name": "--no-sync",
      "tip": [
        "do not invoke sync before getting usage info (default)"
      ]
    },
    {
      "name": "--output",
      "tip": [
        "U: --output[=<FIELD_LIST>...]",
        "use the output format defined by FIELD_LIST, or print all fields if FIELD_LIST is omitted.",
        "[default: source size used avail pcent target]",
        "[possible values: source, fstype, itotal, iused, iavail, ipcent, size, used, avail, pcent, file, target]"
      ]
    },
    {
      "name": "--portability",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --portability",
        "use the POSIX output format"
      ]
    },
    {
      "name": "--print-type",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --print-type",
        "print file system type"
      ]
    },
    {
      "name": "--si",
      "alias": [
        "-H"
      ],
      "tip": [
        "U: -H, --si",
        "likewise, but use powers of 1000 not 1024"
      ]
    },
    {
      "name": "--sync",
      "tip": [
        "invoke sync before getting usage info (non-windows only)"
      ]
    },
    {
      "name": "--total",
      "tip": [
        "produce a grand total"
      ]
    },
    {
      "name": "--type",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --type <TYPE>",
        "limit listing to file systems of type TYPE"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    },
    {
      "name": "-k",
      "tip": [
        "like --block-size=1K"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
