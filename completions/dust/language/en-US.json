{
  "meta": {
    "url": "https://github.com/bootandy/dust",
    "description": [
      "Like du but more intuitive."
    ]
  },
  "option": [
    {
      "name": "--apparent-size",
      "alias": [
        "-s"
      ],
      "tip": [
        "Use file length instead of blocks"
      ]
    },
    {
      "name": "--atime",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --atime <ATIME>",
        "Like --mtime, but based on file access time"
      ],
      "next": 0
    },
    {
      "name": "--bars-on-right",
      "alias": [
        "-B"
      ],
      "tip": [
        "Percent bars moved to right side of screen"
      ]
    },
    {
      "name": "--collapse",
      "tip": [
        "U: --collapse <COLLAPSE>",
        "Keep these directories collapsed"
      ],
      "next": 0
    },
    {
      "name": "--config",
      "tip": [
        "U: --config <FILE>",
        "Specify a config file to use"
      ],
      "next": 0
    },
    {
      "name": "--ctime",
      "alias": [
        "-y"
      ],
      "tip": [
        "U: -y, --ctime <CTIME>",
        "Like --mtime, but based on file change time"
      ],
      "next": 0
    },
    {
      "name": "--depth",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --depth <DEPTH>",
        "Depth to show"
      ],
      "next": 0
    },
    {
      "name": "--dereference-links",
      "alias": [
        "-L"
      ],
      "tip": [
        "Dereference sym links, treat sym links as directories and go into them"
      ]
    },
    {
      "name": "--file-types",
      "alias": [
        "-t"
      ],
      "tip": [
        "Show only these file types"
      ]
    },
    {
      "name": "--filecount",
      "alias": [
        "-f"
      ],
      "tip": [
        "Directory size is number of child files instead of disk size"
      ]
    },
    {
      "name": "--files-from",
      "tip": [
        "U: --files-from <FILES_FROM>",
        "Read newline-terminated paths from FILE (use - for stdin)"
      ],
      "next": 0
    },
    {
      "name": "--files0-from",
      "tip": [
        "U: --files0-from <FILES0_FROM>",
        "Read NUL-terminated paths from FILE (use - for stdin)"
      ],
      "next": 0
    },
    {
      "name": "--filetime",
      "alias": [
        "-m"
      ],
      "tip": [
        "U: -m, --filetime <FILETIME>",
        "Directory size is max filetime of child files instead of disk size"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "Last accessed time"
          ]
        },
        {
          "name": "c",
          "tip": [
            "Last changed time"
          ]
        },
        {
          "name": "m",
          "tip": [
            "Last modified time"
          ]
        }
      ]
    },
    {
      "name": "--filter",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --filter <REGEX>",
        "Only include filepaths matching this regex"
      ],
      "next": 0
    },
    {
      "name": "--force-colors",
      "alias": [
        "-C"
      ],
      "tip": [
        "Force colors print"
      ]
    },
    {
      "name": "--full-paths",
      "alias": [
        "-p"
      ],
      "tip": [
        "Subdirectories will not have their path shortened"
      ]
    },
    {
      "name": "--ignore-all-in-file",
      "alias": [
        "-I"
      ],
      "tip": [
        "U: -I, --ignore-all-in-file <FILE>",
        "Exclude file or directory with a regex matching that listed in this file"
      ],
      "next": 0
    },
    {
      "name": "--ignore-directory",
      "alias": [
        "-X"
      ],
      "tip": [
        "U: -X, --ignore-directory <PATH>",
        "Exclude any file or directory with this path"
      ],
      "next": 0
    },
    {
      "name": "--ignore-hidden",
      "alias": [
        "-i"
      ],
      "tip": [
        "Do not display hidden files"
      ]
    },
    {
      "name": "--invert-filter",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --invert-filter <REGEX>",
        "Exclude filepaths matching this regex"
      ],
      "next": 0
    },
    {
      "name": "--limit-filesystem",
      "alias": [
        "-x"
      ],
      "tip": [
        "Only count the files and directories on the same filesystem as the supplied directory"
      ]
    },
    {
      "name": "--min-size",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --min-size <MIN_SIZE>",
        "Minimum size file to include in output"
      ],
      "next": 0
    },
    {
      "name": "--mtime",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --mtime <MTIME>",
        "+/-n matches files modified more/less than n days ago"
      ],
      "next": 0
    },
    {
      "name": "--no-colors",
      "alias": [
        "-c"
      ],
      "tip": [
        "No colors will be printed (useful for commands like watch)"
      ]
    },
    {
      "name": "--no-percent-bars",
      "alias": [
        "-b"
      ],
      "tip": [
        "No percent bars or percentages will be displayed"
      ]
    },
    {
      "name": "--no-progress",
      "alias": [
        "-P"
      ],
      "tip": [
        "Disable the progress indication"
      ]
    },
    {
      "name": "--number-of-lines",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --number-of-lines <NUMBER>",
        "Display the n largest entries (default is terminal height)"
      ],
      "next": 0
    },
    {
      "name": "--only-dir",
      "alias": [
        "-D"
      ],
      "tip": [
        "Only directories will be displayed"
      ]
    },
    {
      "name": "--only-file",
      "alias": [
        "-F"
      ],
      "tip": [
        "Only files will be displayed (finds your largest files)"
      ]
    },
    {
      "name": "--output-format",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --output-format <FORMAT>",
        "Changes output display size"
      ],
      "next": [
        {
          "name": "b",
          "tip": [
            "Byte (B)"
          ]
        },
        {
          "name": "g",
          "tip": [
            "Gibibyte (GiB)"
          ]
        },
        {
          "name": "gb",
          "tip": [
            "Gigabyte (GB)"
          ]
        },
        {
          "name": "k",
          "tip": [
            "Kibibyte (KiB)"
          ]
        },
        {
          "name": "kb",
          "tip": [
            "Kilobyte (kB)"
          ]
        },
        {
          "name": "m",
          "tip": [
            "Mebibyte (MiB)"
          ]
        },
        {
          "name": "mb",
          "tip": [
            "Megabyte (MB)"
          ]
        },
        {
          "name": "si",
          "tip": [
            "SI prefix (powers of 1000)"
          ]
        },
        {
          "name": "t",
          "tip": [
            "Tebibyte (TiB)"
          ]
        },
        {
          "name": "tb",
          "tip": [
            "Terabyte (TB)"
          ]
        }
      ]
    },
    {
      "name": "--output-json",
      "alias": [
        "-j"
      ],
      "tip": [
        "Output the directory tree as json to the current directory"
      ]
    },
    {
      "name": "--print-errors",
      "tip": [
        "Print path with errors"
      ]
    },
    {
      "name": "--reverse",
      "alias": [
        "-r"
      ],
      "tip": [
        "Print tree upside down (biggest highest)"
      ]
    },
    {
      "name": "--screen-reader",
      "alias": [
        "-R"
      ],
      "tip": [
        "For screen readers, removes bars and adds depth level column"
      ]
    },
    {
      "name": "--skip-total",
      "tip": [
        "No total row will be displayed"
      ]
    },
    {
      "name": "--stack-size",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --stack-size <STACK_SIZE>",
        "Specify memory to use as stack size"
      ],
      "next": 0
    },
    {
      "name": "--terminal-width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --terminal-width <WIDTH>",
        "Specify width of output overriding the auto detection of terminal width"
      ],
      "next": 0
    },
    {
      "name": "--threads",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --threads <THREADS>",
        "Number of threads to use"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    }
  ]
}
