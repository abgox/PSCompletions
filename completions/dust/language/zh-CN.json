{
  "meta": {
    "url": "https://github.com/bootandy/dust",
    "description": [
      "比 du 更直观。"
    ]
  },
  "option": [
    {
      "name": "--apparent-size",
      "alias": [
        "-s"
      ],
      "tip": [
        "使用文件长度而非磁盘块数"
      ]
    },
    {
      "name": "--atime",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --atime <ATIME>",
        "类似 --mtime，但基于文件访问时间"
      ],
      "next": 0
    },
    {
      "name": "--bars-on-right",
      "alias": [
        "-B"
      ],
      "tip": [
        "百分比条移到屏幕右侧"
      ]
    },
    {
      "name": "--collapse",
      "tip": [
        "U: --collapse <COLLAPSE>",
        "保持这些目录折叠"
      ],
      "next": 0
    },
    {
      "name": "--config",
      "tip": [
        "U: --config <FILE>",
        "指定使用的配置文件"
      ],
      "next": 0
    },
    {
      "name": "--ctime",
      "alias": [
        "-y"
      ],
      "tip": [
        "U: -y, --ctime <CTIME>",
        "类似 --mtime，但基于文件更改时间"
      ],
      "next": 0
    },
    {
      "name": "--depth",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --depth <DEPTH>",
        "显示深度"
      ],
      "next": 0
    },
    {
      "name": "--dereference-links",
      "alias": [
        "-L"
      ],
      "tip": [
        "解引用符号链接，将符号链接视为目录并进入"
      ]
    },
    {
      "name": "--file-types",
      "alias": [
        "-t"
      ],
      "tip": [
        "仅显示这些文件类型"
      ]
    },
    {
      "name": "--filecount",
      "alias": [
        "-f"
      ],
      "tip": [
        "目录大小显示为子文件数而非磁盘大小"
      ]
    },
    {
      "name": "--files-from",
      "tip": [
        "U: --files-from <FILES_FROM>",
        "从 FILE 读取以换行符终止的路径（使用 - 表示 stdin）"
      ],
      "next": 0
    },
    {
      "name": "--files0-from",
      "tip": [
        "U: --files0-from <FILES0_FROM>",
        "从 FILE 读取以 NUL 终止的路径（使用 - 表示 stdin）"
      ],
      "next": 0
    },
    {
      "name": "--filetime",
      "alias": [
        "-m"
      ],
      "tip": [
        "U: -m, --filetime <FILETIME>",
        "目录大小显示为子文件的最大文件时间而非磁盘大小"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "最后访问时间"
          ]
        },
        {
          "name": "c",
          "tip": [
            "最后更改时间"
          ]
        },
        {
          "name": "m",
          "tip": [
            "最后修改时间"
          ]
        }
      ]
    },
    {
      "name": "--filter",
      "alias": [
        "-e"
      ],
      "tip": [
        "U: -e, --filter <REGEX>",
        "仅包含与此正则表达式匹配的文件路径"
      ],
      "next": 0
    },
    {
      "name": "--force-colors",
      "alias": [
        "-C"
      ],
      "tip": [
        "强制彩色输出"
      ]
    },
    {
      "name": "--full-paths",
      "alias": [
        "-p"
      ],
      "tip": [
        "子目录路径不会被缩短"
      ]
    },
    {
      "name": "--ignore-all-in-file",
      "alias": [
        "-I"
      ],
      "tip": [
        "U: -I, --ignore-all-in-file <FILE>",
        "排除与此文件中列出的正则表达式匹配的文件或目录"
      ],
      "next": 0
    },
    {
      "name": "--ignore-directory",
      "alias": [
        "-X"
      ],
      "tip": [
        "U: -X, --ignore-directory <PATH>",
        "排除具有此路径的任何文件或目录"
      ],
      "next": 0
    },
    {
      "name": "--ignore-hidden",
      "alias": [
        "-i"
      ],
      "tip": [
        "不显示隐藏文件"
      ]
    },
    {
      "name": "--invert-filter",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --invert-filter <REGEX>",
        "排除与此正则表达式匹配的文件路径"
      ],
      "next": 0
    },
    {
      "name": "--limit-filesystem",
      "alias": [
        "-x"
      ],
      "tip": [
        "仅统计与所提供目录在同一文件系统上的文件和目录"
      ]
    },
    {
      "name": "--min-size",
      "alias": [
        "-z"
      ],
      "tip": [
        "U: -z, --min-size <MIN_SIZE>",
        "输出中包含的最小文件大小"
      ],
      "next": 0
    },
    {
      "name": "--mtime",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --mtime <MTIME>",
        "+/-n 匹配超过/少于 n 天前修改的文件"
      ],
      "next": 0
    },
    {
      "name": "--no-colors",
      "alias": [
        "-c"
      ],
      "tip": [
        "不打印颜色（适用于 watch 等命令）"
      ]
    },
    {
      "name": "--no-percent-bars",
      "alias": [
        "-b"
      ],
      "tip": [
        "不显示百分比条和百分比"
      ]
    },
    {
      "name": "--no-progress",
      "alias": [
        "-P"
      ],
      "tip": [
        "禁用进度指示"
      ]
    },
    {
      "name": "--number-of-lines",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --number-of-lines <NUMBER>",
        "显示前 n 个最大条目（默认为终端高度）"
      ],
      "next": 0
    },
    {
      "name": "--only-dir",
      "alias": [
        "-D"
      ],
      "tip": [
        "仅显示目录"
      ]
    },
    {
      "name": "--only-file",
      "alias": [
        "-F"
      ],
      "tip": [
        "仅显示文件（找出最大的文件）"
      ]
    },
    {
      "name": "--output-format",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --output-format <FORMAT>",
        "更改输出显示大小"
      ],
      "next": [
        {
          "name": "b",
          "tip": [
            "字节 (B)"
          ]
        },
        {
          "name": "g",
          "tip": [
            "Gibibyte (GiB) "
          ]
        },
        {
          "name": "gb",
          "tip": [
            "Gigabyte (GB) "
          ]
        },
        {
          "name": "k",
          "tip": [
            "Kibibyte (KiB) "
          ]
        },
        {
          "name": "kb",
          "tip": [
            "Kilobyte (kB) "
          ]
        },
        {
          "name": "m",
          "tip": [
            "Mebibyte (MiB) "
          ]
        },
        {
          "name": "mb",
          "tip": [
            "Megabyte (MB) "
          ]
        },
        {
          "name": "si",
          "tip": [
            "SI 前缀（1000 的幂）"
          ]
        },
        {
          "name": "t",
          "tip": [
            "Tebibyte (TiB) "
          ]
        },
        {
          "name": "tb",
          "tip": [
            "Terabyte (TB) "
          ]
        }
      ]
    },
    {
      "name": "--output-json",
      "alias": [
        "-j"
      ],
      "tip": [
        "将目录树输出为 json 到当前目录"
      ]
    },
    {
      "name": "--print-errors",
      "tip": [
        "打印有错误的路径"
      ]
    },
    {
      "name": "--reverse",
      "alias": [
        "-r"
      ],
      "tip": [
        "倒序打印树（最大的在最上面）"
      ]
    },
    {
      "name": "--screen-reader",
      "alias": [
        "-R"
      ],
      "tip": [
        "适用于屏幕阅读器，移除条形图并添加深度级别列"
      ]
    },
    {
      "name": "--skip-total",
      "tip": [
        "不显示总计行"
      ]
    },
    {
      "name": "--stack-size",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --stack-size <STACK_SIZE>",
        "指定用作栈大小的内存"
      ],
      "next": 0
    },
    {
      "name": "--terminal-width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --terminal-width <WIDTH>",
        "指定输出宽度，覆盖终端宽度自动检测"
      ],
      "next": 0
    },
    {
      "name": "--threads",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --threads <THREADS>",
        "使用的线程数"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助"
      ]
    }
  ]
}
