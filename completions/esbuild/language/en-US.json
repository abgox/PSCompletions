{
  "meta": {
    "url": "https://esbuild.github.io/",
    "description": [
      "Extremely fast JavaScript and CSS bundler and minifier."
    ]
  },
  "option": [
    {
      "name": "--abs-paths",
      "tip": [
        "U: --abs-paths=<TYPE>",
        "Emit absolute instead of relative paths in these situations"
      ],
      "next": [
        {
          "name": "code",
          "tip": [
            "Absolute paths in generated code"
          ]
        },
        {
          "name": "log",
          "tip": [
            "Absolute paths in log messages"
          ]
        },
        {
          "name": "metafile",
          "tip": [
            "Absolute paths in metafile JSON"
          ]
        }
      ]
    },
    {
      "name": "--allow-overwrite",
      "tip": [
        "Allow output files to overwrite input files"
      ]
    },
    {
      "name": "--analyze",
      "tip": [
        "Print a report about the contents of the bundle (use \"--analyze=verbose\" for a detailed report)"
      ]
    },
    {
      "name": "--asset-names",
      "tip": [
        "U: --asset-names=<TEMPLATE>",
        "Path template to use for \"file\" loader files (default \"[name]-[hash]\")"
      ],
      "next": 0
    },
    {
      "name": "--banner:T=...",
      "alias": [
        "--banner"
      ],
      "tip": [
        "U: --banner:<TYPE>=<TEXT>",
        "Text to be prepended to each output file of type T (css | js)"
      ]
    },
    {
      "name": "--bundle",
      "tip": [
        "Bundle all dependencies into the output files"
      ]
    },
    {
      "name": "--certfile",
      "tip": [
        "U: --certfile=<FILE>",
        "Certificate for serving HTTPS (see also \"--keyfile\")"
      ],
      "next": 0
    },
    {
      "name": "--charset",
      "tip": [
        "Do not escape UTF-8 code points"
      ]
    },
    {
      "name": "--chunk-names",
      "tip": [
        "U: --chunk-names=<TEMPLATE>",
        "Path template to use for code splitting chunks (default \"[name]-[hash]\")"
      ],
      "next": 0
    },
    {
      "name": "--color",
      "tip": [
        "U: --color=<VALUE>",
        "Force use of color terminal escapes"
      ],
      "next": [
        {
          "name": "false",
          "tip": [
            "Disable color output"
          ]
        },
        {
          "name": "true",
          "tip": [
            "Force color output"
          ]
        }
      ]
    },
    {
      "name": "--cors-origin",
      "tip": [
        "U: --cors-origin=<ORIGIN>",
        "Allow cross-origin requests from this origin"
      ],
      "next": 0
    },
    {
      "name": "--define:K=V",
      "alias": [
        "--define"
      ],
      "tip": [
        "U: --define:K=V",
        "Substitute K with V while parsing"
      ]
    },
    {
      "name": "--drop",
      "tip": [
        "U: --drop:<TYPE>",
        "Remove certain constructs"
      ],
      "next": [
        {
          "name": "console",
          "tip": [
            "Remove all console.* calls"
          ]
        },
        {
          "name": "debugger",
          "tip": [
            "Remove all debugger statements"
          ]
        }
      ]
    },
    {
      "name": "--drop-labels",
      "tip": [
        "U: --drop-labels=<LABELS>",
        "Remove labeled statements with these label names"
      ],
      "next": 0
    },
    {
      "name": "--entry-names",
      "tip": [
        "U: --entry-names=<TEMPLATE>",
        "Path template to use for entry point output paths (default \"[dir]/[name]\")"
      ],
      "next": 0
    },
    {
      "name": "--external:M",
      "alias": [
        "--external"
      ],
      "tip": [
        "U: --external:M",
        "Exclude module M from the bundle (can use * wildcards)"
      ]
    },
    {
      "name": "--footer",
      "tip": [
        "U: --footer:<TYPE>=<TEXT>",
        "Text to be appended to each output file of type T (css | js)"
      ]
    },
    {
      "name": "--format",
      "tip": [
        "U: --format=<FORMAT>",
        "Output format"
      ],
      "next": [
        {
          "name": "cjs",
          "tip": [
            "CommonJS module (default for node)"
          ]
        },
        {
          "name": "esm",
          "tip": [
            "ES module"
          ]
        },
        {
          "name": "iife",
          "tip": [
            "Immediately-invoked function expression (default for browser)"
          ]
        }
      ]
    },
    {
      "name": "--global-name",
      "tip": [
        "U: --global-name=<NAME>",
        "The name of the global for the IIFE format"
      ],
      "next": 0
    },
    {
      "name": "--ignore-annotations",
      "tip": [
        "Enable this to work with packages that have incorrect tree-shaking annotations"
      ]
    },
    {
      "name": "--inject",
      "tip": [
        "U: --inject:<FILE>",
        "Import the file F into all input files and automatically replace matching globals with imports"
      ],
      "next": 0
    },
    {
      "name": "--jsx",
      "tip": [
        "U: --jsx=<MODE>",
        "Set to \"automatic\" to use React's automatic runtime or to \"preserve\" to disable transforming JSX to JS"
      ],
      "next": [
        {
          "name": "automatic",
          "tip": [
            "Use React's automatic runtime"
          ]
        },
        {
          "name": "preserve",
          "tip": [
            "Disable transforming JSX to JS"
          ]
        }
      ]
    },
    {
      "name": "--jsx-dev",
      "tip": [
        "Use React's automatic runtime in development mode"
      ]
    },
    {
      "name": "--jsx-factory",
      "tip": [
        "U: --jsx-factory=<EXPR>",
        "What to use for JSX instead of React.createElement"
      ],
      "next": 0
    },
    {
      "name": "--jsx-fragment",
      "tip": [
        "U: --jsx-fragment=<EXPR>",
        "What to use for JSX instead of React.Fragment"
      ],
      "next": 0
    },
    {
      "name": "--jsx-import-source",
      "tip": [
        "U: --jsx-import-source=<PKG>",
        "Override the package name for the automatic runtime (default \"react\")"
      ],
      "next": 0
    },
    {
      "name": "--jsx-side-effects",
      "tip": [
        "Do not remove unused JSX expressions"
      ]
    },
    {
      "name": "--keep-names",
      "tip": [
        "Preserve \"name\" on functions and classes"
      ]
    },
    {
      "name": "--keyfile",
      "tip": [
        "U: --keyfile=<FILE>",
        "Key for serving HTTPS (see also \"--certfile\")"
      ],
      "next": 0
    },
    {
      "name": "--legal-comments",
      "tip": [
        "U: --legal-comments=<WHERE>",
        "Where to place legal comments (default eof when bundling, inline otherwise)"
      ],
      "next": [
        {
          "name": "eof",
          "tip": [
            "Move to the end of the file"
          ]
        },
        {
          "name": "external",
          "tip": [
            "Move to a separate file and link"
          ]
        },
        {
          "name": "inline",
          "tip": [
            "Preserve in the original location"
          ]
        },
        {
          "name": "linked",
          "tip": [
            "Move to a separate file"
          ]
        },
        {
          "name": "none",
          "tip": [
            "Omit all legal comments"
          ]
        }
      ]
    },
    {
      "name": "--line-limit",
      "tip": [
        "U: --line-limit=<CHARS>",
        "Lines longer than this will be wrapped onto a new line"
      ],
      "next": 0
    },
    {
      "name": "--loader:X=L",
      "alias": [
        "--loader"
