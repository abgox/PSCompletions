        },
        {
          "name": "binary",
          "tip": [
            "Binary data"
          ]
        },
        {
          "name": "copy",
          "tip": [
            "Copy file to output and return URL"
          ]
        },
        {
          "name": "css",
          "tip": [
            "CSS"
          ]
        },
        {
          "name": "dataurl",
          "tip": [
            "Data URL"
          ]
        },
        {
          "name": "empty",
          "tip": [
            "Empty content"
          ]
        },
        {
          "name": "file",
          "tip": [
            "File loader"
          ]
        },
        {
          "name": "global-css",
          "tip": [
            "Global CSS (no modules)"
          ]
        },
        {
          "name": "js",
          "tip": [
            "JavaScript"
          ]
        },
        {
          "name": "json",
          "tip": [
            "JSON"
          ]
        },
        {
          "name": "jsx",
          "tip": [
            "JSX (React)"
          ]
        },
        {
          "name": "local-css",
          "tip": [
            "CSS Modules"
          ]
        },
        {
          "name": "text",
          "tip": [
            "Text content"
          ]
        },
        {
          "name": "ts",
          "tip": [
            "TypeScript"
          ]
        },
        {
          "name": "tsx",
          "tip": [
            "TypeScript JSX"
          ]
        }
      ]
    },
    {
      "name": "--log-level",
      "tip": [
        "U: --log-level=<LEVEL>",
        "Disable logging (default info)"
      ],
      "next": [
        {
          "name": "debug",
          "tip": [
            "Show debug and above"
          ]
        },
        {
          "name": "error",
          "tip": [
            "Show errors only"
          ]
        },
        {
          "name": "info",
          "tip": [
            "Show info and above (default)"
          ]
        },
        {
          "name": "silent",
          "tip": [
            "Disable all logging"
          ]
        },
        {
          "name": "verbose",
          "tip": [
            "Show all log messages"
          ]
        },
        {
          "name": "warning",
          "tip": [
            "Show warnings and errors only"
          ]
        }
      ]
    },
    {
      "name": "--log-limit",
      "tip": [
        "U: --log-limit=<N>",
        "Maximum message count or 0 to disable (default 6)"
