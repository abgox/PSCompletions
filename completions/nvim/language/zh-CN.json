{
  "meta": {
    "url": "https://neovim.io/",
    "description": [
      "nvim - 专注于可扩展性和易用性的 Vim 分支。"
    ]
  },
  "option": [
    {
      "name": "--api-info",
      "tip": [
        "将 msgpack 编码的 API 元数据写入 stdout。"
      ]
    },
    {
      "name": "--clean",
      "tip": [
        "恢复出厂设置（跳过用户配置和插件，shada）。"
      ]
    },
    {
      "name": "--embed",
      "tip": [
        "使用 stdin/stdout 作为 msgpack-rpc 通道。"
      ]
    },
    {
      "name": "--headless",
      "tip": [
        "不启动用户界面。"
      ]
    },
    {
      "name": "--listen",
      "tip": [
        "U: --listen <address>",
        "从此地址提供 RPC API。",
        "E: --listen /tmp/nvim.sock"
      ],
      "next": 0
    },
    {
      "name": "--remote",
      "tip": [
        "在服务器上远程执行命令。"
      ]
    },
    {
      "name": "--server",
      "tip": [
        "U: --server <address>",
        "连接到此 Nvim 服务器。",
        "E: --server /tmp/nvim.sock"
      ],
      "next": 0
    },
    {
      "name": "--startuptime",
      "tip": [
        "U: --startuptime <file>",
        "将启动计时信息写入 <file>。",
        "E: --startuptime startup.log"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "打印版本信息。"
      ]
    },
    {
      "name": "-c",
      "tip": [
        "U: -c <cmd>",
        "在配置和第一个文件之后执行 <cmd>。",
        "E: -c 'set number'"
      ],
      "next": 0
    },
    {
      "name": "-d",
      "tip": [
        "差异模式。"
      ]
    },
    {
      "name": "-es",
      "tip": [
        "静默（批处理）模式。"
      ]
    },
    {
      "name": "-i",
      "tip": [
        "U: -i <shada>",
        "使用此 shada 文件。",
        "E: -i shada"
      ],
      "next": 0
    },
    {
      "name": "-l",
      "tip": [
        "U: -l <script> [args...]",
        "执行 Lua <script>（可选参数）。",
        "E: -l init.lua"
      ],
      "next": 0
    },
    {
      "name": "-n",
      "tip": [
        "不使用交换文件，仅使用内存。"
      ]
    },
    {
      "name": "-o",
      "tip": [
        "U: -o[N]",
        "打开 N 个窗口（默认：每个文件一个）。",
        "E: -o3"
      ],
      "next": 0
    },
    {
      "name": "-O",
      "tip": [
        "U: -O[N]",
        "打开 N 个垂直窗口（默认：每个文件一个）。",
        "E: -O3"
      ],
      "next": 0
    },
    {
      "name": "-p",
      "tip": [
        "U: -p[N]",
        "打开 N 个标签页（默认：每个文件一个）。",
        "E: -p3"
      ],
      "next": 0
    },
    {
      "name": "-R",
      "tip": [
        "只读（查看）模式。"
      ]
    },
    {
      "name": "-s",
      "tip": [
        "U: -s <scriptin>",
        "从 <scriptin> 读取普通模式命令。",
        "E: -s scriptin"
      ],
      "next": 0
    },
    {
      "name": "-S",
      "tip": [
        "U: -S <session>",
        "加载第一个文件后源 <session>。",
        "E: -S Session.vim"
      ],
      "next": 0
    },
    {
      "name": "-u",
      "tip": [
        "U: -u <config>",
        "使用此配置文件。",
        "E: -u NONE"
      ],
      "next": 0
    },
    {
      "name": "-V",
      "tip": [
        "U: -V[N][file]",
        "详细输出 [级别][文件]。",
        "E: -V9mylog.txt"
      ],
      "next": 0
    },
    {
      "name": "+",
      "tip": [
        "U: +<cmd>",
        "在配置和第一个文件之后执行 <cmd>。",
        "E: +10"
      ],
      "next": 0
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息。"
      ]
    }
  ]
}
