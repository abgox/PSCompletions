{
  "meta": {
    "url": "https://neovim.io/",
    "description": [
      "Vim-fork focused on extensibility and usability."
    ]
  },
  "option": [
    {
      "name": "--api-info",
      "tip": [
        "Write msgpack-encoded API metadata to stdout."
      ]
    },
    {
      "name": "--clean",
      "tip": [
        "\"Factory defaults\" (skip user config and plugins, shada)."
      ]
    },
    {
      "name": "--embed",
      "tip": [
        "Use stdin/stdout as a msgpack-rpc channel."
      ]
    },
    {
      "name": "--headless",
      "tip": [
        "Don't start a user interface."
      ]
    },
    {
      "name": "--listen",
      "tip": [
        "U: --listen <address>",
        "Serve RPC API from this address.",
        "E: --listen /tmp/nvim.sock"
      ],
      "next": 0
    },
    {
      "name": "--remote",
      "tip": [
        "Execute commands remotely on a server."
      ]
    },
    {
      "name": "--server",
      "tip": [
        "U: --server <address>",
        "Connect to this Nvim server.",
        "E: --server /tmp/nvim.sock"
      ],
      "next": 0
    },
    {
      "name": "--startuptime",
      "tip": [
        "U: --startuptime <file>",
        "Write startup timing messages to <file>.",
        "E: --startuptime startup.log"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Print version information."
      ]
    },
    {
      "name": "-c",
      "tip": [
        "U: -c <cmd>",
        "Execute <cmd> after config and first file.",
        "E: -c 'set number'"
      ],
      "next": 0
    },
    {
      "name": "-d",
      "tip": [
        "Diff mode."
      ]
    },
    {
      "name": "-es",
      "tip": [
        "Silent (batch) mode."
      ]
    },
    {
      "name": "-i",
      "tip": [
        "U: -i <shada>",
        "Use this shada file.",
        "E: -i shada"
      ],
      "next": 0
    },
    {
      "name": "-l",
      "tip": [
        "U: -l <script> [args...]",
        "Execute Lua <script> with optional args.",
        "E: -l init.lua"
      ],
      "next": 0
    },
    {
      "name": "-n",
      "tip": [
        "No swap file, use memory only."
      ]
    },
    {
      "name": "-o",
      "tip": [
        "U: -o[N]",
        "Open N windows (default: one per file).",
        "E: -o3"
      ],
      "next": 0
    },
    {
      "name": "-O",
      "tip": [
        "U: -O[N]",
        "Open N vertical windows (default: one per file).",
        "E: -O3"
      ],
      "next": 0
    },
    {
      "name": "-p",
      "tip": [
        "U: -p[N]",
        "Open N tab pages (default: one per file).",
        "E: -p3"
      ],
      "next": 0
    },
    {
      "name": "-R",
      "tip": [
        "Read-only (view) mode."
      ]
    },
    {
      "name": "-s",
      "tip": [
        "U: -s <scriptin>",
        "Read Normal mode commands from <scriptin>.",
        "E: -s scriptin"
      ],
      "next": 0
    },
    {
      "name": "-S",
      "tip": [
        "U: -S <session>",
        "Source <session> after loading the first file.",
        "E: -S Session.vim"
      ],
      "next": 0
    },
    {
      "name": "-u",
      "tip": [
        "U: -u <config>",
        "Use this config file.",
        "E: -u NONE"
      ],
      "next": 0
    },
    {
      "name": "-V",
      "tip": [
        "U: -V[N][file]",
        "Verbose [level][file].",
        "E: -V9mylog.txt"
      ],
      "next": 0
    },
    {
      "name": "+",
      "tip": [
        "U: +<cmd>",
        "Execute <cmd> after config and first file.",
        "E: +10"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print this help message."
      ]
    }
  ]
}
