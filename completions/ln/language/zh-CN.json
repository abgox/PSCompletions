{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "创建文件之间的链接。"
    ]
  },
  "option": [
    {
      "name": "--backup",
      "tip": [
        "U: --backup[=<CONTROL>]",
        "为每个现有目标文件创建备份"
      ]
    },
    {
      "name": "--force",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --force",
        "移除现有目标文件"
      ]
    },
    {
      "name": "--interactive",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --interactive",
        "提示是否移除现有目标文件"
      ]
    },
    {
      "name": "--logical",
      "alias": [
        "-L"
      ],
      "tip": [
        "U: -L, --logical",
        "跟踪作为符号链接的 TARGET"
      ]
    },
    {
      "name": "--no-dereference",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --no-dereference",
        "如果 LINK_NAME 是指向目录的符号链接，则将其视为普通文件"
      ]
    },
    {
      "name": "--no-target-directory",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --no-target-directory",
        "始终将 LINK_NAME 视为普通文件"
      ]
    },
    {
      "name": "--physical",
      "alias": [
        "-P"
      ],
      "tip": [
        "U: -P, --physical",
        "直接对符号链接创建硬链接"
      ]
    },
    {
      "name": "--relative",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --relative",
        "创建相对于链接位置的符号链接"
      ]
    },
    {
      "name": "--suffix",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --suffix <SUFFIX>",
        "覆盖通常的备份后缀"
      ],
      "next": 0
    },
    {
      "name": "--symbolic",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --symbolic",
        "创建符号链接而非硬链接"
      ]
    },
    {
      "name": "--target-directory",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --target-directory <DIRECTORY>",
        "指定创建链接的 DIRECTORY"
      ],
      "next": 0
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --verbose",
        "打印每个链接文件的名称"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    },
    {
      "name": "-b",
      "tip": [
        "类似 --backup 但不接受参数"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
