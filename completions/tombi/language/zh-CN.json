{
  "meta": {
    "url": "https://tombi-toml.github.io/tombi/",
    "description": [
      "TOML 工具包"
    ]
  },
  "next": [
    {
      "name": "completion",
      "tip": [
        "U: completion <SHELL>",
        "生成 shell 自动补全脚本"
      ],
      "next": [
        {
          "name": "bash",
          "tip": [
            "生成 bash 自动补全脚本"
          ]
        },
        {
          "name": "elvish",
          "tip": [
            "生成 elvish 自动补全脚本"
          ]
        },
        {
          "name": "fish",
          "tip": [
            "生成 fish 自动补全脚本"
          ]
        },
        {
          "name": "powershell",
          "tip": [
            "生成 powershell 自动补全脚本"
          ]
        },
        {
          "name": "zsh",
          "tip": [
            "生成 zsh 自动补全脚本"
          ]
        }
      ]
    },
    {
      "name": "format",
      "tip": [
        "格式化 TOML 文件"
      ],
      "option": [
        {
          "name": "--check",
          "tip": [
            "仅检查，不覆盖文件"
          ]
        },
        {
          "name": "--diff",
          "tip": [
            "显示格式化变更"
          ]
        },
        {
          "name": "--no-cache",
          "tip": [
            "不使用缓存"
          ]
        },
        {
          "name": "--offline",
          "tip": [
            "禁用网络访问"
          ]
        },
        {
          "name": "--quiet",
          "tip": [
            "静默模式"
          ]
        },
        {
          "name": "--stdin-filename",
          "tip": [
            "U: --stdin-filename <STDIN_FILENAME>",
            "从 stdin 读取时使用的文件名"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "lint",
      "tip": [
        "检查 TOML 文件"
      ],
      "option": [
        {
          "name": "--error-on-warnings",
          "tip": [
            "遇到警告时退出并返回错误码"
          ]
        },
        {
          "name": "--no-cache",
          "tip": [
            "不使用缓存"
          ]
        },
        {
          "name": "--offline",
          "tip": [
            "禁用网络访问"
          ]
        },
        {
          "name": "--quiet",
          "tip": [
            "静默模式"
          ]
        },
        {
          "name": "--stdin-filename",
          "tip": [
            "U: --stdin-filename <STDIN_FILENAME>",
            "从 stdin 读取时使用的文件名"
          ],
          "next": 0
        }
      ]
    },
    {
      "name": "lsp",
      "tip": [
        "运行 TOML 语言服务器"
      ],
      "option": [
        {
          "name": "--no-cache",
          "tip": [
            "不使用缓存"
          ]
        },
        {
          "name": "--offline",
          "tip": [
            "禁用网络访问"
          ]
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "更改日志级别",
        "-v: DEBUG, -vv: TRACE"
      ],
      "repeat": 2
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本信息"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助信息"
      ]
    }
  ]
}
