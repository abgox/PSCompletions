{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "显示或设置系统日期和时间。"
    ]
  },
  "option": [
    {
      "name": "--date",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --date <STRING>",
        "显示 STRING 描述的时间，而不是当前时间"
      ],
      "next": [
        {
          "name": "now"
        }
      ]
    },
    {
      "name": "--debug",
      "tip": [
        "标注解析的日期，并对可疑用法向 stderr 发出警告"
      ]
    },
    {
      "name": "--file",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --file <DATEFILE>",
        "类似 --date；对 DATEFILE 的每一行执行一次"
      ],
      "next": 0
    },
    {
      "name": "--iso-8601",
      "alias": [
        "-I"
      ],
      "tip": [
        "U: -I, --iso-8601 [<FMT>]",
        "以 ISO 8601 格式输出日期/时间。",
        "FMT='date' 表示仅输出日期（默认）",
        "'hours'、'minutes'、'seconds' 或 'ns' 表示输出指定精度的日期和时间。"
      ],
      "next": [
        {
          "name": "date",
          "tip": [
            "默认值"
          ]
        },
        {
          "name": "hours"
        },
        {
          "name": "minutes"
        },
        {
          "name": "ns"
        },
        {
          "name": "seconds"
        }
      ]
    },
    {
      "name": "--reference",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --reference <FILE>",
        "显示 FILE 的最后修改时间"
      ],
      "next": 0
    },
    {
      "name": "--resolution",
      "tip": [
        "输出时间戳的可用精度",
        "示例: 0.000000001"
      ]
    },
    {
      "name": "--rfc-3339",
      "tip": [
        "U: --rfc-3339 <FMT>",
        "以 RFC 3339 格式输出日期/时间。",
        "FMT='date'、'seconds' 或 'ns' 表示输出指定精度的日期和时间。",
        "示例: 2006-08-14 02:34:56-06:00"
      ],
      "next": [
        {
          "name": "date"
        },
        {
          "name": "ns"
        },
        {
          "name": "seconds"
        }
      ]
    },
    {
      "name": "--rfc-email",
      "alias": [
        "-R"
      ],
      "tip": [
        "U: -R, --rfc-email",
        "以 RFC 5322 格式输出日期和时间。",
        "示例: Mon, 14 Aug 2006 02:34:56 -0600"
      ]
    },
    {
      "name": "--set",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --set <STRING>",
        "设置 STRING 描述的时间"
      ]
    },
    {
      "name": "--universal",
      "alias": [
        "--utc",
        "-u"
      ],
      "tip": [
        "U: --utc, -u, --universal",
        "打印或设置协调世界时（UTC）"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
