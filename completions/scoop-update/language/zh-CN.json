{
  "meta": {
    "url": "https://gitee.com/abgox/scoop-tools",
    "description": [
      "一个 PowerShell 脚本，它允许你添加 Scoop 配置，在 Scoop 更新应用时使用替换后的 url 而不是原始的 url。"
    ]
  },
  "common_option": [
    {
      "name": "--all",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --all",
        "更新所有应用（'*' 的替代方式）"
      ]
    },
    {
      "name": "--force",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --force",
        "强制更新，即使没有新版本"
      ]
    },
    {
      "name": "--global",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --global",
        "更新全局安装的应用"
      ]
    },
    {
      "name": "--independent",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --independent",
        "不自动安装依赖"
      ]
    },
    {
      "name": "--no-cache",
      "alias": [
        "-k"
      ],
      "tip": [
        "U: -k, --no-cache",
        "不使用下载缓存"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "隐藏多余的消息"
      ]
    },
    {
      "name": "--skip-hash-check",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --skip-hash-check",
        "跳过哈希验证（谨慎使用！）"
      ]
    }
  ],
  "info": {
    "tip": {
      "warning": {
        "config": "Scoop 未配置 root_path, 请先进行配置: scoop config root_path <scoop_path>"
      }
    }
  }
}
