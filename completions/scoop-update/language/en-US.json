{
  "meta": {
    "url": "https://github.com/abgox/scoop-tools",
    "description": [
      "A PowerShell script that allows you to temporarily use the replaced proxy URL to download app packages."
    ]
  },
  "global_option": [
    {
      "name": "--all",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --all",
        "Update all apps (alternative to '*')"
      ]
    },
    {
      "name": "--force",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --force",
        "Force update even when there isn't a newer version"
      ]
    },
    {
      "name": "--global",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --global",
        "Update a globally installed app"
      ]
    },
    {
      "name": "--independent",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --independent",
        "Don't install dependencies automatically"
      ]
    },
    {
      "name": "--no-cache",
      "alias": [
        "-k"
      ],
      "tip": [
        "U: -k, --no-cache",
        "Don't use the download cache"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: -q, --quiet",
        "Hide extraneous messages"
      ]
    },
    {
      "name": "--skip-hash-check",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --skip-hash-check",
        "Skip hash validation (use with caution!)"
      ]
    }
  ],
  "info": {
    "tip": {
      "warning": {
        "config": "Scoop does not have a root_path configuration. Please set it first: scoop config root_path <scoop_path>"
      }
    }
  }
}
