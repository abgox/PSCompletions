{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "计算并校验消息摘要。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--b2sum",
      "tip": [
        "使用 BLAKE2 算法"
      ]
    },
    {
      "name": "--b3sum",
      "tip": [
        "使用 BLAKE3 算法"
      ]
    },
    {
      "name": "--binary",
      "alias": [
        "-b"
      ],
      "tip": [
        "以二进制模式读取（默认）"
      ]
    },
    {
      "name": "--bits",
      "tip": [
        "U: --bits <BITS>",
        "设置输出大小（仅限 SHAKE）"
      ],
      "next": 0
    },
    {
      "name": "--check",
      "alias": [
        "-c"
      ],
      "tip": [
        "从文件中读取哈希值并校验"
      ]
    },
    {
      "name": "--ignore-missing",
      "tip": [
        "忽略缺失的文件，不报错或报告状态"
      ]
    },
    {
      "name": "--md5",
      "tip": [
        "使用 MD5 算法"
      ]
    },
    {
      "name": "--no-names",
      "tip": [
        "输出中省略文件名（GNU/Coreutils 中不存在此选项）"
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "成功校验时不打印 OK"
      ]
    },
    {
      "name": "--sha1",
      "tip": [
        "使用 SHA1 算法"
      ]
    },
    {
      "name": "--sha224",
      "tip": [
        "使用 SHA224 算法"
      ]
    },
    {
      "name": "--sha256",
      "tip": [
        "使用 SHA256 算法"
      ]
    },
    {
      "name": "--sha3",
      "tip": [
        "使用 SHA3 算法"
      ]
    },
    {
      "name": "--sha3-224",
      "tip": [
        "使用 SHA3-224 算法"
      ]
    },
    {
      "name": "--sha3-256",
      "tip": [
        "使用 SHA3-256 算法"
      ]
    },
    {
      "name": "--sha3-384",
      "tip": [
        "使用 SHA3-384 算法"
      ]
    },
    {
      "name": "--sha3-512",
      "tip": [
        "使用 SHA3-512 算法"
      ]
    },
    {
      "name": "--sha384",
      "tip": [
        "使用 SHA384 算法"
      ]
    },
    {
      "name": "--sha512",
      "tip": [
        "使用 SHA512 算法"
      ]
    },
    {
      "name": "--shake128",
      "tip": [
        "使用 SHAKE128 算法，输出大小由 --bits 指定"
      ]
    },
    {
      "name": "--shake256",
      "tip": [
        "使用 SHAKE256 算法，输出大小由 --bits 指定"
      ]
    },
    {
      "name": "--status",
      "alias": [
        "-s"
      ],
      "tip": [
        "不输出任何内容，通过状态码表示成功"
      ]
    },
    {
      "name": "--strict",
      "tip": [
        "遇到格式错误的校验行时返回非零退出码"
      ]
    },
    {
      "name": "--tag",
      "tip": [
        "创建 BSD 风格的校验和"
      ]
    },
    {
      "name": "--text",
      "alias": [
        "-t"
      ],
      "tip": [
        "以文本模式读取"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息"
      ]
    },
    {
      "name": "--warn",
      "alias": [
        "-w"
      ],
      "tip": [
        "对格式错误的校验行发出警告"
      ]
    },
    {
      "name": "--zero",
      "alias": [
        "-z"
      ],
      "tip": [
        "以 NUL 而非换行符结束每行输出"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息"
      ]
    }
  ]
}
