{
  "meta": {
    "url": "https://www.openssh.com",
    "description": [
      "OpenSSH 密钥生成工具。"
    ]
  },
  "option": [
    {
      "name": "-a",
      "tip": [
        "U: -a <rounds>",
        "从密码短语派生新密钥时的 KDF 轮数。"
      ],
      "next": 0
    },
    {
      "name": "-A",
      "tip": [
        "生成所有默认主机密钥类型 (dsa, ecdsa, ed25519, rsa)。"
      ]
    },
    {
      "name": "-b",
      "tip": [
        "U: -b <bits>",
        "要创建的密钥位数（RSA 默认 3072，ECDSA/ED25519 默认 256）。"
      ],
      "next": 0
    },
    {
      "name": "-B",
      "tip": [
        "显示密钥的 bubblebabble 摘要。"
      ]
    },
    {
      "name": "-c",
      "tip": [
        "更改私钥和公钥文件中的注释。"
      ]
    },
    {
      "name": "-C",
      "tip": [
        "U: -C <comment>",
        "提供新的注释。"
      ],
      "next": 0
    },
    {
      "name": "-D",
      "tip": [
        "U: -D <pkcs11>",
        "下载 PKCS#11 令牌提供的公钥。"
      ],
      "next": 0
    },
    {
      "name": "-e",
      "tip": [
        "将私钥或公钥导出到文件。"
      ]
    },
    {
      "name": "-E",
      "tip": [
        "U: -E <fingerprint_hash>",
        "显示指纹时使用的哈希算法。"
      ],
      "next": [
        {
          "name": "md5"
        },
        {
          "name": "sha256"
        }
      ]
    },
    {
      "name": "-f",
      "tip": [
        "U: -f <filename>",
        "指定密钥文件的文件名。"
      ],
      "next": 0
    },
    {
      "name": "-F",
      "tip": [
        "U: -F <hostname>",
        "在 known_hosts 文件中搜索主机。"
      ],
      "next": 0
    },
    {
      "name": "-g",
      "tip": [
        "打印资源记录时使用通用 DNS 格式。"
      ]
    },
    {
      "name": "-h",
      "tip": [
        "签名密钥时，创建主机证书而非用户证书。"
      ]
    },
    {
      "name": "-H",
      "tip": [
        "哈希 known_hosts 文件。"
      ]
    },
    {
      "name": "-i",
      "tip": [
        "读取未加密的私钥（或公钥）文件并将公钥打印到标准输出。"
      ]
    },
    {
      "name": "-I",
      "tip": [
        "U: -I <identity>",
        "身份（证书）。服务器记录的唯一标识符。"
      ],
      "next": 0
    },
    {
      "name": "-k",
      "tip": [
        "生成 KRL（密钥撤销列表）文件。"
      ]
    },
    {
      "name": "-K",
      "tip": [
        "从 KDC（密钥分发中心）下载主机密钥。"
      ]
    },
    {
      "name": "-l",
      "tip": [
        "显示公钥文件的指纹。"
      ]
    },
    {
      "name": "-L",
      "tip": [
        "打印证书内容。"
      ]
    },
    {
      "name": "-m",
      "tip": [
        "U: -m <key_format>",
        "导入或导出密钥时指定密钥格式。"
      ],
      "next": [
        {
          "name": "PEM",
          "tip": [
            "PEM 格式。"
          ]
        },
        {
          "name": "PKCS8",
          "tip": [
            "PKCS#8 格式。"
          ]
        },
        {
          "name": "RFC1421",
          "tip": [
            "RFC1421 格式（已弃用）。"
          ]
        },
        {
          "name": "RFC4716",
          "tip": [
            "RFC 4716 格式。"
          ]
        }
      ]
    },
    {
      "name": "-M",
      "tip": [
        "U: -M <generate|screen>",
        "模数生成或筛选操作。"
      ],
      "next": [
        {
          "name": "generate",
          "tip": [
            "生成候选 DH（Diffie-Hellman）素数。"
          ]
        },
        {
          "name": "screen",
          "tip": [
            "筛选候选 DH 素数以确保安全性。"
          ]
        }
      ]
    },
    {
      "name": "-n",
      "tip": [
        "U: -n <principals>",
        "指定证书的主体（用户或主机名）。"
      ],
      "next": 0
    },
    {
      "name": "-N",
      "tip": [
        "U: -N <new_passphrase>",
        "提供新的密码短语。"
      ],
      "next": 0
    },
    {
      "name": "-O",
      "tip": [
        "U: -O <option>",
        "指定密钥或证书选项。"
      ],
      "next": 0
    },
    {
      "name": "-p",
      "tip": [
        "更改私钥文件的密码短语。"
      ]
    },
    {
      "name": "-P",
      "tip": [
        "U: -P <passphrase>",
        "提供旧的密码短语。"
      ],
      "next": 0
    },
    {
      "name": "-q",
      "tip": [
        "静默 ssh-keygen。"
      ]
    },
    {
      "name": "-Q",
      "tip": [
        "测试 KRL 是否由指定的 CA 签名。"
      ]
    },
    {
      "name": "-r",
      "tip": [
        "U: -r <hostname>",
        "打印 DNS 资源记录。"
      ],
      "next": 0
    },
    {
      "name": "-R",
      "tip": [
        "U: -R <hostname>",
        "从 known_hosts 文件中删除属于某个主机名的所有密钥。"
      ],
      "next": 0
    },
    {
      "name": "-s",
      "tip": [
        "U: -s <ca_key>",
        "用于签名或验证的 CA 密钥。"
      ],
      "next": 0
    },
    {
      "name": "-t",
      "tip": [
        "U: -t <type>",
        "指定要创建的密钥类型。"
      ],
      "next": [
        {
          "name": "dsa",
          "tip": [
            "数字签名算法。"
          ]
        },
        {
          "name": "ecdsa",
          "tip": [
            "椭圆曲线数字签名算法。"
          ]
        },
        {
          "name": "ecdsa-sk",
          "tip": [
            "使用安全密钥的 ECDSA (FIDO2)。"
          ]
        },
        {
          "name": "ed25519",
          "tip": [
            "ED25519 密钥。"
          ]
        },
        {
          "name": "ed25519-sk",
          "tip": [
            "使用安全密钥的 ED25519 (FIDO2)。"
          ]
        },
        {
          "name": "rsa",
          "tip": [
            "RSA 密钥。"
          ]
        }
      ]
    },
    {
      "name": "-U",
      "tip": [
        "指示使用 CA 密钥签署主机证书而非用户证书。"
      ]
    },
    {
      "name": "-v",
      "tip": [
        "详细模式。"
      ]
    },
    {
      "name": "-V",
      "tip": [
        "U: -V <validity_interval>",
        "指定证书的有效期。"
      ],
      "next": 0
    },
    {
      "name": "-w",
      "tip": [
        "U: -w <provider>",
        "指定密钥操作的提供者。"
      ],
      "next": 0
    },
    {
      "name": "-y",
      "tip": [
        "读取私钥文件并将对应的公钥打印到标准输出。"
      ]
    },
    {
      "name": "-Y",
      "tip": [
        "U: -Y <operation>",
        "SSH 签名操作。"
      ],
      "next": [
        {
          "name": "check-novalidate",
          "tip": [
            "检查签名但不验证。"
          ]
        },
        {
          "name": "find-principals",
          "tip": [
            "查找签名中的主体。"
          ]
        },
        {
          "name": "match-principals",
          "tip": [
            "查找签名者身份允许的主体。"
          ]
        },
        {
          "name": "sign",
          "tip": [
            "使用 SSH 签名签署文件。"
          ]
        },
        {
          "name": "verify",
          "tip": [
            "验证签名。"
          ]
        }
      ]
    },
    {
      "name": "-z",
      "tip": [
        "U: -z <serial_number>",
        "指定证书的序列号。"
      ],
      "next": 0
    },
    {
      "name": "-Z",
      "tip": [
        "U: -Z <cipher>",
        "指定用于加密私钥的密码。"
      ],
      "next": [
        {
          "name": "aes128-cbc"
        },
        {
          "name": "aes128-ctr"
        },
        {
          "name": "aes192-cbc"
        },
        {
          "name": "aes192-ctr"
        },
        {
          "name": "aes256-cbc"
        },
        {
          "name": "aes256-ctr"
        }
      ]
    }
  ]
}
