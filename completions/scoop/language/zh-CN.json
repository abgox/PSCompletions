    {
      "name": "cache",
      "tip": [
        "U: cache show, rm [<app>] [<app>...]",
        "管理下载缓存",
        "E: cache                --- 显示所有下载缓存",
        "   cache show 7zip      --- 显示 7zip 的下载缓存",
        "   cache rm 7zip sudo   --- 移除 7zip sudo 的下载缓存"
      ],
      "next": [
        {
          "name": "rm",
          "tip": [
            "移除指定应用程序的下载缓存",
            "E: rm *     --- 移除所有下载缓存",
            "   rm 7zip  --- 移除 7zip 的下载缓存"
          ],
          "next": [
            {
              "name": "*",
              "tip": [
                "移除所有下载缓存"
              ]
            }
          ]
        },
        {
          "name": "show",
          "tip": [
            "显示下载缓存",
            "E: show 7zip"
          ]
        }
      ]
    },
