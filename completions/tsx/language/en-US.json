{
  "meta": {
    "url": "https://tsx.hirok.io",
    "description": [
      "TypeScript Execute. The easiest way to run TypeScript in Node.js."
    ]
  },
  "next": [
    {
      "name": "watch",
      "tip": [
        "Run the script and watch for changes."
      ],
      "option": [
        {
          "name": "--clear-screen",
          "tip": [
            "Clearing the screen on rerun (default: true)."
          ]
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <string>",
            "Paths & globs to exclude from being watched."
          ],
          "next": 0
        },
        {
          "name": "--ignore",
          "tip": [
            "U: --ignore <string>",
            "Paths & globs to exclude from being watched (Deprecated: use --exclude)."
          ],
          "next": 0
        },
        {
          "name": "--include",
          "tip": [
            "U: --include <string>",
            "Additional paths & globs to watch."
          ],
          "next": 0
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--no-cache",
      "tip": [
        "Disable caching."
      ]
    },
    {
      "name": "--tsconfig",
      "tip": [
        "U: --tsconfig <string>",
        "Custom tsconfig.json path."
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show help."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "Show version."
      ]
    }
  ]
}
