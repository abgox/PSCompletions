{
  "meta": {
    "url": "https://tsx.hirok.io",
    "description": [
      "TypeScript Execute。在 Node.js 中运行 TypeScript 的最简单方式。"
    ]
  },
  "next": [
    {
      "name": "watch",
      "tip": [
        "运行脚本并监视更改。"
      ],
      "option": [
        {
          "name": "--clear-screen",
          "tip": [
            "重新运行时清屏（默认：true）。"
          ]
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <string>",
            "要排除监视的路径和 glob 模式。"
          ],
          "next": 0
        },
        {
          "name": "--ignore",
          "tip": [
            "U: --ignore <string>",
            "要排除监视的路径和 glob 模式（已弃用：请使用 --exclude）。"
          ],
          "next": 0
        },
        {
          "name": "--include",
          "tip": [
            "U: --include <string>",
            "要监视的附加路径和 glob 模式。"
          ],
          "next": 0
        }
      ]
    }
  ],
  "option": [
    {
      "name": "--no-cache",
      "tip": [
        "禁用缓存。"
      ]
    },
    {
      "name": "--tsconfig",
      "tip": [
        "U: --tsconfig <string>",
        "自定义 tsconfig.json 路径。"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --version",
        "显示版本信息。"
      ]
    }
  ]
}
