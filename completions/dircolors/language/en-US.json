{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Output commands to set the LS_COLORS environment variable."
    ]
  },
  "option": [
    {
      "name": "--bourne-shell",
      "alias": [
        "--sh",
        "-b"
      ],
      "tip": [
        "U: --sh, -b, --bourne-shell",
        "output Bourne shell code to set LS_COLORS"
      ]
    },
    {
      "name": "--c-shell",
      "alias": [
        "--csh",
        "-c"
      ],
      "tip": [
        "U: --csh, -c, --c-shell",
        "output C shell code to set LS_COLORS"
      ]
    },
    {
      "name": "--print-database",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --print-database",
        "print the byte counts"
      ]
    },
    {
      "name": "--print-ls-colors",
      "tip": [
        "output fully escaped colors for display"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Show the version."
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Show the help."
      ]
    }
  ]
}
