{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "输出设置 LS_COLORS 环境变量的命令。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--bourne-shell",
      "alias": [
        "--sh",
        "-b"
      ],
      "tip": [
        "输出设置 LS_COLORS 的 Bourne shell 代码"
      ]
    },
    {
      "name": "--c-shell",
      "alias": [
        "--csh",
        "-c"
      ],
      "tip": [
        "输出设置 LS_COLORS 的 C shell 代码"
      ]
    },
    {
      "name": "--print-database",
      "alias": [
        "-p"
      ],
      "tip": [
        "打印字节数"
      ]
    },
    {
      "name": "--print-ls-colors",
      "tip": [
        "输出完全转义的颜色以便显示"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
