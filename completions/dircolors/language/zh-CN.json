{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "输出设置 LS_COLORS 环境变量的命令。"
    ]
  },
  "option": [
    {
      "name": "--bourne-shell",
      "alias": [
        "--sh",
        "-b"
      ],
      "tip": [
        "U: --sh, -b, --bourne-shell",
        "输出设置 LS_COLORS 的 Bourne shell 代码"
      ]
    },
    {
      "name": "--c-shell",
      "alias": [
        "--csh",
        "-c"
      ],
      "tip": [
        "U: --csh, -c, --c-shell",
        "输出设置 LS_COLORS 的 C shell 代码"
      ]
    },
    {
      "name": "--print-database",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, --print-database",
        "打印字节数"
      ]
    },
    {
      "name": "--print-ls-colors",
      "tip": [
        "输出完全转义的颜色以便显示"
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "显示版本信息。"
      ]
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "显示帮助信息。"
      ]
    }
  ]
}
