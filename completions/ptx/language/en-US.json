{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "Output a permuted index of the words in the input files."
    ]
  },
  "option": [
    {
      "name": "--auto-reference",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --auto-reference",
        "output automatically generated references"
      ]
    },
    {
      "name": "--break-file",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --break-file=FILE",
        "word break characters in this FILE"
      ],
      "next": 0
    },
    {
      "name": "--flag-truncation",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --flag-truncation=STRING",
        "use STRING for flagging line truncations. The default is '/'"
      ],
      "next": 0
    },
    {
      "name": "--format=roff",
      "alias": [
        "-O"
      ],
      "tip": [
        "U: -O, --format=roff",
        "generate output as roff directives"
      ]
    },
    {
      "name": "--format=tex",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --format=tex",
        "generate output as TeX directives"
      ]
    },
    {
      "name": "--gap-size",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --gap-size=NUMBER",
        "gap size in columns between output fields"
      ],
      "next": 0
    },
    {
      "name": "--ignore-case",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --ignore-case",
        "fold lower case to upper case for sorting"
      ]
    },
    {
      "name": "--ignore-file",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore-file=FILE",
        "read ignore word list from FILE"
      ],
      "next": 0
    },
    {
      "name": "--macro-name",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --macro-name=STRING",
        "macro name to use instead of 'xx'"
      ],
      "next": 0
    },
    {
      "name": "--only-file",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --only-file=FILE",
        "read only word list from this FILE"
      ],
      "next": 0
    },
    {
      "name": "--references",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --references",
        "first field of each line is a reference"
      ]
    },
    {
      "name": "--right-side-refs",
      "alias": [
        "-R"
      ],
      "tip": [
        "U: -R, --right-side-refs",
        "put references at right, not counted in -w"
      ]
    },
    {
      "name": "--sentence-regexp",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --sentence-regexp=REGEXP",
        "for end of lines or end of sentences"
      ],
      "next": 0
    },
    {
      "name": "--traditional",
      "alias": [
        "-G"
      ],
      "tip": [
        "U: -G, --traditional",
        "behave more like System V 'ptx'"
      ]
    },
    {
      "name": "--typeset-mode",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --typeset-mode",
        "not implemented"
      ]
    },
    {
      "name": "--version",
      "tip": [
        "U: --version",
        "output version information and exit"
      ]
    },
    {
      "name": "--width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --width=NUMBER",
        "output width in columns, reference excluded"
      ],
      "next": 0
    },
    {
      "name": "--word-regexp",
      "alias": [
        "-W"
      ],
      "tip": [
        "U: -W, --word-regexp=REGEXP",
        "use REGEXP to match each keyword"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "tip": [
        "U: --help",
        "display this help and exit"
      ]
    }
  ]
}
