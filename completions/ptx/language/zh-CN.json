{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "输出输入文件中单词的排列索引。"
    ]
  },
  "option": [
    {
      "name": "--auto-reference",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --auto-reference",
        "输出自动生成的引用"
      ]
    },
    {
      "name": "--break-file",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --break-file=FILE",
        "单词分隔符在此 FILE 中"
      ],
      "next": 0
    },
    {
      "name": "--flag-truncation",
      "alias": [
        "-F"
      ],
      "tip": [
        "U: -F, --flag-truncation=STRING",
        "使用 STRING 标记行截断，默认为 '/'"
      ],
      "next": 0
    },
    {
      "name": "--format=roff",
      "alias": [
        "-O"
      ],
      "tip": [
        "U: -O, --format=roff",
        "生成 roff 指令格式的输出"
      ]
    },
    {
      "name": "--format=tex",
      "alias": [
        "-T"
      ],
      "tip": [
        "U: -T, --format=tex",
        "生成 TeX 指令格式的输出"
      ]
    },
    {
      "name": "--gap-size",
      "alias": [
        "-g"
      ],
      "tip": [
        "U: -g, --gap-size=NUMBER",
        "输出字段之间的间隔列数"
      ],
      "next": 0
    },
    {
      "name": "--ignore-case",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --ignore-case",
        "排序时忽略大小写"
      ]
    },
    {
      "name": "--ignore-file",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --ignore-file=FILE",
        "从此 FILE 读取忽略词列表"
      ],
      "next": 0
    },
    {
      "name": "--macro-name",
      "alias": [
        "-M"
      ],
      "tip": [
        "U: -M, --macro-name=STRING",
        "使用 STRING 作为宏名，而不是 'xx'"
      ],
      "next": 0
    },
    {
      "name": "--only-file",
      "alias": [
        "-o"
      ],
      "tip": [
        "U: -o, --only-file=FILE",
        "从此 FILE 读取仅包含词列表"
      ],
      "next": 0
    },
    {
      "name": "--references",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, --references",
        "每行的第一个字段是引用"
      ]
    },
    {
      "name": "--right-side-refs",
      "alias": [
        "-R"
      ],
      "tip": [
        "U: -R, --right-side-refs",
        "将引用放在右侧，不计入 -w 宽度"
      ]
    },
    {
      "name": "--sentence-regexp",
      "alias": [
        "-S"
      ],
      "tip": [
        "U: -S, --sentence-regexp=REGEXP",
        "用于行尾或句子结尾的正则表达式"
      ],
      "next": 0
    },
    {
      "name": "--traditional",
      "alias": [
        "-G"
      ],
      "tip": [
        "U: -G, --traditional",
        "行为更像 System V 'ptx'"
      ]
    },
    {
      "name": "--typeset-mode",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: -t, --typeset-mode",
        "未实现"
      ]
    },
    {
      "name": "--version",
      "tip": [
        "U: --version",
        "输出版本信息并退出"
      ]
    },
    {
      "name": "--width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --width=NUMBER",
        "输出宽度（列数），不包括引用"
      ],
      "next": 0
    },
    {
      "name": "--word-regexp",
      "alias": [
        "-W"
      ],
      "tip": [
        "U: -W, --word-regexp=REGEXP",
        "使用 REGEXP 匹配每个关键词"
      ],
      "next": 0
    }
  ],
  "global_option": [
    {
      "name": "--help",
      "tip": [
        "U: --help",
        "显示此帮助信息并退出"
      ]
    }
  ]
}
