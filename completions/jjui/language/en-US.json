{
  "meta": {
    "url": "https://idursun.github.io/jjui/",
    "description": [
      "Text User Interface for the Jujutsu version control system."
    ]
  },
  "global_option": [
    {
      "name": "-config",
      "tip": [
        "Open configuration file in $EDITOR"
      ]
    },
    {
      "name": "-help",
      "tip": [
        "Show the help."
      ]
    },
    {
      "name": "-install-lua-types",
      "tip": [
        "Write Lua type definitions to config directory for LuaLS autocomplete"
      ]
    },
    {
      "name": "-limit",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, -limit <int>",
        "Number of revisions to show (default: 0)"
      ]
    },
    {
      "name": "-period",
      "alias": [
        "-p"
      ],
      "tip": [
        "U: -p, -period <int>",
        "Override auto-refresh interval (seconds, set to 0 to disable) (default -1)"
      ]
    },
    {
      "name": "-revset",
      "alias": [
        "-r"
      ],
      "tip": [
        "U: -r, -revset <string>",
        "Set default revset"
      ]
    },
    {
      "name": "-version",
      "tip": [
        "Show the version."
      ]
    }
  ]
}
