      "repeat": 99,
      "next": 0
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help"
      ]
    },
    {
      "name": "--hidden",
      "tip": [
        "Do not skip hidden directories and files"
      ]
    },
    {
      "name": "--include",
      "tip": [
        "U: --include <INCLUDE>",
