      "next": [
        {
          "name": "complete-bash",
          "tip": [
            "Generate Bash completion"
          ]
        },
        {
          "name": "complete-elvish",
          "tip": [
            "Generate Elvish completion"
          ]
        },
        {
          "name": "complete-fish",
          "tip": [
            "Generate Fish completion"
          ]
        },
        {
          "name": "complete-powershell",
          "tip": [
            "Generate PowerShell completion"
          ]
        },
        {
          "name": "complete-zsh",
          "tip": [
            "Generate Zsh completion"
          ]
        },
        {
          "name": "man",
          "tip": [
            "Generate man page"
          ]
        }
      ]
