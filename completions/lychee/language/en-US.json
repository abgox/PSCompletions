        {
          "name": "color",
          "tip": [
            "Colored output (default)"
          ]
        },
        {
          "name": "emoji",
          "tip": [
            "Emoji output"
          ]
        },
        {
          "name": "plain",
          "tip": [
            "Plain text"
          ]
        },
        {
          "name": "task",
          "tip": [
            "Task output"
          ]
        }
      ]
    },
