      "next": [
        {
          "name": "TLSv1_0",
          "tip": [
            "TLS 1.0"
          ]
        },
        {
          "name": "TLSv1_1",
          "tip": [
            "TLS 1.1"
          ]
        },
        {
          "name": "TLSv1_2",
          "tip": [
            "TLS 1.2"
          ]
        },
        {
          "name": "TLSv1_3",
          "tip": [
            "TLS 1.3"
          ]
        }
      ]
    },
    {
      "name": "--mode",
