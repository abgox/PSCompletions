{
  "meta": {
    "url": "https://github.com/lycheeverse/lychee",
    "description": [
      "A fast, asynchronous link checker",
      "Detects broken URLs and mail addresses in local files and websites"
    ]
  },
  "option": [
    {
      "name": "--accept",
      "alias": [
        "-a"
      ],
      "tip": [
        "U: -a, --accept <ACCEPT>",
        "A list of accepted status codes for valid links"
      ],
      "next": 0
    },
    {
      "name": "--accept-timeouts",
      "tip": [
        "Accept timed out requests and return exit code 0"
      ]
    },
    {
      "name": "--archive",
      "tip": [
        "U: --archive <ARCHIVE>",
        "Web archive to use for suggestions"
      ],
      "next": [
        {
          "name": "wayback",
          "tip": [
            "Wayback Machine"
          ]
        }
      ]
    },
    {
      "name": "--base-url",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --base-url <BASE_URL>",
        "Base URL for resolving relative URLs in local files"
      ],
      "next": 0
    },
    {
      "name": "--basic-auth",
      "tip": [
        "U: --basic-auth <BASIC_AUTH>",
        "Basic authentication support"
      ],
      "next": 0
    },
    {
      "name": "--cache",
      "tip": [
        "Use request cache stored on disk"
      ]
    },
    {
      "name": "--cache-exclude-status",
      "tip": [
        "U: --cache-exclude-status <STATUS>",
        "Status codes to exclude from cache"
      ],
      "next": 0
    },
    {
      "name": "--config",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --config <FILE>",
        "Configuration file to use"
      ],
      "next": 0
    },
    {
      "name": "--cookie-jar",
      "tip": [
        "U: --cookie-jar <COOKIE_JAR>",
        "Read and write cookies using the given file"
      ],
      "next": 0
    },
    {
      "name": "--dump",
      "tip": [
        "Don't check links, just dump all extracted links"
      ]
    },
    {
      "name": "--dump-inputs",
      "tip": [
        "Don't check links, just dump all input sources"
      ]
    },
    {
      "name": "--exclude",
      "tip": [
