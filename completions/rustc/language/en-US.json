{
  "meta": {
    "url": "https://doc.rust-lang.org/rustc",
    "description": [
      "The Rust compiler"
    ]
  },
  "option": [
    {
      "name": "--allow",
      "alias": [
        "-A"
      ],
      "tip": [
        "U: -A, --allow <LINT>",
        "Set lint allowed."
      ],
      "next": 0
    },
    {
      "name": "--cap-lints",
      "tip": [
        "U: --cap-lints <LEVEL>",
        "Set the most restrictive lint level.",
        "More restrictive lints are capped at this level."
      ],
      "next": [
        {
          "name": "allow",
          "tip": [
            "Cap at allow level"
          ]
        },
        {
          "name": "deny",
          "tip": [
            "Cap at deny level"
          ]
        },
        {
          "name": "forbid",
          "tip": [
            "Cap at forbid level"
          ]
        },
        {
          "name": "warn",
          "tip": [
            "Cap at warn level"
          ]
        }
      ]
    },
    {
      "name": "--cfg",
      "tip": [
        "U: --cfg <SPEC>",
        "Configure the compilation environment.",
        "SPEC supports the syntax `<NAME>=[\"<VALUE>\"]`."
      ],
      "next": 0
    },
    {
      "name": "--check-cfg",
      "tip": [
        "U: --check-cfg <SPEC>",
        "Provide list of expected cfgs for checking."
      ],
      "next": 0
    },
    {
      "name": "--codegen",
      "alias": [
        "-C"
      ],
      "tip": [
        "U: -C, --codegen <OPT>[=<VALUE>]",
        "Set a codegen option.",
        "Use -C help to list available options."
      ],
      "next": 0
    },
    {
      "name": "--color",
      "tip": [
        "U: --color <WHEN>",
        "Configure coloring of output."
      ],
      "next": [
        {
          "name": "always",
          "tip": [
            "Always colorize output"
          ]
        },
        {
          "name": "auto",
          "tip": [
            "Colorize if output goes to a tty (default)"
          ]
        },
        {
          "name": "never",
          "tip": [
            "Never colorize output"
          ]
        }
      ]
    },
    {
      "name": "--crate-name",
      "tip": [
        "U: --crate-name <NAME>",
