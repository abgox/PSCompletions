{
  "meta": {
    "url": "https://github.com/astral-sh/ruff",
    "description": [
      "ty - 极速的 Python 类型检查器。"
    ]
  },
  "root": [
    {
      "name": "check",
      "tip": [
        "检查项目中的类型错误。"
      ],
      "option": [
        {
          "name": "--add-ignore",
          "tip": [
            "添加 ty: ignore 注释以抑制所有规则诊断。"
          ]
        },
        {
          "name": "--color",
          "tip": [
            "U: --color <WHEN>",
            "控制何时使用彩色输出。",
            "可选值: auto, always, never"
          ],
          "next": [
            {
              "name": "always",
              "tip": [
                "始终显示颜色。"
              ]
            },
            {
              "name": "auto",
              "tip": [
                "如果输出到交互式终端则显示颜色。"
              ]
            },
            {
              "name": "never",
              "tip": [
                "从不显示颜色。"
              ]
            }
          ]
        },
        {
          "name": "--config",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --config <CONFIG_OPTION>",
            "覆盖特定配置选项的 TOML 键值对。"
          ],
          "next": 0
        },
        {
          "name": "--config-file",
          "tip": [
            "U: --config-file <PATH>",
            "要用作配置的 ty.toml 文件的路径。"
          ],
          "next": 0
        },
        {
          "name": "--error",
          "tip": [
            "U: --error <RULE>",
            "将给定规则视为具有 'error' 严重性。",
            "使用 'all' 应用于所有规则。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--error-on-warning",
          "tip": [
            "如果有任何警告级别的诊断，则使用退出码 1。"
          ]
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <EXCLUDE>",
            "要从类型检查中排除的文件的 glob 模式。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--exit-zero",
          "tip": [
            "始终使用退出码 0，即使有错误级别的诊断。"
          ]
        },
        {
          "name": "--exit-zero-on-warning",
          "tip": [
            "如果没有错误级别的诊断，则使用退出码 0。"
          ]
        },
        {
          "name": "--extra-search-path",
          "tip": [
            "U: --extra-search-path <PATH>",
            "用作模块解析源的附加路径。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--fix",
          "tip": [
            "应用修复以解决错误。"
          ]
        },
        {
          "name": "--force-exclude",
          "tip": [
            "强制排除，即使对于直接在命令行上传递的路径。"
          ]
        },
        {
          "name": "--ignore",
          "tip": [
            "U: --ignore <RULE>",
            "禁用该规则。",
            "使用 'all' 应用于所有规则。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--no-progress",
          "tip": [
            "隐藏所有进度输出。"
          ]
        },
        {
          "name": "--output-format",
          "tip": [
            "U: --output-format <OUTPUT_FORMAT>",
            "用于打印诊断消息的格式。",
            "可选值: full, concise, gitlab, github, junit"
          ],
          "next": [
            {
              "name": "concise",
              "tip": [
                "简洁打印诊断，每行一个。"
              ]
            },
            {
              "name": "full",
              "tip": [
                "详细打印诊断，包含上下文和有用的提示（默认）。"
              ]
            },
            {
              "name": "github",
              "tip": [
                "以 GitHub Actions 格式打印诊断。"
              ]
            },
            {
              "name": "gitlab",
              "tip": [
                "以 GitLab Code Quality 格式打印诊断。"
              ]
            },
            {
              "name": "junit",
              "tip": [
                "以 JUnit XML 报告打印诊断。"
              ]
            }
          ]
        },
        {
          "name": "--project",
          "tip": [
            "U: --project <PROJECT>",
            "在给定的项目目录中运行命令。"
          ],
          "next": 0
        },
        {
          "name": "--python",
          "tip": [
            "U: --python <PATH>",
            "项目 Python 环境或解释器的路径。"
          ],
          "next": 0
        },
        {
          "name": "--python-platform",
          "tip": [
            "U: --python-platform <PLATFORM>",
            "解析类型时假定的目标平台。"
          ],
          "next": 0
        },
        {
          "name": "--python-version",
          "tip": [
            "U: --python-version <VERSION>",
            "解析类型时假定的 Python 版本。",
            "可选值: 3.7, 3.8, 3.9, 3.10, 3.11, 3.12, 3.13, 3.14, 3.15"
          ],
          "next": [
            {
              "name": "3.10",
              "tip": [
                "Python 3.10。"
              ]
            },
            {
              "name": "3.11",
              "tip": [
                "Python 3.11。"
              ]
            },
            {
              "name": "3.12",
              "tip": [
                "Python 3.12。"
              ]
            },
            {
              "name": "3.13",
              "tip": [
                "Python 3.13。"
              ]
            },
            {
              "name": "3.14",
              "tip": [
                "Python 3.14。"
              ]
            },
            {
              "name": "3.15",
              "tip": [
                "Python 3.15。"
              ]
            },
            {
              "name": "3.7",
              "tip": [
                "Python 3.7。"
              ]
            },
            {
              "name": "3.8",
              "tip": [
                "Python 3.8。"
              ]
            },
            {
              "name": "3.9",
              "tip": [
                "Python 3.9。"
              ]
            }
          ]
        },
        {
          "name": "--quiet",
          "alias": [
            "-q"
          ],
          "tip": [
            "U: -q, --quiet",
            "使用安静输出。",
            "使用 -qq 静默输出。"
          ]
        },
        {
          "name": "--respect-ignore-files",
          "tip": [
            "通过 .gitignore 遵守文件排除。"
          ]
        },
        {
          "name": "--typeshed",
          "tip": [
            "U: --typeshed <PATH>",
            "用于 stdlib typeshed 存根的自定义目录。"
          ],
          "next": 0
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "使用详细输出。",
            "使用 -vv 或 -vvv 获取更详细的输出。"
          ]
        },
        {
          "name": "--warn",
          "tip": [
            "U: --warn <RULE>",
            "将给定规则视为具有 'warn' 严重性。",
            "使用 'all' 应用于所有规则。"
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--watch",
          "alias": [
            "-W"
          ],
          "tip": [
            "U: -W, --watch",
            "监视文件更改并重新检查与更改文件相关的文件。"
          ]
        }
      ]
    },
    {
      "name": "explain",
      "tip": [
        "解释 ty 的规则和其他部分。"
      ],
      "next": 0
    },
    {
      "name": "server",
      "tip": [
        "启动语言服务器。"
      ]
    },
    {
      "name": "version",
      "tip": [
        "显示 ty 的版本。"
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "打印版本。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "打印帮助。"
      ]
    }
  ]
}
