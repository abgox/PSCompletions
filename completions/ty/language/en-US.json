{
  "meta": {
    "url": "https://github.com/astral-sh/ruff",
    "description": [
      "ty - An extremely fast Python type checker."
    ]
  },
  "root": [
    {
      "name": "check",
      "tip": [
        "Check a project for type errors."
      ],
      "option": [
        {
          "name": "--add-ignore",
          "tip": [
            "Adds ty: ignore comments to suppress all rule diagnostics."
          ]
        },
        {
          "name": "--color",
          "tip": [
            "U: --color <WHEN>",
            "Control when colored output is used.",
            "Possible values: auto, always, never"
          ],
          "next": [
            {
              "name": "always",
              "tip": [
                "Always display colors."
              ]
            },
            {
              "name": "auto",
              "tip": [
                "Display colors if the output goes to an interactive terminal."
              ]
            },
            {
              "name": "never",
              "tip": [
                "Never display colors."
              ]
            }
          ]
        },
        {
          "name": "--config",
          "alias": [
            "-c"
          ],
          "tip": [
            "U: -c, --config <CONFIG_OPTION>",
            "A TOML key-value pair overriding a specific configuration option."
          ],
          "next": 0
        },
        {
          "name": "--config-file",
          "tip": [
            "U: --config-file <PATH>",
            "The path to a ty.toml file to use for configuration."
          ],
          "next": 0
        },
        {
          "name": "--error",
          "tip": [
            "U: --error <RULE>",
            "Treat the given rule as having severity 'error'.",
            "Use 'all' to apply to all rules."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--error-on-warning",
          "tip": [
            "Use exit code 1 if there are any warning-level diagnostics."
          ]
        },
        {
          "name": "--exclude",
          "tip": [
            "U: --exclude <EXCLUDE>",
            "Glob patterns for files to exclude from type checking."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--exit-zero",
          "tip": [
            "Always use exit code 0, even when there are error-level diagnostics."
          ]
        },
        {
          "name": "--exit-zero-on-warning",
          "tip": [
            "Use exit code 0 if there are no error-level diagnostics."
          ]
        },
        {
          "name": "--extra-search-path",
          "tip": [
            "U: --extra-search-path <PATH>",
            "Additional path to use as a module-resolution source."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--fix",
          "tip": [
            "Apply fixes to resolve errors."
          ]
        },
        {
          "name": "--force-exclude",
          "tip": [
            "Enforce exclusions, even for paths passed directly on the command-line."
          ]
        },
        {
          "name": "--ignore",
          "tip": [
            "U: --ignore <RULE>",
            "Disables the rule.",
            "Use 'all' to apply to all rules."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--no-progress",
          "tip": [
            "Hide all progress outputs."
          ]
        },
        {
          "name": "--output-format",
          "tip": [
            "U: --output-format <OUTPUT_FORMAT>",
            "The format to use for printing diagnostic messages.",
            "Possible values: full, concise, gitlab, github, junit"
          ],
          "next": [
            {
              "name": "concise",
              "tip": [
                "Print diagnostics concisely, one per line."
              ]
            },
            {
              "name": "full",
              "tip": [
                "Print diagnostics verbosely, with context and helpful hints (default)."
              ]
            },
            {
              "name": "github",
              "tip": [
                "Print diagnostics in GitHub Actions format."
              ]
            },
            {
              "name": "gitlab",
              "tip": [
                "Print diagnostics in GitLab Code Quality format."
              ]
            },
            {
              "name": "junit",
              "tip": [
                "Print diagnostics as JUnit XML report."
              ]
            }
          ]
        },
        {
          "name": "--project",
          "tip": [
            "U: --project <PROJECT>",
            "Run the command within the given project directory."
          ],
          "next": 0
        },
        {
          "name": "--python",
          "tip": [
            "U: --python <PATH>",
            "Path to your project's Python environment or interpreter."
          ],
          "next": 0
        },
        {
          "name": "--python-platform",
          "tip": [
            "U: --python-platform <PLATFORM>",
            "Target platform to assume when resolving types."
          ],
          "next": 0
        },
        {
          "name": "--python-version",
          "tip": [
            "U: --python-version <VERSION>",
            "Python version to assume when resolving types.",
            "Possible values: 3.7, 3.8, 3.9, 3.10, 3.11, 3.12, 3.13, 3.14, 3.15"
          ],
          "next": [
            {
              "name": "3.10",
              "tip": [
                "Python 3.10."
              ]
            },
            {
              "name": "3.11",
              "tip": [
                "Python 3.11."
              ]
            },
            {
              "name": "3.12",
              "tip": [
                "Python 3.12."
              ]
            },
            {
              "name": "3.13",
              "tip": [
                "Python 3.13."
              ]
            },
            {
              "name": "3.14",
              "tip": [
                "Python 3.14."
              ]
            },
            {
              "name": "3.15",
              "tip": [
                "Python 3.15."
              ]
            },
            {
              "name": "3.7",
              "tip": [
                "Python 3.7."
              ]
            },
            {
              "name": "3.8",
              "tip": [
                "Python 3.8."
              ]
            },
            {
              "name": "3.9",
              "tip": [
                "Python 3.9."
              ]
            }
          ]
        },
        {
          "name": "--quiet",
          "alias": [
            "-q"
          ],
          "tip": [
            "U: -q, --quiet",
            "Use quiet output.",
            "Use -qq for silent output."
          ]
        },
        {
          "name": "--respect-ignore-files",
          "tip": [
            "Respect file exclusions via .gitignore."
          ]
        },
        {
          "name": "--typeshed",
          "tip": [
            "U: --typeshed <PATH>",
            "Custom directory to use for stdlib typeshed stubs."
          ],
          "next": 0
        },
        {
          "name": "--verbose",
          "alias": [
            "-v"
          ],
          "tip": [
            "U: -v, --verbose",
            "Use verbose output.",
            "Use -vv or -vvv for more verbose output."
          ]
        },
        {
          "name": "--warn",
          "tip": [
            "U: --warn <RULE>",
            "Treat the given rule as having severity 'warn'.",
            "Use 'all' to apply to all rules."
          ],
          "repeat": 99,
          "next": 0
        },
        {
          "name": "--watch",
          "alias": [
            "-W"
          ],
          "tip": [
            "U: -W, --watch",
            "Watch files for changes and recheck files related to the changed files."
          ]
        }
      ]
    },
    {
      "name": "explain",
      "tip": [
        "Explain rules and other parts of ty."
      ],
      "next": 0
    },
    {
      "name": "server",
      "tip": [
        "Start the language server."
      ]
    },
    {
      "name": "version",
      "tip": [
        "Display ty's version."
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "U: -V, --version",
        "Print version."
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --help",
        "Print help."
      ]
    }
  ]
}
