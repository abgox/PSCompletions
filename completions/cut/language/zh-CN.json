{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "从标准输入或输入文件的每一行中打印指定的字节或字段列。",
      "补全基于 [uutils/coreutils](https://github.com/uutils/coreutils) 编写。"
    ]
  },
  "option": [
    {
      "name": "--bytes",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --bytes <LIST>",
        "从输入源中筛选字节列"
      ],
      "next": 0
    },
    {
      "name": "--characters",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: -c, --characters <LIST>",
        "字符模式的别名"
      ],
      "next": 0
    },
    {
      "name": "--complement",
      "tip": [
        "反转筛选 - 显示除筛选列之外的所有列，而不是仅显示筛选的列"
      ]
    },
    {
      "name": "--delimiter",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --delimiter <DELIM>",
        "指定分隔输入源中字段的分隔符。",
        "默认为 Tab。"
      ],
      "next": 0
    },
    {
      "name": "--fields",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --fields <LIST>",
        "从输入源中筛选字段列"
      ],
      "next": 0
    },
    {
      "name": "--only-delimited",
      "alias": [
        "-s"
      ],
      "tip": [
        "在字段模式下，仅输出包含分隔符的行"
      ]
    },
    {
      "name": "--output-delimiter",
      "tip": [
        "U: --output-delimiter <NEW_DELIM>",
        "在字段模式下，将输出行中的分隔符替换为此选项的参数"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    },
    {
      "name": "--zero-terminated",
      "alias": [
        "-z"
      ],
      "tip": [
        "按 \\0（NULL 字符）而不是按行来筛选列"
      ]
    },
    {
      "name": "-w",
      "tip": [
        "使用任意数量的空白字符（空格、制表符）来分隔输入源中的字段（FreeBSD 扩展）。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
