{
  "meta": {
    "url": "https://github.com/winpax/sfsu",
    "description": [
      "可以替代 Scoop 最慢部分的实用工具，运行速度提升 30-100 倍。"
    ]
  },
  "root": [
    {
      "name": "app",
      "tip": [
        "管理应用的命令"
      ]
    },
    {
      "name": "bucket",
      "tip": [
        "管理 bucket 的命令"
      ]
    },
    {
      "name": "cache",
      "tip": [
        "显示或清除下载缓存"
      ]
    },
    {
      "name": "cat",
      "tip": [
        "显示指定清单的内容"
      ]
    },
    {
      "name": "checkup",
      "tip": [
        "检查常见问题"
      ]
    },
    {
      "name": "credits",
      "tip": [
        "显示致谢信息"
      ]
    },
    {
      "name": "depends",
      "tip": [
        "列出给定包的依赖项, 按安装顺序排列"
      ]
    },
    {
      "name": "describe",
      "tip": [
        "描述一个包"
      ]
    },
    {
      "name": "download",
      "tip": [
        "下载指定的应用"
      ]
    },
    {
      "name": "export",
      "tip": [
        "以 JSON 格式导出已安装的应用、bucket (以及可选的配置)"
      ]
    },
    {
      "name": "help",
      "tip": [
        "打印此消息或给定子命令的帮助信息"
      ]
    },
    {
      "name": "home",
      "tip": [
        "打开应用主页"
      ]
    },
    {
      "name": "hook",
      "tip": [
        "为给定的 shell 生成钩子"
      ]
    },
    {
      "name": "info",
      "tip": [
        "显示包的信息"
      ]
    },
    {
      "name": "list",
      "tip": [
        "列出所有已安装的包"
      ]
    },
    {
      "name": "outdated",
      "tip": [
        "列出过时的 bucket 和/或包"
      ]
    },
    {
      "name": "scan",
      "tip": [
        "使用 `VirusTotal` 扫描文件"
      ]
    },
    {
      "name": "search",
      "tip": [
        "搜索一个包"
      ]
    },
    {
      "name": "status",
      "tip": [
        "显示状态并检查新的应用版本"
      ]
    },
    {
      "name": "unused-buckets",
      "tip": [
        "查找没有已安装包的 bucket"
      ]
    },
    {
      "name": "update",
      "tip": [
        "更新 Scoop 和 Scoop bucket"
      ]
    }
  ],
  "option": [
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--assume-yes",
      "alias": [
        "-y"
      ],
      "tip": [
        "自动确认所有提示"
      ]
    },
    {
      "name": "--disable-git",
      "tip": [
        "禁用程序某些部分的 git 命令。",
        "允许 sfsu 在未安装 git 的情况下完全运行, 但可能会影响性能。",
        "[env: DISABLE_GIT=]"
      ]
    },
    {
      "name": "--global",
      "alias": [
        "-g"
      ],
      "tip": [
        "使用全局 Scoop 上下文"
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h"
      ],
      "tip": [
        "显示帮助信息。"
      ]
    },
    {
      "name": "--json",
      "tip": [
        "以原始 JSON 格式输出, 而非人类可读格式"
      ]
    },
    {
      "name": "--no-color",
      "tip": [
        "禁用终端格式化",
        "[env: NO_COLOR=]"
      ]
    },
    {
      "name": "--verbose",
      "alias": [
        "-v"
      ],
      "tip": [
        "启用详细日志"
      ]
    }
  ]
}
