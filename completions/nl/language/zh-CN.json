{
  "meta": {
    "url": "https://github.com/uutils/coreutils",
    "description": [
      "Number lines of files.",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--body-numbering",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --body-numbering <STYLE>",
        "use STYLE for numbering body lines"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "number all lines"
          ]
        },
        {
          "name": "n",
          "tip": [
            "number no lines"
          ]
        },
        {
          "name": "pBRE",
          "tip": [
            "number only lines that contain a match for the basic regular expression, BRE"
          ]
        },
        {
          "name": "t",
          "tip": [
            "number only nonempty lines"
          ]
        }
      ]
    },
    {
      "name": "--footer-numbering",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --footer-numbering <STYLE>",
        "use STYLE for numbering footer lines"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "number all lines"
          ]
        },
        {
          "name": "n",
          "tip": [
            "number no lines"
          ]
        },
        {
          "name": "pBRE",
          "tip": [
            "number only lines that contain a match for the basic regular expression, BRE"
          ]
        },
        {
          "name": "t",
          "tip": [
            "number only nonempty lines"
          ]
        }
      ]
    },
    {
      "name": "--header-numbering",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --header-numbering <STYLE>",
        "use STYLE for numbering header lines"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "number all lines"
          ]
        },
        {
          "name": "n",
          "tip": [
            "number no lines"
          ]
        },
        {
          "name": "pBRE",
          "tip": [
            "number only lines that contain a match for the basic regular expression, BRE"
          ]
        },
        {
          "name": "t",
          "tip": [
            "number only nonempty lines"
          ]
        }
      ]
    },
    {
      "name": "--join-blank-lines",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --join-blank-lines <NUMBER>",
        "group of NUMBER empty lines counted as one"
      ],
      "next": 0
    },
    {
      "name": "--line-increment",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --line-increment <NUMBER>",
        "line number increment at each line"
      ],
      "next": 0
    },
    {
      "name": "--no-renumber",
      "alias": [
        "-p"
      ],
      "tip": [
        "do not reset line numbers at logical pages"
      ]
    },
    {
      "name": "--number-format",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --number-format <FORMAT>",
        "insert line numbers according to FORMAT"
      ],
      "next": [
        {
          "name": "ln",
          "tip": [
            "left justified, no leading zeros"
          ]
        },
        {
          "name": "rn",
          "tip": [
            "right justified, no leading zeros"
          ]
        },
        {
          "name": "rz",
          "tip": [
            "right justified, leading zeros"
          ]
        }
      ]
    },
    {
      "name": "--number-separator",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --number-separator <STRING>",
        "add STRING after (possible) line number"
      ],
      "next": 0
    },
    {
      "name": "--number-width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --number-width <NUMBER>",
        "use NUMBER columns for line numbers"
      ],
      "next": 0
    },
    {
      "name": "--section-delimiter",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --section-delimiter <CC>",
        "use CC for separating logical pages"
      ],
      "next": 0
    },
    {
      "name": "--starting-line-number",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --starting-line-number <NUMBER>",
        "first line number on each logical page"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
