{
  "meta": {
    "url": "https://uutils.org",
    "description": [
      "为文件的行编号。",
      "Completion was written based on [uutils/coreutils](https://github.com/uutils/coreutils)."
    ]
  },
  "option": [
    {
      "name": "--body-numbering",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: -b, --body-numbering <STYLE>",
        "使用 STYLE 为正文行编号"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "为所有行编号"
          ]
        },
        {
          "name": "n",
          "tip": [
            "不为任何行编号"
          ]
        },
        {
          "name": "pBRE",
          "tip": [
            "仅为包含基本正则表达式 BRE 匹配的行编号"
          ]
        },
        {
          "name": "t",
          "tip": [
            "仅为非空行编号"
          ]
        }
      ]
    },
    {
      "name": "--footer-numbering",
      "alias": [
        "-f"
      ],
      "tip": [
        "U: -f, --footer-numbering <STYLE>",
        "使用 STYLE 为页脚行编号"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "为所有行编号"
          ]
        },
        {
          "name": "n",
          "tip": [
            "不为任何行编号"
          ]
        },
        {
          "name": "pBRE",
          "tip": [
            "仅为包含基本正则表达式 BRE 匹配的行编号"
          ]
        },
        {
          "name": "t",
          "tip": [
            "仅为非空行编号"
          ]
        }
      ]
    },
    {
      "name": "--header-numbering",
      "alias": [
        "-h"
      ],
      "tip": [
        "U: -h, --header-numbering <STYLE>",
        "使用 STYLE 为页眉行编号"
      ],
      "next": [
        {
          "name": "a",
          "tip": [
            "为所有行编号"
          ]
        },
        {
          "name": "n",
          "tip": [
            "不为任何行编号"
          ]
        },
        {
          "name": "pBRE",
          "tip": [
            "仅为包含基本正则表达式 BRE 匹配的行编号"
          ]
        },
        {
          "name": "t",
          "tip": [
            "仅为非空行编号"
          ]
        }
      ]
    },
    {
      "name": "--join-blank-lines",
      "alias": [
        "-l"
      ],
      "tip": [
        "U: -l, --join-blank-lines <NUMBER>",
        "NUMBER 个空行视为一组"
      ],
      "next": 0
    },
    {
      "name": "--line-increment",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: -i, --line-increment <NUMBER>",
        "每行的行号增量"
      ],
      "next": 0
    },
    {
      "name": "--no-renumber",
      "alias": [
        "-p"
      ],
      "tip": [
        "不在逻辑页重置行号"
      ]
    },
    {
      "name": "--number-format",
      "alias": [
        "-n"
      ],
      "tip": [
        "U: -n, --number-format <FORMAT>",
        "根据 FORMAT 插入行号"
      ],
      "next": [
        {
          "name": "ln",
          "tip": [
            "左对齐，无前导零"
          ]
        },
        {
          "name": "rn",
          "tip": [
            "右对齐，无前导零"
          ]
        },
        {
          "name": "rz",
          "tip": [
            "右对齐，有前导零"
          ]
        }
      ]
    },
    {
      "name": "--number-separator",
      "alias": [
        "-s"
      ],
      "tip": [
        "U: -s, --number-separator <STRING>",
        "在（可能的）行号后添加 STRING"
      ],
      "next": 0
    },
    {
      "name": "--number-width",
      "alias": [
        "-w"
      ],
      "tip": [
        "U: -w, --number-width <NUMBER>",
        "使用 NUMBER 列作为行号宽度"
      ],
      "next": 0
    },
    {
      "name": "--section-delimiter",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: -d, --section-delimiter <CC>",
        "使用 CC 分隔逻辑页"
      ],
      "next": 0
    },
    {
      "name": "--starting-line-number",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: -v, --starting-line-number <NUMBER>",
        "每个逻辑页的起始行号"
      ],
      "next": 0
    },
    {
      "name": "--version",
      "alias": [
        "-V"
      ],
      "tip": [
        "显示版本信息。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--help",
      "tip": [
        "显示帮助信息。"
      ]
    }
  ]
}
